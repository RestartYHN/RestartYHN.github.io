---
import { i18n } from 'astro:config/client';
import { Icon } from 'astro-icon/components';
import { findMeAccounts } from '@/config';

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const isEn = currentLang === 'en';
const accounts = findMeAccounts.filter((item) => item.enabled !== false);

const iconByPlatform: Record<string, string> = {
  steam: 'fa6-brands:steam',
  qzone: 'fa6-brands:qq',
  qq: 'fa6-brands:qq',
  'qq music': 'fa6-solid:music',
  'netease music': 'fa6-solid:music',
  netease: 'fa6-solid:music',
  github: 'fa6-brands:github',
  x: 'fa6-brands:x-twitter',
  twitter: 'fa6-brands:x-twitter',
  bilibili: 'simple-icons:bilibili',
  discord: 'fa6-brands:discord',
  telegram: 'fa6-brands:telegram',
  linkedin: 'fa6-brands:linkedin',
  instagram: 'fa6-brands:instagram',
  youtube: 'fa6-brands:youtube',
  twitch: 'fa6-brands:twitch',
};

const getPlatformIcon = (platform: string) => {
  const key = platform.toLowerCase();
  return iconByPlatform[key] || 'fa6-solid:link';
};
---

{accounts.length > 0 && (
  <section class="mx-auto mt-8 mb-8 w-full max-w-[var(--page-width)]">
    <div class="rounded-2xl border border-[var(--button-border-color)] bg-[color-mix(in_oklab,var(--bg-color)_92%,transparent)] p-5 shadow-[0_8px_24px_rgba(0,0,0,0.06)]">
      <h2 class="text-2xl font-bold text-[var(--text-color)]">
        {isEn ? 'Where you can find me' : '你可以在这里找到我'}
      </h2>
      <p class="mt-1 text-sm text-[var(--text-color-70)]">
        {isEn ? 'Choose a platform below and jump directly to my profile.' : '点击下方平台图标，可直接跳转到我的账号主页。'}
      </p>

      <div class="mt-5 flex flex-wrap items-center gap-3">
        {accounts.map((item) => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            title={`${item.platform} - ${item.account}`}
            aria-label={`${item.platform} - ${item.account}`}
            class="group inline-flex h-11 w-11 items-center justify-center rounded-full border border-[var(--button-border-color)] bg-[var(--bg-color)] text-[var(--text-color-70)] transition-all duration-200 hover:-translate-y-0.5 hover:border-[var(--link-color)] hover:text-[var(--link-color)]"
          >
            <Icon name={getPlatformIcon(item.platform)} class="h-5 w-5" />
          </a>
        ))}
      </div>

      <div class="mt-3 flex flex-wrap gap-2 text-xs text-[var(--text-color-70)]">
        {accounts.map((item) => (
          <span class="rounded-full border border-[var(--button-border-color)] px-2.5 py-1">
            {item.platform}
          </span>
        ))}
      </div>
    </div>
  </section>
)}
