---
import { musicConfig } from '@/data/music';
import { i18n } from 'astro:config/client';

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const isEn = currentLang === 'en';
---

<section class="mx-auto mt-8 mb-8 w-full max-w-[var(--page-width)]">
  <div id="music-stats-card" class="rounded-2xl border border-[var(--button-border-color)] bg-[color-mix(in_oklab,var(--bg-color)_92%,transparent)] p-5 shadow-[0_8px_24px_rgba(0,0,0,0.06)] hidden">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold text-[var(--text-color)]">
        {isEn ? 'Weekly Listening' : '听歌统计'}
      </h2>
      <a href={isEn ? '/music' : '/zh/music'} class="text-sm text-[var(--link-color)] hover:underline">
        {isEn ? 'Full page' : '完整音乐页'}
      </a>
    </div>

    <div id="music-stats-summary" class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5 pb-4 border-b border-[var(--button-border-color)]">
      <div class="text-center"><div id="stat-week-duration" class="text-xl font-bold text-[var(--text-color)]">--</div><div class="text-xs text-[var(--text-color-70)]">{isEn ? 'Week' : '本周时长'}</div></div>
      <div class="text-center"><div id="stat-days" class="text-xl font-bold text-[var(--text-color)]">--</div><div class="text-xs text-[var(--text-color-70)]">{isEn ? 'Days' : '听歌天数'}</div></div>
      <div class="text-center"><div id="stat-today-count" class="text-xl font-bold text-[var(--text-color)]">--</div><div class="text-xs text-[var(--text-color-70)]">{isEn ? 'Today songs' : '今日歌曲'}</div></div>
      <div class="text-center"><div id="stat-today-dur" class="text-xl font-bold text-[var(--text-color)]">--</div><div class="text-xs text-[var(--text-color-70)]">{isEn ? 'Today' : '今日收听'}</div></div>
    </div>

    <h3 class="text-sm font-semibold text-[var(--text-color-70)] mb-3">{isEn ? 'Top 10 this week' : '本周 Top 10'}</h3>
    <div id="music-stats-list" class="space-y-2"></div>
    <p id="music-stats-empty" class="text-sm text-[var(--text-color-70)] hidden">
      {isEn ? 'No data yet.' : '暂无数据，去网易云听歌吧！'}
    </p>
  </div>
</section>

<script>
  const API = musicConfig.apiBase;
  if (!API) return;

  const card = document.getElementById('music-stats-card');
  const list = document.getElementById('music-stats-list');
  const empty = document.getElementById('music-stats-empty');
  const isEn = document.documentElement.lang === 'en';

  function fmtDuration(ms) {
    if (!ms) return '--';
    const h = Math.floor(ms / 3600000);
    const m = Math.floor((ms % 3600000) / 60000);
    return h > 0 ? `${h}h ${m}m` : `${m}m`;
  }

  async function load() {
    try {
      const res = await fetch(`${API}/api/music/record`, { referrerPolicy: 'no-referrer' });
      const json = await res.json();
      if (json.code !== 200 || !Array.isArray(json.data?.top) || !json.data.top.length) {
        empty.classList.remove('hidden');
        card.classList.remove('hidden');
        return;
      }
      const d = json.data;
      document.getElementById('stat-week-duration').textContent = fmtDuration(d.weekDurationMs);
      document.getElementById('stat-days').textContent = d.listeningDays;
      document.getElementById('stat-today-count').textContent = d.todaySongs;
      document.getElementById('stat-today-dur').textContent = fmtDuration(d.todayDurationMs);

      const playsWord = isEn ? 'plays' : '次';
      list.innerHTML = d.top.map((t, i) => `
        <a href="https://music.163.com/#/song?id=${t.id}" target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-3 rounded-lg p-1.5 transition-colors hover:bg-[var(--button-hover-color)] no-underline">
          <span class="w-5 text-center text-xs font-bold ${i < 3 ? 'text-[#d5a56a]' : 'text-[var(--text-color-70)]'}">${i + 1}</span>
          <div class="h-9 w-9 rounded-md bg-[var(--button-hover-color)] bg-cover bg-center flex-shrink-0" style="background-image:url(${t.cover}?param=60y60)"></div>
          <div class="min-w-0 flex-1">
            <p class="text-xs font-semibold text-[var(--text-color)] truncate">${t.title}</p>
          </div>
          <span class="text-xs text-[var(--text-color-70)] flex-shrink-0">${t.playCount}${playsWord}</span>
        </a>
      `).join('');
      card.classList.remove('hidden');
    } catch (e) {
      console.debug('[music-stats]', e);
    }
  }

  load();
  document.addEventListener('astro:page-load', load);
</script>
