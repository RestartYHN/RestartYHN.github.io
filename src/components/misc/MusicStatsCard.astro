---
import { musicConfig } from '@/data/music';
import { i18n } from 'astro:config/client';

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const isEn = currentLang === 'en';
---

<section class="mx-auto mt-8 mb-8 w-full max-w-[var(--page-width)]">
  <div id="music-stats-card" data-api={musicConfig.apiBase} class="rounded-2xl border border-[var(--button-border-color)] bg-[color-mix(in_oklab,var(--bg-color)_92%,transparent)] p-5 shadow-[0_8px_24px_rgba(0,0,0,0.06)] hidden">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold text-[var(--text-color)]">
        {isEn ? 'Listening' : '听歌统计'}
      </h2>
      <div class="flex gap-2">
        <a href={isEn ? '/en/music' : '/music'} class="text-sm text-[var(--link-color)] hover:underline">
          {isEn ? 'Music' : '音乐页'}
        </a>
      </div>
    </div>

    <div id="music-stats-summary" class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5 pb-4 border-b border-[var(--button-border-color)]">
      <div class="text-center"><div id="stat-week-duration" class="text-xl font-bold text-[var(--text-color)]">--</div><div class="text-xs text-[var(--text-color-70)]">{isEn ? 'Week' : '最近一周'}</div></div>
      <div class="text-center"><div id="stat-days" class="text-xl font-bold text-[var(--text-color)]">--</div><div class="text-xs text-[var(--text-color-70)]">{isEn ? 'Days' : '听歌天数'}</div></div>
      <div class="text-center"><div id="stat-today-count" class="text-xl font-bold text-[var(--text-color)]">--</div><div class="text-xs text-[var(--text-color-70)]">{isEn ? 'Songs' : '今日歌曲'}</div></div>
      <div class="text-center"><div id="stat-today-dur" class="text-xl font-bold text-[var(--text-color)]">--</div><div class="text-xs text-[var(--text-color-70)]">{isEn ? 'Today' : '今日收听'}</div></div>
    </div>

    <div id="music-recent-block" class="mb-5 pb-4 border-b border-[var(--button-border-color)] hidden">
      <h3 class="text-sm font-semibold text-[var(--text-color-70)] mb-2">{isEn ? 'Recently Played' : '最近播放'}</h3>
      <div id="music-recent-list" class="music-stats-scroll" style="max-height:250px"></div>
    </div>

    <div class="flex items-center justify-between mb-3">
      <div class="flex gap-2 text-sm">
        <button id="st-btn-week" class="px-3 py-1 rounded-full border border-[var(--button-border-color)] font-semibold text-[var(--text-color)] bg-[var(--button-hover-color)]">{isEn ? 'Week' : '最近一周'}</button>
        <button id="st-btn-all" class="px-3 py-1 rounded-full border border-[var(--button-border-color)] text-[var(--text-color-70)]">{isEn ? 'All time' : '所有时间'}</button>
      </div>
      <span id="st-rank-count" class="text-xs text-[var(--text-color-70)]"></span>
    </div>
    <div id="music-stats-list" class="music-stats-scroll"></div>
    <p id="music-stats-empty" class="text-sm text-[var(--text-color-70)] hidden">
      {isEn ? 'No data yet.' : '暂无数据，去网易云听歌吧！'}
    </p>
  </div>
</section>

<style>
  .music-stats-scroll {
    max-height: 360px;
    overflow-y: auto;
    scroll-behavior: smooth;
  }
</style>

<script is:inline>
  (function () {
    var list = document.getElementById('music-stats-list');
    var empty = document.getElementById('music-stats-empty');
    var recentBlock = document.getElementById('music-recent-block');
    var recentList = document.getElementById('music-recent-list');
    var btnWeek = document.getElementById('st-btn-week');
    var btnAll = document.getElementById('st-btn-all');
    var rankCount = document.getElementById('st-rank-count');
    var cardEl = null;
    var currentType = '1';
    var allData = [];
    var isEn = document.documentElement.lang === 'en';

    function fmtDuration(ms) {
      if (!ms) return '--';
      var h = Math.floor(ms / 3600000);
      var m = Math.floor((ms % 3600000) / 60000);
      return h > 0 ? h + 'h ' + m + 'm' : m + 'm';
    }

    function formatPlayedTime(ms) {
      if (!ms) return '';
      var diff = Date.now() - Number(ms);
      if (diff <= 0) return isEn ? 'just now' : '刚刚';
      var min = Math.floor(diff / 60000);
      if (min < 60) return isEn ? min + 'm ago' : min + ' 分钟前';
      var hour = Math.floor(min / 60);
      if (hour < 24) return isEn ? hour + 'h ago' : hour + ' 小时前';
      var day = Math.floor(hour / 24);
      return isEn ? day + 'd ago' : day + ' 天前';
    }

    async function load(type) {
      var card = document.getElementById('music-stats-card');
      if (!card) return;
      var API = card.getAttribute('data-api');
      if (!API) return;
      cardEl = card;
      var list = document.getElementById('music-stats-list');
      var empty = document.getElementById('music-stats-empty');
      var recentBlock = document.getElementById('music-recent-block');
      var recentList = document.getElementById('music-recent-list');
      var rankCount = document.getElementById('st-rank-count');
        var json = await res.json();
        if (json.code !== 200 || !json.data) {
          if (empty) empty.classList.remove('hidden');
          card.classList.remove('hidden');
          return;
        }
        var d = json.data;
        setText('stat-week-duration', fmtDuration(d.weekDurationMs));
        setText('stat-days', String(d.listeningDays));
        setText('stat-today-count', String(d.todaySongs));
        setText('stat-today-dur', fmtDuration(d.todayDurationMs));

        var ranked = (d.top || []).filter(function (t) { return t.playCount >= 4; });
        allData = ranked;
        renderRecent(d.recent || []);
        renderList(ranked);
        card.classList.remove('hidden');
      } catch (e) {
        console.debug('[music-stats]', e);
      }
    }

    function renderRecent(items) {
      if (!recentBlock || !recentList) return;
      if (!items.length) {
        recentBlock.classList.add('hidden');
        return;
      }
      recentBlock.classList.remove('hidden');

      var html = '';
      for (var i = 0; i < items.length; i++) {
        var t = items[i];
        var timeStr = formatPlayedTime(t.playedAt);
        var coverStyle = t.cover ? 'background-image:url(' + t.cover + '?param=60y60)' : '';
        html += '<div class="flex items-center gap-3 rounded-lg p-1.5 cursor-pointer hover:bg-[var(--button-hover-color)] transition-colors" data-id="' + t.id + '">'
          + '<div class="h-9 w-9 rounded-md bg-[var(--button-hover-color)] bg-cover bg-center flex-shrink-0" style="' + coverStyle + '"></div>'
          + '<div class="min-w-0 flex-1">'
          + '<p class="text-xs font-semibold text-[var(--text-color)] truncate">' + esc(t.title) + '<span class="font-normal text-[var(--text-color-70)]"> — ' + esc(t.artist) + '</span></p>'
          + '</div>'
          + (timeStr ? '<span class="text-xs text-[var(--text-color-70)] flex-shrink-0">' + timeStr + '</span>' : '')
          + '</div>';
      }
      recentList.innerHTML = html;

      var domEls = recentList.querySelectorAll('[data-id]');
      for (var j = 0; j < domEls.length; j++) {
        domEls[j].addEventListener('click', (function (rec) {
          return async function () {
            var t = { id: rec.id, title: rec.title, artist: rec.artist, cover: rec.cover || '', audio: '', lyric: '', tlyric: '' };
            try {
              var fres = await fetch(API + '/api/music/track?id=' + rec.id, { referrerPolicy: 'no-referrer' });
              var fj = await fres.json();
              if (fj.code === 200 && fj.data) {
                t.audio = fj.data.audio || '';
                t.lyric = fj.data.lyric || '';
                t.tlyric = fj.data.tlyric || '';
              }
            } catch (e) {}
            var gc = window.__globalMusicBootstrapV1;
            if (gc && typeof gc.syncState === 'function') {
              gc.syncState({ tracks: [t], currentIndex: 0 });
              setTimeout(function () {
                var audio = document.getElementById('music-audio');
                if (audio) {
                  audio.removeAttribute('crossorigin');
                  audio.crossOrigin = null;
                  if (audio.paused) audio.play().catch(function(){});
                }
              }, 100);
            }
          };
        })(items[j]));
      }
    }

    function renderList(tracks) {
      if (!tracks.length) {
        empty.classList.remove('hidden');
        list.innerHTML = '';
        if (rankCount) rankCount.textContent = '';
        return;
      }
      empty.classList.add('hidden');
      if (rankCount) rankCount.textContent = tracks.length + ' ' + (isEn ? 'songs' : '首');

      var playsWord = isEn ? 'plays' : '次';
      var html = '';
      for (var i = 0; i < tracks.length; i++) {
        var t = tracks[i];
        html += '<div class="flex items-center gap-3 rounded-lg p-1.5 cursor-pointer hover:bg-[var(--button-hover-color)] transition-colors" data-id="' + t.id + '">'
          + '<span class="w-5 text-center text-xs font-bold ' + (i < 3 ? 'text-[#d5a56a]' : 'text-[var(--text-color-70)]') + '">' + (i + 1) + '</span>'
          + '<div class="h-9 w-9 rounded-md bg-[var(--button-hover-color)] bg-cover bg-center flex-shrink-0" style="background-image:url(' + (t.cover ? t.cover + '?param=60y60' : '') + ')"></div>'
          + '<div class="min-w-0 flex-1">'
          + '<p class="text-xs font-semibold text-[var(--text-color)] truncate">' + esc(t.title) + '</p>'
          + '</div>'
          + '<span class="text-xs text-[var(--text-color-70)] flex-shrink-0">' + t.playCount + playsWord + '</span>'
          + '</div>';
      }
      list.innerHTML = html;

      var items = list.querySelectorAll('[data-id]');
      for (var j = 0; j < items.length; j++) {
        items[j].addEventListener('click', (function (trk, idx) {
          return async function () {
            var t = { id: trk.id, title: trk.title, artist: trk.artist, cover: trk.cover || '', audio: '', lyric: '', tlyric: '' };
            try {
              var fres = await fetch(API + '/api/music/track?id=' + trk.id, { referrerPolicy: 'no-referrer' });
              var fj = await fres.json();
              if (fj.code === 200 && fj.data) {
                t.audio = fj.data.audio || '';
                t.lyric = fj.data.lyric || '';
                t.tlyric = fj.data.tlyric || '';
              }
            } catch (e) {}

            var all = [];
            var foundIdx = 0;
            for (var k = 0; k < tracks.length; k++) {
              var x = { id: tracks[k].id, title: tracks[k].title, artist: tracks[k].artist, cover: tracks[k].cover || '', audio: '', lyric: '', tlyric: '' };
              if (tracks[k].id === trk.id) {
                x.audio = t.audio;
                x.lyric = t.lyric;
                x.tlyric = t.tlyric;
                foundIdx = k;
              }
              all.push(x);
            }
            var gc = window.__globalMusicBootstrapV1;
            if (gc && typeof gc.syncState === 'function') {
              gc.syncState({ tracks: all, currentIndex: foundIdx });
              setTimeout(function () {
                var audio = document.getElementById('music-audio');
                if (audio) {
                  audio.removeAttribute('crossorigin');
                  audio.crossOrigin = null;
                  if (audio.paused) audio.play().catch(function(){});
                }
              }, 100);
            }
          };
        })(tracks[j], j));
      }
    }

    function setText(id, val) {
      var el = document.getElementById(id);
      if (el) el.textContent = val;
    }

    function esc(s) {
      var d = document.createElement('div');
      d.textContent = s || '';
      return d.innerHTML;
    }

    load('1');

    if (btnWeek) btnWeek.addEventListener('click', function () {
      if (currentType === '1') return;
      currentType = '1';
      btnWeek.className = btnWeek.className.replace('text-[var(--text-color-70)]', 'text-[var(--text-color)]').replace('bg-transparent', 'bg-[var(--button-hover-color)]');
      if (!btnWeek.className.includes('bg-[')) btnWeek.className += ' bg-[var(--button-hover-color)] font-semibold';
      btnAll.className = btnAll.className.replace('text-[var(--text-color)] font-semibold', 'text-[var(--text-color-70)]').replace('bg-[var(--button-hover-color)]', '');
      load('1');
    });

    if (btnAll) btnAll.addEventListener('click', function () {
      if (currentType === '0') return;
      currentType = '0';
      btnAll.className = btnAll.className.replace('text-[var(--text-color-70)]', 'text-[var(--text-color)] font-semibold').replace('bg-transparent', 'bg-[var(--button-hover-color)]');
      if (!btnAll.className.includes('bg-[')) btnAll.className += ' bg-[var(--button-hover-color)] font-semibold';
      btnWeek.className = btnWeek.className.replace('text-[var(--text-color)] font-semibold', 'text-[var(--text-color-70)]').replace('bg-[var(--button-hover-color)]', '');
      load('0');
    });

    document.addEventListener('astro:page-load', function () { load(currentType); });
  })();
</script>
