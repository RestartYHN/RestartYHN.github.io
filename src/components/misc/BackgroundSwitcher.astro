---
import { Icon } from 'astro-icon/components';
import bgMeta from '../../data/bg-meta';

const images = Astro.props.images || [
  '/cg/1st.jpg',
  '/cg/2nd.jpg',
  '/cg/3rd.jpg',
  '/cg/4th.jpg',
  '/cg/5th.jpg',
  '/cg/6th.jpg',
  '/cg/7th.jpg',
  '/cg/8th.jpg',
  '/cg/9th.jpg',
  '/cg/10th.jpg',
  '/cg/xmm.jpg',
  '/cg/dark-cg.jpg',
];
const id = 'global-bg-switcher';
---

<div id={id} class="bg-switcher" data-images={JSON.stringify(images)} data-meta={JSON.stringify(bgMeta)}>
  <div class="bg-switcher-controls" role="group" aria-label="Background switcher">
    <button class="bg-switcher-btn flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-lg border border-[var(--button-border-color)]" type="button" data-action="prev" title="Previous background">
      <Icon name="fa6-solid:chevron-left" class="w-3.5 h-3.5" />
    </button>
    <button class="bg-switcher-btn flex items-center justify-center w-9 h-9 md:w-10 md:h-10 rounded-lg border border-[var(--button-border-color)]" type="button" data-action="next" title="Next background">
      <Icon name="fa6-solid:chevron-right" class="w-3.5 h-3.5" />
    </button>
  </div>
</div>

<script is:inline type="module">
  (function () {
    const id = 'global-bg-switcher';
    let el = null;
    let prevEl = null;
    let images = [];
    let metaMap = {};
    let idx = 0;
    let prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
    let globalBound = false;

    function refreshElement() {
      el = document.getElementById(id);
      if (!el) return false;
      try { images = JSON.parse(el.dataset.images || '[]'); } catch (e) { images = []; }
      try { metaMap = JSON.parse(el.dataset.meta || '{}'); } catch (e) { metaMap = {}; }
      return true;
    }

    function apply() {
      const url = images.length ? `url('${images[idx]}')` : 'none';
      document.body.style.setProperty('--bg-image', url);
      const key = images[idx];
      const meta = metaMap[key] || {};
      if (meta.position) document.body.style.setProperty('--bg-position', meta.position);
      else document.body.style.removeProperty('--bg-position');
      if (meta.size) document.body.style.setProperty('--bg-size', meta.size);
      else document.body.style.removeProperty('--bg-size');
      const curTheme = document.documentElement.getAttribute('data-theme');
      const isDark = curTheme === 'dark' || (!curTheme && prefersDark);
      let overlayVal = null;
      if (isDark) overlayVal = meta.overlayDark ?? meta.overlay ?? null;
      else overlayVal = meta.overlayLight ?? meta.overlay ?? null;
      if (overlayVal) document.body.style.setProperty('--bg-overlay', overlayVal);
      else document.body.style.removeProperty('--bg-overlay');
      console.debug('[BackgroundSwitcher] apply()', { idx, url });
    }

    function handleGlobalNext() {
      if (!refreshElement()) return;
      if (!images.length) return;
      idx = (idx + 1) % images.length;
      apply();
      localStorage.setItem('bgSwitcherIdx', String(idx));
    }

    function handleGlobalPrev() {
      if (!refreshElement()) return;
      if (!images.length) return;
      idx = (idx - 1 + images.length) % images.length;
      apply();
      localStorage.setItem('bgSwitcherIdx', String(idx));
    }

    function initSwitcher() {
      if (!refreshElement()) return;
      // If same element already bound, just apply current styles
      if (el === prevEl && el.dataset.bound === 'true') { apply(); return; }
      prevEl = el;

      // restore saved index or pick theme default
      const saved = localStorage.getItem('bgSwitcherIdx');
      if (saved !== null && !isNaN(Number(saved))) {
        const s = Number(saved);
        if (images.length && s >= 0 && s < images.length) idx = s;
      } else {
        const theme = document.documentElement.getAttribute('data-theme');
        if (theme === 'dark' || (!theme && prefersDark)) {
          const i = images.findIndex((p) => p.includes('dark-cg'));
          if (i >= 0) idx = i;
        } else {
          const i = images.findIndex((p) => p.includes('xmm'));
          if (i >= 0) idx = i;
        }
      }

      apply();

      // bind global handlers once
      if (!globalBound) {
        window.addEventListener('bg-switcher-next', handleGlobalNext);
        window.addEventListener('bg-switcher-prev', handleGlobalPrev);
        globalBound = true;
      }

      // bind local buttons only once per controls element
      const controls = el.querySelector('.bg-switcher-controls');
      if (controls && controls.dataset.bound !== 'true') {
        const prevBtn = controls.querySelector('[data-action="prev"]');
        const nextBtn = controls.querySelector('[data-action="next"]');
        if (prevBtn) prevBtn.addEventListener('click', (e) => {
          e.stopPropagation(); if (!images.length) return; idx = (idx - 1 + images.length) % images.length; apply(); localStorage.setItem('bgSwitcherIdx', String(idx));
        });
        if (nextBtn) nextBtn.addEventListener('click', (e) => {
          e.stopPropagation(); if (!images.length) return; idx = (idx + 1) % images.length; apply(); localStorage.setItem('bgSwitcherIdx', String(idx));
        });
        controls.dataset.bound = 'true';
      }
    }

    if (typeof window !== 'undefined') {
      document.addEventListener('DOMContentLoaded', initSwitcher);
      document.addEventListener('astro:page-load', initSwitcher);
      document.addEventListener('astro:after-swap', initSwitcher);
      window.addEventListener('beforeunload', () => {
        document.removeEventListener('astro:page-load', initSwitcher);
        document.removeEventListener('astro:after-swap', initSwitcher);
      });
    }
  })();
</script>

<style is:global>
  :root {
    --bg-image: none;
    --bg-position: center;
    --bg-size: cover;
    --bg-overlay: transparent;
  }

  body {
    background-image: var(--bg-image);
    background-position: var(--bg-position);
    background-size: var(--bg-size);
    background-repeat: no-repeat;
    background-attachment: fixed;
    transition: background-image 0.6s ease-in-out, background-color 0.3s ease;
  }

  /* overlay layer */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: var(--bg-overlay);
    z-index: 0;
    transition: background 0.3s ease;
  }

  .bg-switcher {
    position: relative;
    display: block;
    width: 0;
    height: 0;
    overflow: visible;
  }

  .bg-switcher-controls {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    display: flex;
    gap: 0.5rem;
    z-index: 60;
  }

  .bg-switcher-btn {
    background: color-mix(in oklab, var(--button-hover-color) 80%, transparent);
    border: 1px solid var(--button-border-color);
    color: var(--text-color);
    padding: 0.35rem 0.6rem;
    border-radius: 0.5rem;
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
    box-shadow: 0 6px 16px rgba(0,0,0,0.06);
    transition: transform .15s ease, background .15s ease;
  }

  .bg-switcher-controls.in-header .bg-switcher-btn {
    width: 30px;
    height: 30px;
    padding: 0;
    display: inline-grid;
    place-items: center;
    border-radius: 6px;
    font-size: 0.95rem;
  }

  @media (min-width: 1200px) {
    .bg-switcher-controls.in-header .bg-switcher-btn {
      width: 28px;
      height: 28px;
      font-size: 0.9rem;
    }
  }

  .bg-switcher-btn:hover { transform: translateY(-2px); }
</style>
