---
import { musicConfig } from '@/data/music';
---

<div id="global-music-player" transition:persist>
  <audio id="music-audio" preload="metadata" class="hidden"></audio>

  {/* Playlist Popup Modal for Global Player */}
  <div id="global-music-playlist-modal" class="global-music-playlist-modal hidden">
    <div class="global-music-playlist-modal-backdrop" id="global-music-playlist-modal-backdrop"></div>
    <div class="global-music-playlist-modal-content">
      <div class="global-music-playlist-modal-header">
        <h3 class="global-music-playlist-modal-title">Playlist</h3>
        <button id="global-music-playlist-modal-close" class="global-music-playlist-modal-close" type="button">×</button>
      </div>
      <ul id="global-music-playlist-modal-list" class="global-music-playlist-modal-list"></ul>
    </div>
  </div>

  <div class="music-bottom-player" id="music-bottom-player">
    <div class="music-bottom-cover" id="music-bottom-cover"></div>
    <div class="min-w-0 flex-1">
      <p id="music-bottom-title" class="truncate font-semibold text-[var(--text-color)]">-</p>
      <p id="music-bottom-artist" class="truncate text-sm text-[var(--text-color-70)]">-</p>
      <div class="music-progress-wrap">
        <span id="music-current-time" class="music-time">0:00</span>
        <input id="music-progress" class="music-progress" type="range" min="0" max="1000" value="0" step="1" />
        <span id="music-total-time" class="music-time">0:00</span>
      </div>
    </div>
    <span id="music-player-position" class="music-position-info">-</span>
    {/* Play Mode Controls */}
    <button id="music-mode-toggle" class="music-control music-mode-toggle" type="button" aria-label="Play Mode" title="Toggle play mode">
      <span class="music-mode-icon music-mode-sequential">≡</span>
      <span class="music-mode-icon music-mode-loop hidden">↻</span>
      <span class="music-mode-icon music-mode-shuffle hidden">⤮</span>
    </button>
    <button id="music-prev" class="music-control" type="button" aria-label="Prev">◀</button>
    <button
      id="music-main-play"
      class="music-control primary music-control-play"
      type="button"
      aria-label="Play"
      aria-pressed="false"
      data-ui-rev="icon-v2"
    >
      <span class="music-control-icon music-control-icon-play" aria-hidden="true">▶</span>
      <span class="music-control-icon music-control-icon-pause hidden" aria-hidden="true">❚❚</span>
    </button>
    <button id="music-next" class="music-control" type="button" aria-label="Next">▶</button>
    <button id="music-playlist-btn" class="music-control music-playlist-btn" type="button" aria-label="Playlist" title="View playlist">
      <span>☰</span>
    </button>
  </div>
</div>

<style is:global>
  .music-bottom-player {
    position: fixed;
    left: 50%;
    transform: translateX(-50%);
    bottom: 0.8rem;
    width: min(960px, calc(100vw - 1.2rem));
    z-index: 60;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid var(--button-border-color);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--bg-color) 90%, transparent);
    padding: 0.75rem;
    backdrop-filter: blur(8px);
  }

  .music-bottom-cover {
    width: 54px;
    height: 54px;
    border-radius: 0.6rem;
    background: var(--button-hover-color);
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .music-progress-wrap {
    margin-top: 0.2rem;
    display: grid;
    grid-template-columns: 42px 1fr 42px;
    gap: 0.45rem;
    align-items: center;
  }

  .music-time {
    font-size: 0.72rem;
    color: var(--text-color-70);
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  .music-progress {
    width: 100%;
    height: 4px;
    appearance: none;
    border-radius: 999px;
    outline: none;
    background: color-mix(in oklab, var(--text-color-70) 18%, transparent);
  }

  .music-progress::-webkit-slider-thumb {
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #d5a56a;
    border: 2px solid color-mix(in oklab, #d5a56a 20%, white);
    cursor: pointer;
  }

  .music-control {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid var(--button-border-color);
    background: color-mix(in oklab, var(--bg-color) 85%, transparent);
    color: var(--text-color);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
  }

  .music-control.primary {
    width: 44px;
    height: 44px;
    background: #d5a56a;
    border-color: #d5a56a;
    color: #fff;
  }

  .music-control-icon {
    display: inline-block;
    line-height: 1;
  }

  .music-control-icon.hidden {
    display: none;
  }

  .music-position-info {
    min-width: 52px;
    text-align: center;
    font-size: 0.72rem;
    color: var(--text-color-70);
  }

  @media (max-width: 768px) {
    .music-bottom-player {
      display: grid;
      grid-template-columns: 54px minmax(0, 1fr) auto auto auto;
      grid-template-areas:
        "cover info prev play next"
        "progress progress progress progress progress";
      gap: 0.45rem 0.5rem;
      align-items: center;
      padding: 0.65rem;
      width: calc(100vw - 0.8rem);
      bottom: 0.4rem;
    }

    .music-bottom-cover {
      grid-area: cover;
    }

    .music-bottom-player .min-w-0 {
      grid-area: info;
      min-width: 0;
    }

    #music-prev {
      grid-area: prev;
    }

    #music-main-play {
      grid-area: play;
    }

    #music-next {
      grid-area: next;
    }

    .music-progress-wrap {
      grid-area: progress;
      grid-column: 1 / -1;
      margin-top: 0.2rem;
      margin-left: -0.65rem;
      margin-right: -0.65rem;
      padding: 0 0.65rem;
      grid-template-columns: 34px 1fr 34px;
      gap: 0.35rem;
    }

    .music-position-info {
      display: none;
    }

    .music-control {
      width: 36px;
      height: 36px;
    }

    .music-control.primary {
      width: 40px;
      height: 40px;
    }

    .music-mode-toggle,
    .music-playlist-btn {
      display: none;
    }
  }

  /* Play Mode Toggle */
  .music-mode-toggle {
    font-size: 0.85rem;
  }

  .music-mode-icon.hidden {
    display: none;
  }

  .music-mode-toggle.active {
    background: #d5a56a;
    border-color: #d5a56a;
    color: #fff;
  }

  /* Global Playlist Modal */
  .global-music-playlist-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .global-music-playlist-modal.hidden {
    display: none;
  }

  .global-music-playlist-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .global-music-playlist-modal-content {
    position: relative;
    width: min(480px, calc(100vw - 2rem));
    max-height: 70vh;
    background: var(--bg-color);
    border: 1px solid var(--button-border-color);
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  }

  .global-music-playlist-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.2rem;
    border-bottom: 1px solid var(--button-border-color);
    background: color-mix(in oklab, var(--bg-color) 95%, transparent);
  }

  .global-music-playlist-modal-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-color);
    margin: 0;
  }

  .global-music-playlist-modal-close {
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--text-color-70);
    font-size: 1.5rem;
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 160ms ease;
  }

  .global-music-playlist-modal-close:hover {
    background: var(--button-hover-color);
  }

  .global-music-playlist-modal-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    overflow-y: auto;
    flex: 1;
  }

  .global-music-playlist-modal-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.2rem;
    cursor: pointer;
    transition: background-color 160ms ease;
  }

  .global-music-playlist-modal-item:hover {
    background: var(--button-hover-color);
  }

  .global-music-playlist-modal-item.active {
    background: color-mix(in oklab, #d5a56a 15%, transparent);
  }

  .global-music-playlist-modal-item-index {
    width: 2rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--text-color-70);
    flex-shrink: 0;
  }

  .global-music-playlist-modal-item.active .global-music-playlist-modal-item-index {
    color: #d5a56a;
  }

  .global-music-playlist-modal-item-info {
    flex: 1;
    min-width: 0;
  }

  .global-music-playlist-modal-item-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-color);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .global-music-playlist-modal-item-artist {
    font-size: 0.8rem;
    color: var(--text-color-70);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>

<script define:vars={{ musicConfig }}>
  const GLOBAL_MUSIC_KEY = '__globalMusicBootstrapV1';

  function isMusicPagePath() {
    return /\/music\/?$/i.test(window.location.pathname);
  }

  function formatClock(sec) {
    const t = Number.isFinite(sec) ? Math.max(0, Math.floor(sec)) : 0;
    const m = Math.floor(t / 60);
    const s = t % 60;
    return `${m}:${String(s).padStart(2, '0')}`;
  }

  function normalizeAudioUrl(rawUrl) {
    if (!rawUrl || typeof rawUrl !== 'string') return '';
    const trimmed = rawUrl.trim();
    if (!trimmed) return '';
    if (window.location.protocol === 'https:' && /^http:\/\/m\d+\.music\.126\.net\//i.test(trimmed)) {
      return trimmed.replace(/^http:\/\//i, 'https://');
    }
    return trimmed;
  }

  async function getJson(url) {
    const res = await fetch(url, { referrerPolicy: 'no-referrer' });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
  }

  function makeController() {
    const API_BASE = musicConfig.apiBase;

    const PLAY_MODE_KEY = 'music-play-mode';
    const PLAY_MODES = ['sequential', 'loop', 'shuffle'];

    const state = {
      tracks: [],
      currentIndex: 0,
      loaded: false,
      loading: false,
      bound: false,
      handlers: {},
      els: null,
      playMode: localStorage.getItem(PLAY_MODE_KEY) || 'sequential',
      shuffleHistory: [],
      shuffleIndex: -1,
    };

    // Bootstrap the global player with tracks from music page
    function bootstrap(options) {
      if (!options) return;
      if (Array.isArray(options.tracks) && options.tracks.length) {
        state.tracks = options.tracks;
        state.currentIndex = Number.isFinite(options.currentIndex) ? options.currentIndex : 0;
        state.loaded = true;
        // Update UI if bound
        if (state.bound && state.els) {
          const track = state.tracks[state.currentIndex];
          if (track) {
            updateNowPlaying(track);
          }
          updatePlayerPosition();
          updatePlayButtonState();
        }
      }
    }

    // Sync current playback state from music page
    function syncState(options) {
      if (!options) return;
      if (Array.isArray(options.tracks)) {
        state.tracks = options.tracks;
      }
      if (Number.isFinite(options.currentIndex)) {
        state.currentIndex = options.currentIndex;
      }
      if (state.bound && state.els) {
        const track = state.tracks[state.currentIndex];
        if (track) {
          updateNowPlaying(track);
        }
        updatePlayerPosition();
        updatePlayButtonState();
      }
    }

    // Get current state for external access
    function getState() {
      return {
        tracks: state.tracks,
        currentIndex: state.currentIndex,
        playMode: state.playMode,
        loaded: state.loaded,
      };
    }

    function getEls() {
      return {
        audio: document.getElementById('music-audio'),
        bottomCover: document.getElementById('music-bottom-cover'),
        bottomTitle: document.getElementById('music-bottom-title'),
        bottomArtist: document.getElementById('music-bottom-artist'),
        progressEl: document.getElementById('music-progress'),
        currentTimeEl: document.getElementById('music-current-time'),
        totalTimeEl: document.getElementById('music-total-time'),
        btnMainPlay: document.getElementById('music-main-play'),
        btnPrev: document.getElementById('music-prev'),
        btnNext: document.getElementById('music-next'),
        posEl: document.getElementById('music-player-position'),
        btnModeToggle: document.getElementById('music-mode-toggle'),
        btnPlaylist: document.getElementById('music-playlist-btn'),
        playlistModal: document.getElementById('global-music-playlist-modal'),
        playlistModalBackdrop: document.getElementById('global-music-playlist-modal-backdrop'),
        playlistModalClose: document.getElementById('global-music-playlist-modal-close'),
        playlistModalList: document.getElementById('global-music-playlist-modal-list'),
      };
    }

    function updatePlayModeUI() {
      const { btnModeToggle } = state.els || {};
      if (!btnModeToggle) return;
      const icons = btnModeToggle.querySelectorAll('.music-mode-icon');
      icons.forEach((icon) => icon.classList.add('hidden'));
      const activeIcon = btnModeToggle.querySelector(`.music-mode-${state.playMode}`);
      if (activeIcon) activeIcon.classList.remove('hidden');
    }

    function cyclePlayMode() {
      const currentIdx = PLAY_MODES.indexOf(state.playMode);
      state.playMode = PLAY_MODES[(currentIdx + 1) % PLAY_MODES.length];
      localStorage.setItem(PLAY_MODE_KEY, state.playMode);
      updatePlayModeUI();
      if (state.playMode === 'shuffle') {
        state.shuffleHistory = [state.currentIndex];
        state.shuffleIndex = 0;
      }
    }

    function getNextIndex() {
      if (!state.tracks.length) return 0;
      if (state.playMode === 'loop') {
        return state.currentIndex;
      }
      if (state.playMode === 'shuffle') {
        if (state.shuffleIndex < state.shuffleHistory.length - 1) {
          state.shuffleIndex++;
          return state.shuffleHistory[state.shuffleIndex];
        }
        let nextIdx;
        do {
          nextIdx = Math.floor(Math.random() * state.tracks.length);
        } while (state.tracks.length > 1 && nextIdx === state.currentIndex);
        state.shuffleHistory.push(nextIdx);
        state.shuffleIndex = state.shuffleHistory.length - 1;
        return nextIdx;
      }
      return (state.currentIndex + 1) % state.tracks.length;
    }

    function getPrevIndex() {
      if (!state.tracks.length) return 0;
      if (state.playMode === 'loop') {
        return state.currentIndex;
      }
      if (state.playMode === 'shuffle') {
        if (state.shuffleIndex > 0) {
          state.shuffleIndex--;
          return state.shuffleHistory[state.shuffleIndex];
        }
        let prevIdx;
        do {
          prevIdx = Math.floor(Math.random() * state.tracks.length);
        } while (state.tracks.length > 1 && prevIdx === state.currentIndex);
        state.shuffleHistory.unshift(prevIdx);
        return prevIdx;
      }
      return (state.currentIndex - 1 + state.tracks.length) % state.tracks.length;
    }

    function openPlaylistModal() {
      const { playlistModal } = state.els || {};
      if (!playlistModal) return;
      playlistModal.classList.remove('hidden');
      renderPlaylistModal();
      document.body.style.overflow = 'hidden';
    }

    function closePlaylistModal() {
      const { playlistModal } = state.els || {};
      if (!playlistModal) return;
      playlistModal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    function renderPlaylistModal() {
      const { playlistModalList } = state.els || {};
      if (!playlistModalList) return;
      if (!state.tracks.length) {
        playlistModalList.innerHTML = '<li class="global-music-playlist-modal-item" style="justify-content: center; color: var(--text-color-70);">No tracks</li>';
        return;
      }

      playlistModalList.innerHTML = state.tracks.map((track, idx) => `
        <li class="global-music-playlist-modal-item ${idx === state.currentIndex ? 'active' : ''}" data-idx="${idx}">
          <div class="global-music-playlist-modal-item-index">${idx === state.currentIndex ? '▶' : String(idx + 1).padStart(2, '0')}</div>
          <div class="global-music-playlist-modal-item-info">
            <div class="global-music-playlist-modal-item-title">${track.title || 'Unknown'}</div>
            <div class="global-music-playlist-modal-item-artist">${track.artist || 'Unknown Artist'}</div>
          </div>
        </li>
      `).join('');

      playlistModalList.querySelectorAll('.global-music-playlist-modal-item').forEach((el) => {
        el.addEventListener('click', async () => {
          const idx = Number(el.getAttribute('data-idx') || '0');
          state.currentIndex = idx;
          await playCurrent();
          renderPlaylistModal();
        });
      });

      const activeItem = playlistModalList.querySelector('.global-music-playlist-modal-item.active');
      if (activeItem) {
        activeItem.scrollIntoView({ behavior: 'auto', block: 'nearest' });
      }
    }

    function updatePlayButtonState() {
      const { audio, btnMainPlay } = state.els || {};
      if (!audio || !btnMainPlay) return;
      const isPlaying = !audio.paused;
      const playIcon = btnMainPlay.querySelector('.music-control-icon-play');
      const pauseIcon = btnMainPlay.querySelector('.music-control-icon-pause');
      btnMainPlay.classList.toggle('playing', isPlaying);
      btnMainPlay.setAttribute('aria-pressed', String(isPlaying));
      btnMainPlay.setAttribute('aria-label', isPlaying ? 'Pause' : 'Play');
      playIcon?.classList.toggle('hidden', isPlaying);
      pauseIcon?.classList.toggle('hidden', !isPlaying);
    }

    function updateProgressVisual() {
      const { progressEl } = state.els || {};
      if (!progressEl) return;
      const ratio = Number(progressEl.value || 0) / 1000;
      progressEl.style.setProperty('--progress-percent', `${Math.max(0, Math.min(100, ratio * 100))}%`);
    }

    function updatePlayerPosition() {
      const { posEl } = state.els || {};
      if (!posEl) return;
      if (!state.tracks.length) {
        posEl.textContent = '-';
        return;
      }
      posEl.textContent = `${state.currentIndex + 1} / ${state.tracks.length}`;
    }

    async function loadTrack(id) {
      const result = await getJson(`${API_BASE}/api/music/track?id=${encodeURIComponent(id)}`);
      if (result?.code === 200 && result?.data) {
        return {
          ...result.data,
          audio: normalizeAudioUrl(result.data?.audio || ''),
        };
      }
      return null;
    }

    async function hydrateTrack(idx) {
      const current = state.tracks[idx];
      if (!current) return null;
      if (current.audio) return current;
      const full = await loadTrack(current.id);
      if (!full) return current;
      const merged = { ...current, ...full };
      state.tracks[idx] = merged;
      return merged;
    }

    function updateNowPlaying(track) {
      const { audio, bottomCover, bottomTitle, bottomArtist } = state.els || {};
      if (bottomTitle) bottomTitle.textContent = track?.title || '-';
      if (bottomArtist) bottomArtist.textContent = track?.artist || '-';
      if (bottomCover) bottomCover.style.backgroundImage = track?.cover ? `url(${track.cover})` : '';
      if (!audio) return;

      if (track?.audio) {
        const previousSrc = audio.getAttribute('src') || '';
        if (previousSrc !== track.audio) {
          audio.src = track.audio;
          audio.load();
        }
      }
      updatePlayerPosition();
      updatePlayButtonState();
    }

    async function playCurrent() {
      const { audio } = state.els || {};
      if (!audio || !state.tracks.length) return;
      const track = await hydrateTrack(state.currentIndex);
      if (!track) return;
      updateNowPlaying(track);
      if (track.audio) {
        audio.play().catch(() => {});
      }
      updatePlayButtonState();
    }

    async function stepPrev() {
      if (!state.tracks.length) return;
      state.currentIndex = getPrevIndex();
      await playCurrent();
    }

    async function stepNext() {
      if (!state.tracks.length) return;
      state.currentIndex = getNextIndex();
      await playCurrent();
    }

    function bind() {
      if (state.bound || isMusicPagePath()) return;
      state.els = getEls();
      const { audio, btnMainPlay, btnPrev, btnNext, progressEl, btnModeToggle, btnPlaylist, playlistModalBackdrop, playlistModalClose } = state.els;
      if (!audio || !btnMainPlay || !btnPrev || !btnNext || !progressEl) return;

      updatePlayModeUI();

      state.handlers.onMainPlay = async () => {
        if (!state.tracks.length && !audio.src) return;
        if (!audio.src) {
          await playCurrent();
          return;
        }
        if (audio.paused) audio.play().catch(() => {});
        else audio.pause();
        updatePlayButtonState();
      };

      state.handlers.onPrev = () => stepPrev();
      state.handlers.onNext = () => stepNext();
      state.handlers.onTimeUpdate = () => {
        if (!audio || !progressEl) return;
        const duration = Number.isFinite(audio.duration) ? audio.duration : 0;
        const current = Number.isFinite(audio.currentTime) ? audio.currentTime : 0;
        if (duration > 0) {
          progressEl.value = String(Math.round((current / duration) * 1000));
          updateProgressVisual();
        }
        if (state.els?.currentTimeEl) state.els.currentTimeEl.textContent = formatClock(current);
        if (state.els?.totalTimeEl) state.els.totalTimeEl.textContent = formatClock(duration);
      };

      state.handlers.onEnded = async () => {
        if (state.playMode === 'loop') {
          audio.currentTime = 0;
          audio.play().catch(() => {});
          return;
        }
        await stepNext();
      };
      state.handlers.onLoadedMetadata = () => {
        if (state.els?.totalTimeEl) state.els.totalTimeEl.textContent = formatClock(audio.duration || 0);
      };
      state.handlers.onProgressInput = () => {
        if (!audio) return;
        const duration = Number.isFinite(audio.duration) ? audio.duration : 0;
        if (duration <= 0) return;
        const ratio = Number(progressEl.value || 0) / 1000;
        audio.currentTime = duration * Math.max(0, Math.min(1, ratio));
      };

      btnMainPlay.addEventListener('click', state.handlers.onMainPlay);
      btnPrev.addEventListener('click', state.handlers.onPrev);
      btnNext.addEventListener('click', state.handlers.onNext);
      audio.addEventListener('timeupdate', state.handlers.onTimeUpdate);
      audio.addEventListener('ended', state.handlers.onEnded);
      audio.addEventListener('loadedmetadata', state.handlers.onLoadedMetadata);
      progressEl.addEventListener('input', state.handlers.onProgressInput);

      // Play mode toggle
      if (btnModeToggle) {
        btnModeToggle.addEventListener('click', cyclePlayMode);
      }

      // Playlist modal
      if (btnPlaylist) {
        btnPlaylist.addEventListener('click', openPlaylistModal);
      }
      if (playlistModalBackdrop) {
        playlistModalBackdrop.addEventListener('click', closePlaylistModal);
      }
      if (playlistModalClose) {
        playlistModalClose.addEventListener('click', closePlaylistModal);
      }

      state.bound = true;
      updatePlayButtonState();
      if (state.tracks[state.currentIndex]) {
        updateNowPlaying(state.tracks[state.currentIndex]);
      }
    }

    function unbind() {
      if (!state.bound || !state.els) return;
      const { audio, btnMainPlay, btnPrev, btnNext, progressEl, btnModeToggle, btnPlaylist, playlistModalBackdrop, playlistModalClose } = state.els;
      if (btnMainPlay && state.handlers.onMainPlay) btnMainPlay.removeEventListener('click', state.handlers.onMainPlay);
      if (btnPrev && state.handlers.onPrev) btnPrev.removeEventListener('click', state.handlers.onPrev);
      if (btnNext && state.handlers.onNext) btnNext.removeEventListener('click', state.handlers.onNext);
      if (audio && state.handlers.onTimeUpdate) audio.removeEventListener('timeupdate', state.handlers.onTimeUpdate);
      if (audio && state.handlers.onEnded) audio.removeEventListener('ended', state.handlers.onEnded);
      if (audio && state.handlers.onLoadedMetadata) audio.removeEventListener('loadedmetadata', state.handlers.onLoadedMetadata);
      if (progressEl && state.handlers.onProgressInput) progressEl.removeEventListener('input', state.handlers.onProgressInput);
      if (btnModeToggle) btnModeToggle.removeEventListener('click', cyclePlayMode);
      if (btnPlaylist) btnPlaylist.removeEventListener('click', openPlaylistModal);
      if (playlistModalBackdrop) playlistModalBackdrop.removeEventListener('click', closePlaylistModal);
      if (playlistModalClose) playlistModalClose.removeEventListener('click', closePlaylistModal);
      state.handlers = {};
      state.bound = false;
    }

    function onRouteChange() {
      state.els = getEls();
      if (isMusicPagePath()) {
        unbind();
        return;
      }
      bind();
      if (state.tracks[state.currentIndex]) {
        updateNowPlaying(state.tracks[state.currentIndex]);
      }
    }

    return {
      onRouteChange,
      bootstrap,
      syncState,
      getState,
    };
  }

  if (!window[GLOBAL_MUSIC_KEY]) {
    window[GLOBAL_MUSIC_KEY] = makeController();
    window[GLOBAL_MUSIC_KEY].onRouteChange();
    document.addEventListener('astro:page-load', () => window[GLOBAL_MUSIC_KEY].onRouteChange());
    document.addEventListener('astro:after-swap', () => window[GLOBAL_MUSIC_KEY].onRouteChange());
  } else {
    window[GLOBAL_MUSIC_KEY].onRouteChange();
  }
</script>
