---
---
<canvas id="cursor-trail" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; pointer-events: none; z-index: 9999;"></canvas>

<script>
  const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;

  let cursorStyleEl: HTMLStyleElement | null = null;
  const CURSOR_STORAGE_KEY = 'momo-cursor-enabled';

  function injectCursorStyle() {
    if (cursorStyleEl && document.getElementById('momo-custom-cursor')) return;
    if (isTouchDevice) return;
    cursorStyleEl = document.createElement('style');
    cursorStyleEl.id = 'momo-custom-cursor';
    cursorStyleEl.textContent = [
      'html, body, * { cursor: url("/cursor/Normal_page_01_small.png") 0 0, auto !important; }',
      'a, button, [role="button"], input, select, textarea, a *, button * { cursor: url("/cursor/Link_page_01_small.png") 0 0, pointer !important; }',
    ].join('\n');
    document.head.appendChild(cursorStyleEl);
  }

  function removeCursorStyle() {
    if (cursorStyleEl) {
      cursorStyleEl.remove();
      cursorStyleEl = null;
    }
  }

  function isCursorStyleEnabled(): boolean {
    if (isTouchDevice) return false;
    return localStorage.getItem(CURSOR_STORAGE_KEY) !== 'false';
  }

  function isTrailEnabled(): boolean {
    return localStorage.getItem(CURSOR_STORAGE_KEY) !== 'false';
  }

  function applyState() {
    if (isCursorStyleEnabled()) {
      injectCursorStyle();
    } else {
      removeCursorStyle();
    }
    const canvas = document.getElementById('cursor-trail');
    if (canvas) {
      canvas.style.display = isTrailEnabled() ? '' : 'none';
    }
  }

  applyState();

  window.addEventListener('momo-cursor-toggle', () => {
    applyState();
  });

  class Particle {
    x: number;
    y: number;
    size: number;
    color: string;
    speedX: number;
    speedY: number;
    opacity: number;
    angle: number;
    spin: number;

    constructor(x: number, y: number, color: string) {
      this.x = x;
      this.y = y;
      this.size = Math.random() * 6 + 4; // 4 to 10 px
      this.color = color;
      this.speedX = Math.random() * 2 - 1;
      this.speedY = Math.random() * 2 - 1;
      this.opacity = 1;
      this.angle = Math.random() * 360;
      this.spin = (Math.random() - 0.5) * 10;
    }

    update() {
      this.x += this.speedX;
      this.y += this.speedY;
      this.opacity -= 0.02;
      this.size *= 0.95;
      this.angle += this.spin;
    }

    draw(ctx: CanvasRenderingContext2D) {
      ctx.save();
      ctx.translate(this.x, this.y);
      ctx.rotate((this.angle * Math.PI) / 180);
      ctx.globalAlpha = this.opacity;
      ctx.fillStyle = this.color;
      ctx.fillRect(-this.size / 2, -this.size / 2, this.size, this.size);
      ctx.restore();
    }
  }

  class Ripple {
    x: number;
    y: number;
    radius: number;
    maxRadius: number;
    opacity: number;
    color: string;

    constructor(x: number, y: number, color: string) {
      this.x = x;
      this.y = y;
      this.radius = 1;
      this.maxRadius = 50 + Math.random() * 30;
      this.opacity = 1;
      this.color = color;
    }

    update(): boolean {
      this.radius += (this.maxRadius - this.radius) * 0.08;
      this.opacity -= 0.022;
      return this.opacity > 0.02 && this.radius < this.maxRadius;
    }

    draw(ctx: CanvasRenderingContext2D) {
      ctx.save();
      ctx.globalAlpha = this.opacity * 0.45;
      ctx.strokeStyle = this.color;
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
      ctx.stroke();

      ctx.globalAlpha = this.opacity * 0.08;
      ctx.fillStyle = this.color;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }
  }

  class SplashDrop {
    x: number;
    y: number;
    size: number;
    color: string;
    speedX: number;
    speedY: number;
    opacity: number;
    gravity: number;

    constructor(x: number, y: number, angle: number, speed: number, color: string, size: number) {
      this.x = x;
      this.y = y;
      this.size = size;
      this.color = color;
      this.speedX = Math.cos(angle) * speed;
      this.speedY = Math.sin(angle) * speed;
      this.opacity = 1;
      this.gravity = 0.08;
    }

    update() {
      this.speedY += this.gravity;
      this.x += this.speedX;
      this.y += this.speedY;
      this.opacity -= 0.018;
      this.size *= 0.985;
    }

    draw(ctx: CanvasRenderingContext2D) {
      ctx.save();
      ctx.globalAlpha = this.opacity;
      ctx.fillStyle = this.color;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }
  }

  let cleanup: (() => void) | null = null;

  function initCursorTrail() {
    if (cleanup) cleanup();

    const canvas = document.getElementById("cursor-trail") as HTMLCanvasElement;
    if (!canvas) return;
    
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    let particles: Particle[] = [];
    let ripples: Ripple[] = [];
    let splashDrops: SplashDrop[] = [];
    let width = window.innerWidth;
    let height = window.innerHeight;
    let animFrameId = 0;
    
    // Offscreen canvas for spatial color sampling
    let bgRefCanvas = document.createElement("canvas");
    let bgRefCtx = bgRefCanvas.getContext("2d", { willReadFrequently: true });
    let currentBgObj = new Image();
    currentBgObj.crossOrigin = "Anonymous";

    function extractSpatialBg() {
      try {
        // Fallback checks
        let actualElement = document.body;
        let bgStr = window.getComputedStyle(actualElement, "::before").backgroundImage;
        if (!bgStr || bgStr === 'none') {
            bgStr = window.getComputedStyle(actualElement).backgroundImage;
        }

        const urlMatch = bgStr.match(/url\(['"]?(.*?)['"]?\)/);
        if (urlMatch && urlMatch[1]) {
          const imgUrl = urlMatch[1];
          if (currentBgObj.src !== imgUrl && !imgUrl.startsWith('data:')) {
            currentBgObj.onload = renderOffscreenBg;
            currentBgObj.src = imgUrl;
          } else {
             // Already loaded and matches, just re-layout on resize
             renderOffscreenBg();
          }
        }
      } catch(e) { }
    }

    function renderOffscreenBg() {
      if (!currentBgObj.width) return;
      bgRefCanvas.width = width;
      bgRefCanvas.height = height;
      if (!bgRefCtx) return;

      const imgW = currentBgObj.width;
      const imgH = currentBgObj.height;
      const winRatio = width / height;
      const imgRatio = imgW / imgH;

      let drawW, drawH, offsetX, offsetY;

      // Replicate background-size: cover & center position
      if (winRatio > imgRatio) {
        drawW = width;
        drawH = width / imgRatio;
        offsetX = 0;
        // By default center, adapt if we know it's a specific dark theme position
        const isDark = document.documentElement.classList.contains('dark');
        const posPercent = isDark ? 0.2 : 0.5; // (center 20% vs center)
        offsetY = (height - drawH) * posPercent;
      } else {
        drawH = height;
        drawW = height * imgRatio;
        offsetX = (width - drawW) / 2;
        offsetY = 0;
      }

      bgRefCtx.clearRect(0, 0, width, height);
      bgRefCtx.drawImage(currentBgObj, offsetX, offsetY, drawW, drawH);
    }

    function resize() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
      extractSpatialBg();
    }

    window.addEventListener("resize", resize);
    resize();

    // Listen to background change via custom attributes or style changes
    const observer = new MutationObserver(() => {
      extractSpatialBg();
    });
    observer.observe(document.body, { attributes: true, attributeFilter: ['style', 'class'] });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    let fgCanvas = document.createElement("canvas");
    let fgCtx = fgCanvas.getContext("2d", { willReadFrequently: true });
    fgCanvas.width = 1;
    fgCanvas.height = 1;

    function getThemeColorAt(clientX: number, clientY: number) {
      // 1. Detect if hovering over foreground elements like cards, images, or content areas
      let el = document.elementFromPoint(clientX, clientY);
      let hasSolidBg = false;
      let currentEl = el;
      let hoveredImg = null;
      
      while (currentEl && currentEl !== document.body && currentEl !== document.documentElement) {
          if (currentEl.tagName === 'IMG' || currentEl.tagName === 'VIDEO') {
              hoveredImg = currentEl as HTMLImageElement;
              break; // Found an image!
          }
          let style = window.getComputedStyle(currentEl);
          let bg = style.backgroundColor;
          if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') {
              hasSolidBg = true;
              break;
          }
          if (['CANVAS', 'SVG', 'A', 'BUTTON', 'ARTICLE', 'SECTION'].includes(currentEl.tagName)) {
               // Verify if it actually has a visible background class
               if (style.backgroundColor !== 'rgba(0, 0, 0, 0)') {
                   hasSolidBg = true;
                   break;
               }
          }
          currentEl = currentEl.parentElement;
      }

      // 2. If floating over an actual foreground image, sample that image!
      if (hoveredImg && fgCtx) {
        try {
          const rect = hoveredImg.getBoundingClientRect();
          const relX = clientX - rect.left;
          const relY = clientY - rect.top;
          
          // Basic scaling mapping (handles default object-fit, could vary by fit style, but good enough)
          const scaleX = hoveredImg.naturalWidth / rect.width;
          const scaleY = hoveredImg.naturalHeight / rect.height;
          
          fgCtx.clearRect(0, 0, 1, 1);
          fgCtx.drawImage(hoveredImg, relX * scaleX, relY * scaleY, 1, 1, 0, 0, 1, 1);
          let pixel = fgCtx.getImageData(0, 0, 1, 1).data;
          
          if (pixel[3] > 0) {
              let r = Math.min(255, Math.floor(pixel[0] * 1.5));
              let g = Math.min(255, Math.floor(pixel[1] * 1.5));
              let b = Math.min(255, Math.floor(pixel[2] * 1.5));
              return `rgb(${r}, ${g}, ${b})`;
          }
        } catch(e) { } // CORS or un-renderable image, gracefully fallback
      }

      // 3. If floating over transparent background areas, use the spatial background matching 
      if (!hasSolidBg && !hoveredImg) {
        try {
          if (bgRefCtx && currentBgObj.width) {
            const pixel = bgRefCtx.getImageData(clientX, clientY, 1, 1).data;
            if (pixel[3] > 0) {
              let r = Math.min(255, Math.floor(pixel[0] * 1.5));
              let g = Math.min(255, Math.floor(pixel[1] * 1.5));
              let b = Math.min(255, Math.floor(pixel[2] * 1.5));
              return `rgb(${r}, ${g}, ${b})`;
            }
          }
        } catch(e) {}
      }
      
      // 3. Instead of trying to blend with random foreground colors, fallback to the requested default color
      return "#A5F6F7";
    }

    let isMoving = false;
    let lastX = -100;
    let lastY = -100;

    function onMouseMove(e: MouseEvent) {
      lastX = e.clientX;
      lastY = e.clientY;
      isMoving = true;
      
      const spatialColor = getThemeColorAt(e.clientX, e.clientY);
      particles.push(new Particle(e.clientX, e.clientY, spatialColor));
      if (Math.random() > 0.5) {
        particles.push(new Particle(e.clientX + (Math.random()*10-5), e.clientY + (Math.random()*10-5), spatialColor));
      }
    }
    window.addEventListener("mousemove", onMouseMove);

    function spawnTouchParticles(e: TouchEvent) {
      for (let i = 0; i < e.touches.length; i++) {
        const t = e.touches[i];
        const spatialColor = getThemeColorAt(t.clientX, t.clientY);
        particles.push(new Particle(t.clientX, t.clientY, spatialColor));
        particles.push(new Particle(t.clientX + (Math.random()*10-5), t.clientY + (Math.random()*10-5), spatialColor));
      }
    }
    window.addEventListener("touchmove", spawnTouchParticles, { passive: true });
    window.addEventListener("touchstart", spawnTouchParticles, { passive: true });

    function onClick(e: MouseEvent) {
      const color = getThemeColorAt(e.clientX, e.clientY);
      ripples.push(new Ripple(e.clientX, e.clientY, color));

      const dropCount = 8 + Math.floor(Math.random() * 6);
      for (let i = 0; i < dropCount; i++) {
        const angle = (Math.PI * 2 * i) / dropCount + (Math.random() - 0.5) * 0.4;
        const speed = 1.5 + Math.random() * 3;
        const size = 1 + Math.random() * 2;
        splashDrops.push(new SplashDrop(e.clientX, e.clientY, angle, speed, color, size));
      }
    }
    window.addEventListener("click", onClick);

    function animate() {
      ctx.clearRect(0, 0, width, height);

      for (let i = 0; i < particles.length; i++) {
        particles[i].update();
        particles[i].draw(ctx);
        if (particles[i].opacity <= 0.05 || particles[i].size <= 0.5) {
          particles.splice(i, 1);
          i--;
        }
      }

      for (let i = ripples.length - 1; i >= 0; i--) {
        ripples[i].draw(ctx);
        if (!ripples[i].update()) {
          ripples.splice(i, 1);
        }
      }

      for (let i = splashDrops.length - 1; i >= 0; i--) {
        splashDrops[i].update();
        splashDrops[i].draw(ctx);
        if (splashDrops[i].opacity <= 0.03 || splashDrops[i].size <= 0.3) {
          splashDrops.splice(i, 1);
        }
      }

      animFrameId = requestAnimationFrame(animate);
    }

    animate();

    cleanup = () => {
      cancelAnimationFrame(animFrameId);
      window.removeEventListener("mousemove", onMouseMove);
      window.removeEventListener("touchmove", spawnTouchParticles);
      window.removeEventListener("touchstart", spawnTouchParticles);
      window.removeEventListener("click", onClick);
      window.removeEventListener("resize", resize);
      observer.disconnect();
    };
  }

  document.addEventListener("astro:page-load", initCursorTrail);
  document.addEventListener("astro:page-load", applyState);
</script>

