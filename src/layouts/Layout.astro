---
import { siteConfig, profileConfig } from '@/config';
import "@styles/global.css"
import 'katex/dist/katex.min.css';
import 'aos/dist/aos.css';
import 'photoswipe/style.css'
import { i18n } from "astro:config/client";
import { ClientRouter } from "astro:transitions";
import CursorTrail from "@/components/CursorTrail.astro";
import { Image } from "astro:assets";
import headerAvatar from "@assets/Motues.jpg";

interface Props {
  title: string;
  lang?: string;
  description?: string;
  noCache?: boolean;
}
const { title, lang, description, noCache = false } = Astro.props;

const pageTitle = title;
const pageLang = lang || i18n?.defaultLocale || "zh-cn";

const isExternalAvatar = profileConfig.avatar?.startsWith("/") || profileConfig.avatar?.startsWith("http");
const externalAvatarSrc = isExternalAvatar ? profileConfig.avatar : undefined;
---

<!DOCTYPE html>
<html lang={pageLang} class="h-full">
<head>
    <script is:inline>
        (function() {
        const savedTheme = localStorage.getItem('theme');
        const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        let theme;
        if ( savedTheme === 'system') {
          theme = systemTheme;
        } else {
          theme = savedTheme || 'light';
        }
        localStorage.setItem('theme', savedTheme || theme);
        document.documentElement.setAttribute('data-theme', theme);

        if (theme === 'dark') {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }

        // 开场动画状态判断
        if (sessionStorage.getItem('splashShown')) {
          document.documentElement.classList.add('splash-shown');
        }
        })();
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {noCache && <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />}
    {noCache && <meta http-equiv="Pragma" content="no-cache" />}
    {noCache && <meta http-equiv="Expires" content="0" />}
    <meta name="description" content={((description != null && description !== undefined && description !== "") ? description : profileConfig.description) + " This is a blog site, which is built with Astro."}>
    <meta name="author" content={profileConfig.name}>
    <link rel="alternate" type="application/rss+xml" title={siteConfig.title} href={new URL("rss.xml", Astro.site)} >
    <link rel="icon" href={siteConfig.favicon} type="image/x-icon">
    <link rel="stylesheet" href="https://fonts.font.im/css2?family=Noto+Serif+SC:wght@400;700&display=swap">
    <link rel="stylesheet" href="https://fonts.font.im/css2?family=EB+Garamond&display=swap">
    <script defer src="https://umami.motues.top/script.js" data-hash is:inline></script>
    <title>{pageTitle}</title>
    <ClientRouter />
</head>
<body class="h-full bg-[var(--bg-color)]">
    
    <!-- Splash Screen -->
    <div id="splash-screen" class="splash-screen" aria-hidden="true">
      <div class="splash-content">
        {isExternalAvatar ? (
          <img src={externalAvatarSrc ?? ""} alt={profileConfig.name} class="splash-avatar" />
        ) : (
          <Image src={headerAvatar} alt={profileConfig.name} quality={90} format="webp" loading="eager" class="splash-avatar" />
        )}
        <h1 class="splash-name">{profileConfig.name}</h1>
      </div>
    </div>
    <script is:inline data-astro-rerun>
      (function() {
        const splash = document.getElementById('splash-screen');
        if (!splash) return;
        if (sessionStorage.getItem('splashShown')) {
          // 兜底防御，确保完全移除
          splash.remove();
        } else {
          // 首次访问，停顿 2.5 秒后淡出隐藏
          setTimeout(() => {
            splash.classList.add('hidden');
            sessionStorage.setItem('splashShown', 'true');
            
            // 重要：必须等待动画结束后，才能加上 splash-shown 从而触发 display: none，否则动画会被打断！
            setTimeout(() => {
              document.documentElement.classList.add('splash-shown');
              splash.remove();
            }, 1000); // 这个 1000ms 需要和 css 中的 transition 时间一致
          }, 2500);
        }
      })();
    </script>

    <!-- Page Loading Overlay -->
    <div id="loading-overlay" aria-hidden="true">
      <img src="/images/transition.gif" alt="loading" class="loading-gif" />
    </div>

    <slot />
    
    <script is:inline>
        let loaderTimeout;

        // 1. 开始准备跳转
        document.addEventListener('astro:before-preparation', () => {
            loaderTimeout = setTimeout(() => {
            const overlay = document.getElementById('loading-overlay');
            if (overlay) overlay.style.display = 'flex';
            }, 500); 
        });

        // 2. 页面内容交换完成（DOM 已更新）
        document.addEventListener('astro:after-swap', () => {
            clearTimeout(loaderTimeout);
            
            const overlay = document.getElementById('loading-overlay');
            if (overlay) overlay.style.display = 'none';
        });

        // 3. 兜底方案：页面完全加载完成（包括资源）
        document.addEventListener('astro:page-load', () => {
            clearTimeout(loaderTimeout);
            const overlay = document.getElementById('loading-overlay');
            if (overlay) overlay.style.display = 'none';
        });
        </script>
    <CursorTrail />
</body>
</html>

<style is:global>
  #loading-overlay {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.7);
    z-index: 9999;
    backdrop-filter: blur(2px);
    animation: fadeIn 0.3s ease-out;
  }

  [data-theme="dark"] #loading-overlay {
    background-color: rgba(0, 0, 0, 0.7);
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .loading-gif {
    width: 80px;
    height: 80px;
    object-fit: contain;
  }

  /* 开场屏基础样式 */
  html.splash-shown .splash-screen {
    display: none !important;
  }
  
  .splash-screen {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background-color: var(--bg-color);
    display: flex;
    align-items: center;
    justify-content: center;
    /* 增加 transform 过渡，使用优雅的贝塞尔曲线实现“拉开帷幕” */
    transition: transform 1s cubic-bezier(0.7, 0, 0.3, 1), opacity 1s cubic-bezier(0.7, 0, 0.3, 1), visibility 1s;
  }
  
  .splash-screen.hidden {
    /* 向上平移 100% 离开屏幕 */
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
  }

  .splash-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .splash-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    animation: scaleUp 1.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .splash-name {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--text-color);
    margin: 0;
    opacity: 0;
    animation: slideUpFade 1.8s cubic-bezier(0.2, 0.8, 0.2, 1) 0.5s forwards;
  }

  [data-theme="dark"] .splash-avatar {
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.1);
  }

  @keyframes scaleUp {
    0% { transform: scale(0.8); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes slideUpFade {
    0% { transform: translateY(15px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }
</style>

<script>
  import AOS from 'aos';

  function initApp() {
    // 1. 先处理 Markdown 的动态注入 (如果有)
    const container = document.querySelector('.markdown-content');
    if (container) {
      const elements = container.querySelectorAll(':scope > *');
      elements.forEach((el, i) => {
        el.setAttribute('data-aos', 'fade-up');
        el.setAttribute('data-aos-delay', (i % 5 * 50).toString());
      });
    }

    // 2. 统一初始化
    AOS.init({
      duration: 800,
      once: true,
    });
    
    // 3. 强力刷新
    AOS.refreshHard();
  }

  document.addEventListener('astro:page-load', initApp);
  // document.addEventListener('astro:after-swap', initApp);

</script>

<script is:inline>document.addEventListener('astro:page-load', () => { document.querySelectorAll('.lqip-markdown-img').forEach(img => { if (img.complete) { img.classList.add('lqip-loaded'); } else { img.addEventListener('load', () => img.classList.add('lqip-loaded')); } }); });</script>
