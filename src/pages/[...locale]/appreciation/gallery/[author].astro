---
import MainPageLayout from '@layouts/MainPageLayout.astro'
import Cover from '@components/Cover.astro'
import FabMenu from '@components/control/FabMenu.astro'
import { siteConfig } from '@/config'
import i18nit from '@i18n/translation'
import { i18n } from "astro:config/client"
import { getRelativeLocaleUrl } from '@utils/url-utils'
import { getAuthorWorks, loadGalleryData } from '@utils/gallery-utils'
import { pinyin } from 'pinyin-pro'

export async function getStaticPaths() {
  const paths = []
  const { authors } = loadGalleryData()

  for (const locale of i18n!.locales) {
    const localeCode = locale as string
    const localeParam = localeCode === i18n!.defaultLocale ? undefined : localeCode

    for (const author of authors) {
      paths.push({
        params: {
          locale: localeParam,
          author: author.slug,
        },
      })
    }
  }

  return paths
}

const currentLang = Astro.currentLocale || i18n!.defaultLocale
const normalizedLang = currentLang === 'en' ? 'en' : 'zh-cn'
const t = i18nit(currentLang)
const authorParam = Astro.params.author || ''

const { authors } = loadGalleryData()
const authorInfo = authors.find((a) => a.slug.toLowerCase() === authorParam.toLowerCase())
const authorWorks = getAuthorWorks(authorParam)

if (!authorInfo) {
  throw new Error(`Gallery author not found: ${authorParam}`)
}

const pageTitle = `${authorInfo.name[normalizedLang]} - ${t('header.gallery')} - ${siteConfig.title}`
const coverSubTitle = normalizedLang === 'en'
  ? `${authorWorks.length} works`
  : `共 ${authorWorks.length} 幅作品`
const allTags = [...new Set(authorWorks.flatMap(w => [...(w.tags || []), `年份:${w.year}`]))]
function parseTag(tag: string): [string, string] {
  const idx = tag.indexOf(':');
  if (idx === -1) return ['', tag];
  return [tag.slice(0, idx), tag.slice(idx + 1)];
}
function getInitial(tag: string): string {
  const [, val] = parseTag(tag);
  const ch = val.charAt(0);
  if (/[a-zA-Z]/.test(ch)) return ch.toUpperCase();
  if (/[0-9]/.test(ch)) return '#';
  if (/[\u4e00-\u9fff]/.test(ch)) {
    const py = pinyin(ch, { pattern: 'first', toneType: 'none' });
    return py ? py.toUpperCase() : '#';
  }
  return '#';
}
const dimGroups: { dim: string, letters: { key: string, values: { val: string, full: string, count: number }[] }[] }[] = (() => {
  const map = new Map<string, Map<string, Map<string, number>>>();
  for (const tag of allTags) {
    const [dim, val] = parseTag(tag);
    const d = dim || '其他';
    const init = getInitial(val);
    if (!map.has(d)) map.set(d, new Map());
    const dm = map.get(d)!;
    if (!dm.has(init)) dm.set(init, new Map());
    const vm = dm.get(init)!;
    vm.set(val, (vm.get(val) || 0) + 1);
  }
  const result: typeof dimGroups = [];
  for (const [dim, dm] of map) {
    const letters: { key: string; values: { val: string; full: string; count: number }[] }[] = [];
    for (const [key, vm] of dm) {
      const values = Array.from(vm.entries()).map(([val, count]) => ({ val, full: `${dim}:${val}`, count }));
      values.sort((a, b) => a.val.localeCompare(b.val, 'zh-u-co-pinyin'));
      letters.push({ key, values });
    }
    letters.sort((a, b) => a.key.localeCompare(b.key));
    result.push({ dim, letters });
  }
  result.sort((a, b) => a.dim.localeCompare(b.dim, 'zh-u-co-pinyin'));
  return result;
})()
const cacheVersion = Date.now().toString()
---

<MainPageLayout title={pageTitle} lang={currentLang} noCache={true}>
  <script is:inline>
    if (localStorage.getItem('momo-gallery-hide-cards') === 'true') {
      document.documentElement.classList.add('gallery-hide-cards');
    }
    window.toggleCardText = function() {
      var hidden = document.documentElement.classList.toggle('gallery-hide-cards');
      localStorage.setItem('momo-gallery-hide-cards', String(hidden));
      var btns = document.querySelectorAll('#tag-hide-toggle, #tag-hide-toggle-mobile');
      var label = document.documentElement.lang === 'en' ? (hidden ? 'Hide' : 'Show') : (hidden ? '隐藏' : '显示');
      for (var j = 0; j < btns.length; j++) {
        btns[j].textContent = label;
        btns[j].classList.toggle('bg-[var(--link-color)]', hidden);
        btns[j].classList.toggle('text-white', hidden);
        btns[j].classList.toggle('border-[var(--link-color)]', hidden);
      }
    };
    setTimeout(function() {
      var hidden = document.documentElement.classList.contains('gallery-hide-cards');
      var btns = document.querySelectorAll('#tag-hide-toggle, #tag-hide-toggle-mobile');
      var label = document.documentElement.lang === 'en' ? (hidden ? 'Hide' : 'Show') : (hidden ? '隐藏' : '显示');
      for (var j = 0; j < btns.length; j++) {
        btns[j].textContent = label;
        btns[j].classList.toggle('bg-[var(--link-color)]', hidden);
        btns[j].classList.toggle('text-white', hidden);
        btns[j].classList.toggle('border-[var(--link-color)]', hidden);
      }
    }, 0);
  </script>
  <div class="mx-auto w-full max-w-[var(--page-width)]" data-pagefind-body>
    <div class="mb-4">
      <a href={`${getRelativeLocaleUrl(currentLang, '/appreciation/gallery/')}?v=${cacheVersion}`} class="text-sm text-[var(--link-color)] hover:underline">
        {normalizedLang === 'en' ? '← Back to Gallery' : '← 返回画廊'}
      </a>
    </div>

    <Cover title={authorInfo.name[normalizedLang]} subTitle={coverSubTitle} />

    <div class="artist-bio-box mb-6">
      <div class="artist-bio-mark" aria-hidden="true"></div>
      <h2 class="text-lg font-semibold text-[var(--text-color)] mb-2">
        {normalizedLang === 'en' ? 'Artist Bio' : '画师简介'}
      </h2>
      <p id="artist-bio-content" class="artist-bio-content text-sm leading-relaxed text-[var(--text-color-70)] whitespace-pre-line">
        {authorInfo.description[normalizedLang]}
      </p>
      <button
        id="artist-bio-toggle"
        type="button"
        class="artist-bio-toggle hidden mt-3 text-sm font-medium text-[var(--link-color)] hover:opacity-80"
        aria-expanded="false"
      >
        {normalizedLang === 'en' ? 'Show more' : '展开'}
      </button>
    </div>

    {allTags.length > 0 && (
      <details id="tag-filter" class="lg:hidden mb-6 border border-[var(--button-border-color)] rounded-xl p-3">
        <summary class="flex items-center gap-2 text-sm font-semibold text-[var(--text-color)] cursor-pointer select-none">
          <span>{normalizedLang === 'en' ? 'Tags' : '标签'}</span>
          <span id="selected-count" class="text-xs font-normal text-[var(--text-color-70)] hidden"></span>
          <div class="ml-auto flex items-center gap-1">
            <button id="tag-hide-toggle-mobile" class="px-1.5 py-0.5 text-[11px] rounded border border-[var(--button-border-color)] text-[var(--text-color-70)]" onclick="toggleCardText();event.preventDefault();event.stopPropagation();">显示</button>
            <button id="filter-mode-toggle" class="px-1.5 py-0.5 text-[11px] rounded border border-[var(--button-border-color)] text-[var(--text-color-70)]" onclick="event.preventDefault(); event.stopPropagation();">AND</button>
          </div>
        </summary>
        <div class="mt-2 max-h-[50vh] overflow-y-auto">
          <button data-tag="" class="tag-filter-btn w-full text-left px-2 py-1.5 text-sm rounded text-[var(--link-color)] font-semibold transition-colors mb-1">
            {normalizedLang === 'en' ? 'All' : '全部'}
          </button>
          {dimGroups.map(group => (<>
            <div class="tag-dim-group" data-dim={group.dim}>
              <span class="block text-xs font-bold text-[var(--link-color)] px-2 py-0.5 mt-2 cursor-pointer" data-dim-toggle={group.dim}>{group.dim}</span>
              <div class="tag-dim-values ml-1 hidden">
                {group.letters.map(l => (
                  <div class="tag-letter-group" data-letter={l.key}>
                    <span class="block text-[11px] text-[var(--text-color-70)] px-2 py-0.5 cursor-pointer" data-letter-toggle={`${group.dim}:${l.key}`}>{l.key}</span>
                    <div class:list={["tag-letter-values ml-2", { hidden: l.values.length > 3 }]}>
                      {l.values.map(v => (
                        <button data-tag={v.full} class="tag-filter-btn w-full text-left px-2 py-1 text-xs rounded text-[var(--text-color-70)] hover:bg-[var(--button-hover-color)] transition-colors">
                          {v.val} <span class="opacity-50">({v.count})</span>
                        </button>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </>))}
        </div>
      </details>
    )}

    {allTags.length > 0 && (
      <aside id="tag-filter-desktop" class="hidden lg:block absolute left-[var(--toc-offset-left)] top-20 w-44 border-l border-[var(--button-border-color)] pl-4 max-h-[calc(100vh-5rem)] overflow-y-auto z-10">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-sm font-semibold text-[var(--text-color)]">
            {normalizedLang === 'en' ? 'Tags' : '标签'}
          </h3>
          <div class="flex items-center gap-1">
            <button id="tag-hide-toggle" class="px-1.5 py-0.5 text-[11px] rounded border border-[var(--button-border-color)] text-[var(--text-color-70)] hover:border-[var(--link-color)] transition-colors" onclick="toggleCardText()">显示</button>
            <button id="filter-mode-toggle-desktop" class="px-1.5 py-0.5 text-[11px] rounded border border-[var(--button-border-color)] text-[var(--text-color-70)] hover:border-[var(--link-color)] transition-colors">AND</button>
          </div>
        </div>
        <button data-tag="" class="tag-filter-btn w-full text-left px-2 py-1.5 text-sm rounded text-[var(--link-color)] font-semibold transition-colors mb-1">
          {normalizedLang === 'en' ? 'All' : '全部'}
        </button>
        {dimGroups.map(group => (<>
          <div class="tag-dim-group-desktop" data-dim={group.dim}>
            <span class="block text-xs font-bold text-[var(--link-color)] px-2 py-0.5 mt-2 cursor-pointer" data-dim-toggle={group.dim}>{group.dim}</span>
            <div class="tag-dim-values-desktop ml-1 hidden">
              {group.letters.map(l => (
                <div class="tag-letter-group-desktop" data-letter={l.key}>
                  <span class="block text-[11px] text-[var(--text-color-70)] px-2 py-0.5 cursor-pointer" data-letter-toggle={`${group.dim}:${l.key}`}>{l.key}</span>
                  <div class:list={["tag-letter-values-desktop ml-2", { hidden: l.values.length > 3 }]}>
                    {l.values.map(v => (
                      <button data-tag={v.full} class="tag-filter-btn w-full text-left px-2 py-1 text-xs rounded text-[var(--text-color-70)] hover:bg-[var(--button-hover-color)] transition-colors">
                        {v.val} <span class="opacity-50">({v.count})</span>
                      </button>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </>))}
      </aside>
    )}

    <section id="gallery-grid" class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4 mb-8">
      {authorWorks.map((item) => (
        <article data-tags={JSON.stringify([...(item.tags || []), `年份:${item.year}`])} class="break-inside-avoid overflow-hidden rounded-xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/70">
          <img
            src={item.image}
            alt={item.title['zh-cn']}
            data-gallery-src={item.image}
            class="w-full h-auto object-contain cursor-zoom-in"
            loading="lazy" decoding="async"
          />
          <div class="card-text p-3">
            <h3 class="text-base font-semibold text-[var(--text-color)]">{item.title['zh-cn']}</h3>
            <p class="mt-1 text-sm text-[var(--text-color-70)]">{item.year}</p>
            {item.tags?.length > 0 && (
              <div class="mt-2 flex flex-wrap gap-1">
                {item.tags.map((tag) => {
                  const [dim, val] = parseTag(tag);
                  return (
                    <span class="text-xs px-2 py-1 rounded-md bg-[var(--button-hover-color)] text-[var(--text-color-70)]">
                      {dim ? <><span class="opacity-50">{dim}·</span>{val}</> : val}
                    </span>
                  );
                })}
              </div>
            )}
          </div>
        </article>
      ))}
    </section>
  </div>

  <FabMenu showBackBottom={true} />
</MainPageLayout>

<style>
  .artist-bio-box {
    position: relative;
    border: 1px solid var(--button-border-color);
    border-left: 4px solid var(--link-color);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--bg-color) 88%, transparent);
    padding: 1rem 1rem 1rem 1.1rem;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.02);
  }

  .artist-bio-mark {
    position: absolute;
    top: 0.9rem;
    left: -0.2rem;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 999px;
    background: var(--link-color);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--link-color) 14%, transparent);
  }

  .artist-bio-content {
    overflow: hidden;
    transition: all 220ms ease;
    display: -webkit-box;
    -webkit-box-orient: vertical;
  }

  .artist-bio-content.is-collapsed {
    -webkit-line-clamp: 3;
  }

  .artist-bio-content.is-expanded {
    display: block;
    -webkit-line-clamp: unset;
  }

  .artist-bio-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .artist-bio-toggle::after {
    content: "";
    display: inline-block;
    width: 0.45rem;
    height: 0.45rem;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg) translateY(-1px);
    transition: transform 180ms ease;
  }

  .artist-bio-toggle[aria-expanded="true"]::after {
    transform: rotate(-135deg) translateY(-1px);
  }
</style>

<script>
  let overlayEl: HTMLDivElement | null = null;

  function closeOverlay() {
    if (overlayEl) {
      document.removeEventListener('keydown', (overlayEl as any).__keyHandler);
      overlayEl.remove();
      overlayEl = null;
    }
  }

  function openGalleryPreview(imageSrc: string) {
    closeOverlay();

    const visibleArticles = document.querySelectorAll('#gallery-grid article:not([style*="display: none"])');
    const imgs = Array.from(visibleArticles).map(article => {
      const img = article.querySelector<HTMLElement>('img[data-gallery-src]');
      return img ? img.dataset.gallerySrc : null;
    }).filter(src => src) as string[];

    let currentIndex = imgs.indexOf(imageSrc);
    if (currentIndex === -1) currentIndex = 0;

    overlayEl = document.createElement('div');
    overlayEl.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:99999;background:rgba(0,0,0,0.8);display:flex;align-items:center;justify-content:center;overflow:hidden';
    overlayEl.className = 'relative';
    overlayEl.onclick = (e) => { if (e.target === overlayEl) closeOverlay(); };

    const closeBtn = document.createElement('button');
    closeBtn.className = 'absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white/20 text-white hover:bg-white/40 transition-colors cursor-pointer';
    closeBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>';
    closeBtn.onclick = (e) => { e.stopPropagation(); closeOverlay(); };
    overlayEl.appendChild(closeBtn);

    const prevBtn = document.createElement('button');
    prevBtn.className = 'absolute left-2 sm:left-8 z-10 w-10 h-10 sm:w-16 sm:h-16 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/30 transition-colors cursor-pointer md:flex shadow-md';
    prevBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 sm:w-10 sm:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>';

    const nextBtn = document.createElement('button');
    nextBtn.className = 'absolute right-2 sm:right-8 z-10 w-10 h-10 sm:w-16 sm:h-16 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/30 transition-colors cursor-pointer md:flex shadow-md';
    nextBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 sm:w-10 sm:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>';

    let autoplayTimer = null;
    let isAutoplayRunning = false;
    let autoplayProgress = 0;
    let autoplayStartTime = 0;

    const playSvg = '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.14v14.72a1 1 0 001.5.86l11-7.36a1 1 0 000-1.72l-11-7.36A1 1 0 008 5.14z"/></svg>';
    const pauseSvg = '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>';

    const progressRingId = `ring-${Math.random().toString(36).slice(-6)}`;
    const playBtn = document.createElement('button');
    playBtn.style.cssText = 'position:relative;width:48px;height:48px;display:flex;align-items:center;justify-content:center;border-radius:50%;border:none;cursor:pointer;background:rgba(255,255,255,0.12);color:#fff;transition:background 0.2s;backdrop-filter:blur(4px)';
    playBtn.innerHTML = playSvg;
    playBtn.title = isAutoplayRunning ? 'Pause' : 'Play';
    playBtn.onmouseenter = () => { playBtn.style.background = 'rgba(255,255,255,0.25)'; };
    playBtn.onmouseleave = () => { playBtn.style.background = 'rgba(255,255,255,0.12)'; };

    const progressSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    progressSvg.setAttribute('class', 'absolute inset-0 w-full h-full -rotate-90 overflow-visible');
    progressSvg.setAttribute('viewBox', '0 0 48 48');
    const progressCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    progressCircle.setAttribute('id', progressRingId);
    progressCircle.setAttribute('cx', '24');
    progressCircle.setAttribute('cy', '24');
    progressCircle.setAttribute('r', '22');
    progressCircle.setAttribute('fill', 'none');
    progressCircle.setAttribute('stroke', 'currentColor');
    progressCircle.setAttribute('stroke-width', '2');
    progressCircle.setAttribute('stroke-dasharray', '0 138.23');
    progressCircle.setAttribute('stroke-linecap', 'round');
    progressCircle.style.opacity = '0';
    progressCircle.style.transition = 'none';
    progressSvg.appendChild(progressCircle);
    playBtn.appendChild(progressSvg);

    let animFrame = null;
    function updateProgressRing() {
      if (!isAutoplayRunning) {
        progressCircle.style.opacity = '0';
        progressCircle.setAttribute('stroke-dasharray', '0 138.23');
        if (animFrame) { cancelAnimationFrame(animFrame); animFrame = null; }
        return;
      }
      const elapsed = Date.now() - autoplayStartTime;
      const pct = Math.min(1, elapsed / 3000);
      const circ = 2 * Math.PI * 22;
      const filled = circ * pct;
      progressCircle.style.opacity = '1';
      progressCircle.setAttribute('stroke-dasharray', `${filled} ${circ - filled}`);
      if (pct < 1) {
        animFrame = requestAnimationFrame(updateProgressRing);
      }
    }

    function startAutoplay() {
      if (imgs.length <= 1) return;
      stopAutoplay();
      isAutoplayRunning = true;
      playBtn.innerHTML = '';
      playBtn.appendChild(progressSvg);
      const icon = document.createElement('span');
      icon.innerHTML = pauseSvg;
      icon.className = 'relative z-10 flex items-center justify-center';
      playBtn.appendChild(icon);
      playBtn.title = 'Pause';
      autoplayStartTime = Date.now();
      updateProgressRing();
      autoplayTimer = setInterval(() => { autoplayStartTime = Date.now(); updateProgressRing(); updateImage(currentIndex + 1); }, 3000);
    }

    function stopAutoplay() {
      if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; }
      isAutoplayRunning = false;
      if (animFrame) { cancelAnimationFrame(animFrame); animFrame = null; }
      progressCircle.style.opacity = '0';
      progressCircle.setAttribute('stroke-dasharray', '0 138.23');
      playBtn.innerHTML = '';
      const icon = document.createElement('span');
      icon.innerHTML = playSvg;
      icon.className = 'relative z-10 flex items-center justify-center';
      playBtn.appendChild(icon);
      playBtn.title = 'Play';
    }

    playBtn.onclick = (e) => { e.stopPropagation(); isAutoplayRunning ? stopAutoplay() : startAutoplay(); };

    const wrapper = document.createElement('div');
    wrapper.className = 'absolute bottom-6 left-1/2 -translate-x-1/2 z-10';
    wrapper.appendChild(playBtn);
    if (imgs.length > 1) overlayEl.appendChild(wrapper);

    let scale = 1, posX = 0, posY = 0, dragging = false, lastX = 0, lastY = 0;

    const img = document.createElement('img');
    img.src = imgs[currentIndex] || imageSrc;
    img.className = 'max-w-full max-h-full object-contain rounded shadow-2xl select-none';
    img.style.transition = 'transform 0.1s ease-out';
    img.style.cursor = 'grab';
    img.draggable = false;

    const updateTransform = () => { img.style.transform = `translate(${posX}px, ${posY}px) scale(${scale})`; };
    const resetTransform = () => { scale = 1; posX = 0; posY = 0; updateTransform(); };

    const updateImage = (index: number) => {
      if(index < 0) index = imgs.length - 1;
      if(index >= imgs.length) index = 0;
      currentIndex = index;
      img.src = imgs[currentIndex];
      resetTransform();
    };

    prevBtn.onclick = (e) => { e.stopPropagation(); stopAutoplay(); updateImage(currentIndex - 1); };
    nextBtn.onclick = (e) => { e.stopPropagation(); stopAutoplay(); updateImage(currentIndex + 1); };
    
    if(imgs.length > 1) {
        overlayEl.appendChild(prevBtn);
        overlayEl.appendChild(nextBtn);
    }

    overlayEl.addEventListener('wheel', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const delta = e.deltaY > 0 ? -0.1 : 0.1;
      scale = Math.max(0.5, Math.min(5, scale + delta));
      updateTransform();
    }, { passive: false });

    img.addEventListener('mousedown', (e) => {
      dragging = true;
      lastX = e.clientX;
      lastY = e.clientY;
      img.style.cursor = 'grabbing';
      img.style.transition = 'none';
    });

    window.addEventListener('mousemove', (e) => {
      if (!dragging) return;
      posX += e.clientX - lastX;
      posY += e.clientY - lastY;
      lastX = e.clientX;
      lastY = e.clientY;
      updateTransform();
    });

    window.addEventListener('mouseup', () => {
      if (dragging) {
        dragging = false;
        img.style.cursor = 'grab';
        img.style.transition = 'transform 0.1s ease-out';
      }
    });

    img.addEventListener('dblclick', () => { resetTransform(); });

    overlayEl.appendChild(img);
    (document.body.parentElement || document.documentElement).appendChild(overlayEl);

    const onKey = (e: KeyboardEvent) => { 
      if (e.key === 'Escape') closeOverlay(); 
      if (imgs.length > 1) {
        if (e.key === 'ArrowLeft') { stopAutoplay(); updateImage(currentIndex - 1); }
        if (e.key === 'ArrowRight') { stopAutoplay(); updateImage(currentIndex + 1); }
      }
    };
    document.addEventListener('keydown', onKey);
    (overlayEl as any).__keyHandler = onKey;
  }

  function initGalleryPreview() {
    const imgs = document.querySelectorAll<HTMLElement>('img[data-gallery-src]');
    imgs.forEach(img => {
      if (img.dataset.bound === 'true') return;
      img.dataset.bound = 'true';
      img.addEventListener('click', () => {
        openGalleryPreview(img.dataset.gallerySrc!);
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initGalleryPreview);
  document.addEventListener('astro:page-load', initGalleryPreview);

  function initTagFilter() {
    const containers = [document.getElementById('tag-filter'), document.getElementById('tag-filter-desktop')].filter(Boolean) as HTMLElement[];
    if (containers.length === 0) return;
    if (containers.every(c => c.dataset.bound === 'true')) return;

    const unbound = containers.filter(c => c.dataset.bound !== 'true');
    unbound.forEach(c => { c.dataset.bound = 'true'; });

    unbound.forEach(filterBar => {
      filterBar.querySelectorAll<HTMLElement>('[data-dim-toggle]').forEach(toggle => {
        toggle.addEventListener('click', () => {
          const dim = toggle.dataset.dimToggle;
          const suffix = filterBar.id === 'tag-filter-desktop' ? '-desktop' : '';
          const values = filterBar.querySelector(`.tag-dim-values${suffix}[data-dim="${dim}"], .tag-dim-group${suffix}[data-dim="${dim}"] .tag-dim-values${suffix}`);
          if (values) values.classList.toggle('hidden');
        });
      });
      filterBar.querySelectorAll('[data-letter-toggle]').forEach(toggle => {
        toggle.addEventListener('click', () => {
          const parent = toggle.closest(`.tag-letter-group, .tag-letter-group-desktop`);
          if (parent) {
            const values = parent.querySelector('.tag-letter-values, .tag-letter-values-desktop');
            if (values) values.classList.toggle('hidden');
          }
        });
      });
    });

    const allBtns = containers.flatMap(c => [...c.querySelectorAll<HTMLElement>('.tag-filter-btn')]);
    const articles = document.querySelectorAll<HTMLElement>('#gallery-grid article');
    const selected = new Set();
    let useOr = false;
    const modeToggles = [document.getElementById('filter-mode-toggle'), document.getElementById('filter-mode-toggle-desktop')].filter(Boolean) as HTMLElement[];

    modeToggles.forEach(t => {
      t.addEventListener('click', () => {
        useOr = !useOr;
        modeToggles.forEach(b => { b.textContent = useOr ? 'OR' : 'AND'; b.classList.toggle('bg-[var(--link-color)]', useOr); b.classList.toggle('text-white', useOr); b.classList.toggle('border-[var(--link-color)]', useOr); });
        applyFilter();
      });
    });

    function applyFilter() {
      containers.forEach(filterBar => {
        const allBtn = filterBar.querySelector('[data-tag=""]');
        const tagBtns = filterBar.querySelectorAll<HTMLElement>('[data-tag]:not([data-tag=""])');
        if (!allBtn) return;
        if (selected.size === 0) {
          allBtn.classList.add('bg-[var(--link-color)]', 'text-white', 'border-[var(--link-color)]');
          allBtn.classList.remove('border-[var(--button-border-color)]', 'text-[var(--text-color-70)]');
        } else {
          allBtn.classList.remove('bg-[var(--link-color)]', 'text-white', 'border-[var(--link-color)]');
          allBtn.classList.add('border-[var(--button-border-color)]', 'text-[var(--text-color-70)]');
        }
        tagBtns.forEach(b => {
          if (selected.size > 0 && selected.has(b.dataset.tag)) {
            b.classList.add('bg-[var(--link-color)]', 'text-white', 'border-[var(--link-color)]');
            b.classList.remove('border-[var(--button-border-color)]', 'text-[var(--text-color-70)]');
          } else {
            b.classList.remove('bg-[var(--link-color)]', 'text-white', 'border-[var(--link-color)]');
            b.classList.add('border-[var(--button-border-color)]', 'text-[var(--text-color-70)]');
          }
        });
      });
      articles.forEach(article => {
        if (selected.size === 0) {
          article.style.display = '';
        } else {
          const tags = JSON.parse(article.dataset.tags || '[]');
          article.style.display = useOr
            ? selected.values().some(t => tags.includes(t)) ? '' : 'none'
            : [...selected].every(t => tags.includes(t)) ? '' : 'none';
        }
      });
    }

    allBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag;
        if (!tag) { selected.clear(); }
        else if (selected.has(tag)) { selected.delete(tag); }
        else { selected.add(tag); }
        applyFilter();
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initTagFilter);
  document.addEventListener('astro:page-load', initTagFilter);

  function initBioToggle() {
    const bioContent = document.getElementById('artist-bio-content');
    const bioToggle = document.getElementById('artist-bio-toggle');
    if (!bioContent || !bioToggle) return;
    if (bioToggle.dataset.bound === 'true') return;
    bioToggle.dataset.bound = 'true';

    const isLong = bioContent.textContent !== null && bioContent.textContent.trim().length > 120;
    if (!isLong) return;

    bioContent.classList.add('is-collapsed');
    bioToggle.classList.remove('hidden');

    bioToggle.addEventListener('click', () => {
      const expanded = bioToggle.getAttribute('aria-expanded') === 'true';
      bioToggle.setAttribute('aria-expanded', String(!expanded));
      bioToggle.textContent = expanded
        ? (document.documentElement.lang === 'en' ? 'Show more' : '展开')
        : (document.documentElement.lang === 'en' ? 'Show less' : '收起');

      if (expanded) {
        bioContent.classList.add('is-collapsed');
        bioContent.classList.remove('is-expanded');
      } else {
        bioContent.classList.remove('is-collapsed');
        bioContent.classList.add('is-expanded');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initBioToggle);
  document.addEventListener('astro:page-load', initBioToggle);
</script>
