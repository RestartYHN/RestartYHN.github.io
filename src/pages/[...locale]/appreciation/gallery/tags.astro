---
import MainPageLayout from '@layouts/MainPageLayout.astro'
import Cover from '@components/Cover.astro'
import FabMenu from '@components/control/FabMenu.astro'
import { siteConfig } from '@/config'
import i18nit from '@i18n/translation'
import { i18n } from "astro:config/client"
import { getRelativeLocaleUrl } from '@utils/url-utils'
import { loadGalleryData } from '@utils/gallery-utils'
import { pinyin } from 'pinyin-pro'

export async function getStaticPaths() {
  return i18n?.locales.map(locale => ({
    params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) }
  }))
}

const currentLang = Astro.currentLocale || i18n!.defaultLocale
const normalizedLang = currentLang === 'en' ? 'en' : 'zh-cn'
const t = i18nit(currentLang)

function parseTag(tag: string): [string, string] {
  const idx = tag.indexOf(':');
  if (idx === -1) return ['', tag];
  return [tag.slice(0, idx), tag.slice(idx + 1)];
}

function getInitial(tag: string): string {
  const [, val] = parseTag(tag);
  const ch = val.charAt(0);
  if (/[a-zA-Z]/.test(ch)) return ch.toUpperCase()
  if (/[0-9]/.test(ch)) return '#'
  if (/[\u4e00-\u9fff]/.test(ch)) {
    const py = pinyin(ch, { pattern: 'first', toneType: 'none' })
    return py ? py.toUpperCase() : '#'
  }
  return '#'
}

const { authors, works } = loadGalleryData()
const tagCounts: Record<string, number> = {}
works.forEach(w => {
  (w.tags || []).forEach(tag => { tagCounts[tag] = (tagCounts[tag] || 0) + 1 })
})
const allTags = [...new Set(works.flatMap(w => [...(w.tags || []), `年份:${w.year}`]))].sort((a, b) => {
  const [, va] = parseTag(a);
  const [, vb] = parseTag(b);
  return va.localeCompare(vb, 'zh-u-co-pinyin') || a.localeCompare(b);
})

const dimGroups: { dim: string, letters: { key: string, values: { val: string, full: string, count: number }[] }[] }[] = (() => {
  const map = new Map<string, Map<string, Map<string, number>>>();
  for (const tag of allTags) {
    const [dim, val] = parseTag(tag);
    const d = dim || '其他';
    const init = getInitial(val);
    if (!map.has(d)) map.set(d, new Map());
    const dm = map.get(d)!;
    if (!dm.has(init)) dm.set(init, new Map());
    const vm = dm.get(init)!;
    vm.set(val, (vm.get(val) || 0) + 1);
  }
  const result: typeof dimGroups = [];
  for (const [dim, dm] of map) {
    const letters: { key: string; values: { val: string; full: string; count: number }[] }[] = [];
    for (const [key, vm] of dm) {
      const values = Array.from(vm.entries()).map(([val, count]) => ({
        val,
        full: dim === '其他' ? val : `${dim}:${val}`,
        count,
      }));
      values.sort((a, b) => a.val.localeCompare(b.val, 'zh-u-co-pinyin'));
      letters.push({ key, values });
    }
    letters.sort((a, b) => a.key.localeCompare(b.key));
    result.push({ dim, letters });
  }
  result.sort((a, b) => a.dim.localeCompare(b.dim, 'zh-u-co-pinyin'));
  return result;
})()

const cacheVersion = Date.now().toString()
const pageTitle = `${normalizedLang === 'en' ? 'Gallery Overview' : '画廊总览'} - ${t('header.appreciation')} - ${siteConfig.title}`
---

<MainPageLayout title={pageTitle} lang={currentLang} noCache={true}>
  <div class="mx-auto w-full max-w-[var(--page-width)]">
    <div class="mb-4">
      <a href={`${getRelativeLocaleUrl(currentLang, '/appreciation/gallery/')}?v=${cacheVersion}`} class="text-sm text-[var(--link-color)] hover:underline">
        {normalizedLang === 'en' ? '← Back to Gallery' : '← 返回画廊'}
      </a>
    </div>

    <Cover
      title={normalizedLang === 'en' ? 'Gallery Overview' : '画廊总览'}
      subTitle={normalizedLang === 'en'
        ? `${works.length} works · ${allTags.length} tags`
        : `${works.length} 幅作品 · ${allTags.length} 个标签`}
    />

    <details id="tag-filter-mobile" class="lg:hidden mb-6 border border-[var(--button-border-color)] rounded-xl p-3">
      <summary class="flex items-center gap-2 text-sm font-semibold text-[var(--text-color)] cursor-pointer select-none">
        <span>{normalizedLang === 'en' ? 'Tags' : '标签'}</span>
        <span id="selected-count-mobile" class="text-xs font-normal text-[var(--text-color-70)] hidden"></span>
        <div class="ml-auto flex items-center gap-1">
          <button id="tag-hide-toggle-mobile" class="px-1.5 py-0.5 text-[11px] rounded border border-[var(--button-border-color)] text-[var(--text-color-70)]" onclick="toggleCardText(this);event.preventDefault(); event.stopPropagation();">显示</button>
          <button id="filter-mode-toggle-mobile" class="px-1.5 py-0.5 text-[11px] rounded border border-[var(--button-border-color)] text-[var(--text-color-70)]" onclick="event.preventDefault(); event.stopPropagation();">AND</button>
        </div>
      </summary>
      <div class="mt-2 max-h-[50vh] overflow-y-auto">
        <button data-tag="" class="tag-filter-btn w-full text-left px-2 py-1.5 text-sm rounded text-[var(--link-color)] font-semibold transition-colors mb-1">
          {normalizedLang === 'en' ? 'All' : '全部'} ({works.length})
        </button>
        {dimGroups.map(group => (<>
          <div class="tag-dim-group-mobile" data-dim={group.dim}>
            <span class="block text-xs font-bold text-[var(--link-color)] px-2 py-0.5 mt-2 cursor-pointer" data-dim-toggle={group.dim}>{group.dim}</span>
            <div class="tag-dim-values-mobile ml-1 hidden">
              {group.letters.map(l => (
                <div class="tag-letter-group-mobile" data-letter={l.key}>
                  <span class="block text-[11px] text-[var(--text-color-70)] px-2 py-0.5 cursor-pointer" data-letter-toggle={`${group.dim}:${l.key}`}>{l.key}</span>
                  <div class:list={["tag-letter-values-mobile ml-2", { hidden: l.values.length > 3 }]}>
                    {l.values.map(v => (
                      <button data-tag={v.full} class="tag-filter-btn w-full text-left px-2 py-1 text-xs rounded text-[var(--text-color-70)] hover:bg-[var(--button-hover-color)] transition-colors">
                        {v.val} <span class="opacity-50">({v.count})</span>
                      </button>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </>))}
      </div>
    </details>

    <div class="relative mb-8">
      <section id="gallery-grid" class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
        {works.map((item) => {
          const authorInfo = authors.find(a => a.slug.toLowerCase() === item.author.toLowerCase())
          return (
            <article data-tags={JSON.stringify([...(item.tags || []), `年份:${item.year}`])} class="break-inside-avoid overflow-hidden rounded-xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/70">
              <img
                src={item.image}
                alt={item.title['zh-cn']}
                data-gallery-src={item.image}
                class="w-full h-auto object-contain cursor-zoom-in"
                loading="lazy" decoding="async"
              />
              <div class="card-text p-3">
                <h3 class="text-base font-semibold text-[var(--text-color)]">{item.title['zh-cn']}</h3>
                {authorInfo && (
                  <a href={`${getRelativeLocaleUrl(currentLang, `/appreciation/gallery/${authorInfo.slug}/`)}?v=${cacheVersion}`} class="inline-block mt-1 text-sm text-[var(--link-color)] hover:underline">
                    {authorInfo.name[normalizedLang]}
                  </a>
                )}
                <p class="mt-1 text-sm text-[var(--text-color-70)]">{item.year}</p>
                {item.tags?.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1">
                    {item.tags.map((tag) => {
                      const [dim, val] = parseTag(tag);
                      return (
                        <span class="text-xs px-2 py-1 rounded-md bg-[var(--button-hover-color)] text-[var(--text-color-70)]">
                          {dim ? <><span class="opacity-50">{dim}·</span>{val}</> : val}
                        </span>
                      );
                    })}
                  </div>
                )}
              </div>
            </article>
          )
        })}
      </section>
    </div>

    <aside id="tag-filter" class="hidden lg:block absolute left-[var(--toc-offset-left)] top-20 w-44 border-l border-[var(--button-border-color)] pl-4 max-h-[calc(100vh-5rem)] overflow-y-auto z-10">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-sm font-semibold text-[var(--text-color)]">
            {normalizedLang === 'en' ? 'Tags' : '标签'}
            <span id="selected-count" class="ml-1 text-xs font-normal text-[var(--text-color-70)] hidden"></span>
          </h3>
          <div class="flex items-center gap-1">
            <button id="tag-hide-toggle-desktop" class="px-1.5 py-0.5 text-[11px] rounded border border-[var(--button-border-color)] text-[var(--text-color-70)] hover:border-[var(--link-color)] transition-colors" onclick="toggleCardText(this);event.stopPropagation()">显示</button>
            <button id="filter-mode-toggle" class="px-1.5 py-0.5 text-[11px] rounded border border-[var(--button-border-color)] text-[var(--text-color-70)] hover:border-[var(--link-color)] transition-colors">AND</button>
          </div>
        </div>
        <button data-tag="" class="tag-filter-btn w-full text-left px-2 py-1.5 text-sm rounded text-[var(--link-color)] font-semibold transition-colors mb-1">
          {normalizedLang === 'en' ? 'All' : '全部'} ({works.length})
        </button>
        {dimGroups.map(group => (<>
          <div class="tag-dim-group" data-dim={group.dim}>
            <span class="block text-xs font-bold text-[var(--link-color)] px-2 py-0.5 mt-2 cursor-pointer" data-dim-toggle={group.dim}>{group.dim}</span>
            <div class="tag-dim-values ml-1 hidden">
              {group.letters.map(l => (
                <div class="tag-letter-group" data-letter={l.key}>
                  <span class="block text-[11px] text-[var(--text-color-70)] px-2 py-0.5 cursor-pointer" data-letter-toggle={`${group.dim}:${l.key}`}>{l.key}</span>
                  <div class:list={["tag-letter-values ml-2", { hidden: l.values.length > 3 }]}>
                    {l.values.map(v => (
                      <button data-tag={v.full} class="tag-filter-btn w-full text-left px-2 py-1 text-xs rounded text-[var(--text-color-70)] hover:bg-[var(--button-hover-color)] transition-colors">
                        {v.val} <span class="opacity-50">({v.count})</span>
                      </button>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </>))}
      </aside>
  </div>
  <FabMenu showBackBottom={true} />
</MainPageLayout>

<script>
  let overlayEl: HTMLDivElement | null = null;

  function closeOverlay() {
    if (overlayEl) {
      document.removeEventListener('keydown', (overlayEl as any).__keyHandler);
      overlayEl.remove();
      overlayEl = null;
    }
  }

  function openGalleryPreview(imageSrc: string) {
    closeOverlay();

    const visibleArticles = document.querySelectorAll('#gallery-grid article:not([style*="display: none"])');
    const imgs = Array.from(visibleArticles).map(article => {
      const img = article.querySelector<HTMLElement>('img[data-gallery-src]');
      return img ? img.dataset.gallerySrc : null;
    }).filter(src => src) as string[];

    let currentIndex = imgs.indexOf(imageSrc);
    if (currentIndex === -1) currentIndex = 0;

    overlayEl = document.createElement('div');
    overlayEl.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:99999;background:rgba(0,0,0,0.8);display:flex;align-items:center;justify-content:center;overflow:hidden';
    overlayEl.className = 'relative';
    overlayEl.onclick = (e) => { if (e.target === overlayEl) closeOverlay(); };

    const closeBtn = document.createElement('button');
    closeBtn.className = 'absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white/20 text-white hover:bg-white/40 transition-colors cursor-pointer';
    closeBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>';
    closeBtn.onclick = (e) => { e.stopPropagation(); closeOverlay(); };
    overlayEl.appendChild(closeBtn);

    const prevBtn = document.createElement('button');
    prevBtn.className = 'absolute left-2 sm:left-8 z-10 w-10 h-10 sm:w-16 sm:h-16 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/30 transition-colors cursor-pointer md:flex shadow-md';
    prevBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 sm:w-10 sm:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>';

    const nextBtn = document.createElement('button');
    nextBtn.className = 'absolute right-2 sm:right-8 z-10 w-10 h-10 sm:w-16 sm:h-16 flex items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/30 transition-colors cursor-pointer md:flex shadow-md';
    nextBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 sm:w-10 sm:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>';

    let scale = 1, posX = 0, posY = 0, dragging = false, lastX = 0, lastY = 0;

    const img = document.createElement('img');
    img.src = imgs[currentIndex] || imageSrc;
    img.className = 'max-w-full max-h-full object-contain rounded shadow-2xl select-none';
    img.style.transition = 'transform 0.1s ease-out';
    img.style.cursor = 'grab';
    img.draggable = false;

    const updateTransform = () => { img.style.transform = `translate(${posX}px, ${posY}px) scale(${scale})`; };
    const resetTransform = () => { scale = 1; posX = 0; posY = 0; updateTransform(); };

    const updateImage = (index: number) => {
      if(index < 0) index = imgs.length - 1;
      if(index >= imgs.length) index = 0;
      currentIndex = index;
      img.src = imgs[currentIndex];
      resetTransform();
    };

    prevBtn.onclick = (e) => { e.stopPropagation(); updateImage(currentIndex - 1); };
    nextBtn.onclick = (e) => { e.stopPropagation(); updateImage(currentIndex + 1); };

    if(imgs.length > 1) {
        overlayEl.appendChild(prevBtn);
        overlayEl.appendChild(nextBtn);
    }

    overlayEl.addEventListener('wheel', (e) => {
      e.preventDefault(); e.stopPropagation();
      scale = Math.max(0.5, Math.min(5, scale + (e.deltaY > 0 ? -0.1 : 0.1)));
      updateTransform();
    }, { passive: false });

    img.addEventListener('mousedown', (e) => { dragging = true; lastX = e.clientX; lastY = e.clientY; img.style.cursor = 'grabbing'; img.style.transition = 'none'; });
    window.addEventListener('mousemove', (e) => { if (!dragging) return; posX += e.clientX - lastX; posY += e.clientY - lastY; lastX = e.clientX; lastY = e.clientY; updateTransform(); });
    window.addEventListener('mouseup', () => { if (dragging) { dragging = false; img.style.cursor = 'grab'; img.style.transition = 'transform 0.1s ease-out'; } });
    img.addEventListener('dblclick', () => { resetTransform(); });

    overlayEl.appendChild(img);
    (document.body.parentElement || document.documentElement).appendChild(overlayEl);
    const onKey = (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeOverlay();
      if (imgs.length > 1) {
        if (e.key === 'ArrowLeft') updateImage(currentIndex - 1);
        if (e.key === 'ArrowRight') updateImage(currentIndex + 1);
      }
    };
    document.addEventListener('keydown', onKey);
    (overlayEl as any).__keyHandler = onKey;
  }

  function initGalleryPreview() {
    document.querySelectorAll<HTMLElement>('img[data-gallery-src]').forEach(img => {
      if (img.dataset.bound === 'true') return;
      img.dataset.bound = 'true';
      img.addEventListener('click', () => openGalleryPreview(img.dataset.gallerySrc!));
    });
  }

  document.addEventListener('DOMContentLoaded', initGalleryPreview);
  document.addEventListener('astro:page-load', initGalleryPreview);

  function initTagFilter() {
    const containers = [document.getElementById('tag-filter'), document.getElementById('tag-filter-mobile')].filter(Boolean) as HTMLElement[];
    if (containers.length === 0) return;
    if (containers.every(c => c.dataset.bound === 'true')) return;

    const unbound = containers.filter(c => c.dataset.bound !== 'true');
    unbound.forEach(c => { c.dataset.bound = 'true'; });

    unbound.forEach(filterBar => {
      filterBar.querySelectorAll<HTMLElement>('[data-dim-toggle]').forEach(toggle => {
        toggle.addEventListener('click', () => {
          const dim = toggle.dataset.dimToggle;
          const cls = filterBar.id === 'tag-filter-mobile' ? '.tag-dim-group-mobile' : '.tag-dim-group';
          const values = filterBar.querySelector(`${cls}[data-dim="${dim}"] .tag-dim-values, ${cls}[data-dim="${dim}"] .tag-dim-values-mobile`);
          if (values) values.classList.toggle('hidden');
        });
      });

      filterBar.querySelectorAll('[data-letter-toggle]').forEach(toggle => {
        toggle.addEventListener('click', () => {
          const parent = toggle.closest('.tag-letter-group, .tag-letter-group-mobile');
          if (parent) {
            const values = parent.querySelector('.tag-letter-values, .tag-letter-values-mobile');
            if (values) values.classList.toggle('hidden');
          }
        });
      });
    });

    const allBtns = containers.flatMap(c => [...c.querySelectorAll<HTMLElement>('.tag-filter-btn')]);
    const articles = document.querySelectorAll<HTMLElement>('#gallery-grid article');
    const selected = new Set();
    let useOr = false;
    const countEls = [document.getElementById('selected-count'), document.getElementById('selected-count-mobile')].filter(Boolean) as HTMLElement[];
    const modeToggles = [document.getElementById('filter-mode-toggle'), document.getElementById('filter-mode-toggle-mobile')].filter(Boolean) as HTMLElement[];

    modeToggles.forEach(t => {
      t.addEventListener('click', () => {
        useOr = !useOr;
        modeToggles.forEach(b => { b.textContent = useOr ? 'OR' : 'AND'; b.classList.toggle('bg-[var(--link-color)]', useOr); b.classList.toggle('text-white', useOr); b.classList.toggle('border-[var(--link-color)]', useOr); });
        applyFilter();
      });
    });

    function applyFilter() {
      containers.forEach(filterBar => {
        const allBtn = filterBar.querySelector('[data-tag=""]');
        const tagBtns = filterBar.querySelectorAll<HTMLElement>('[data-tag]:not([data-tag=""])');
        if (!allBtn) return;

        if (selected.size === 0) {
          allBtn.classList.add('bg-[var(--link-color)]', 'text-white', 'border-[var(--link-color)]');
          allBtn.classList.remove('border-[var(--button-border-color)]', 'text-[var(--text-color-70)]');
        } else {
          allBtn.classList.remove('bg-[var(--link-color)]', 'text-white', 'border-[var(--link-color)]');
          allBtn.classList.add('border-[var(--button-border-color)]', 'text-[var(--text-color-70)]');
        }

        tagBtns.forEach(b => {
          if (selected.size > 0 && selected.has(b.dataset.tag)) {
            b.classList.add('bg-[var(--link-color)]', 'text-white', 'border-[var(--link-color)]');
            b.classList.remove('border-[var(--button-border-color)]', 'text-[var(--text-color-70)]');
          } else {
            b.classList.remove('bg-[var(--link-color)]', 'text-white', 'border-[var(--link-color)]');
            b.classList.add('border-[var(--button-border-color)]', 'text-[var(--text-color-70)]');
          }
        });
      });

      countEls.forEach(el => {
        el.classList.toggle('hidden', selected.size === 0);
        if (selected.size > 0) el.textContent = `· ${selected.size} ${document.documentElement.lang === 'en' ? 'selected' : '已选'}`;
      });

      articles.forEach(article => {
        if (selected.size === 0) {
          article.style.display = '';
        } else {
          const tags = JSON.parse(article.dataset.tags || '[]');
          article.style.display = useOr
            ? selected.values().some(t => tags.includes(t)) ? '' : 'none'
            : [...selected].every(t => tags.includes(t)) ? '' : 'none';
        }
      });
    }

    allBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag;
        if (!tag) { selected.clear(); }
        else if (selected.has(tag)) { selected.delete(tag); }
        else { selected.add(tag); }
        applyFilter();
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initTagFilter);
  document.addEventListener('astro:page-load', initTagFilter);

  function initCardTagToggle() {
    const hidden = localStorage.getItem('momo-gallery-hide-card-tags') === 'true';
    if (hidden) {
      const grid = document.getElementById('gallery-grid');
      if (grid) {
        grid.querySelectorAll('.card-text').forEach(c => { c.style.display = 'none'; });
        const btns = document.querySelectorAll('#tag-hide-toggle-desktop, #tag-hide-toggle-mobile');
        const label = document.documentElement.lang === 'en' ? 'Show' : '显示';
        btns.forEach(b => {
          b.textContent = label;
          b.classList.add('bg-[var(--link-color)]', 'text-white', 'border-[var(--link-color)]');
        });
      }
    }
  }

  initCardTagToggle();
  document.addEventListener('astro:page-load', initCardTagToggle);
</script>
