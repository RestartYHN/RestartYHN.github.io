---
import MainPageLayout from '@layouts/MainPageLayout.astro';
import Cover from '@components/Cover.astro';
import PostPage from '@components/PostPage.astro';
import Navi from '@components/control/Navi.astro';
import FabMenu from '@components/control/FabMenu.astro';

import { getCollection } from 'astro:content';
import { getAppreciationEntrySort } from '@utils/content-utils'
import { siteConfig } from '@/config';
import { i18n } from "astro:config/client";
import type { GetStaticPaths } from 'astro';
import { getRelativeLocaleUrl } from '@utils/url-utils';

import i18nit from '@i18n/translation'

const { page } = Astro.props;
const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);

export const getStaticPaths = (async ({ paginate }) => {
  const paths = [];
  const localeConfig = i18n!;
  for (const locale of localeConfig.locales) {
    const localeCode = typeof locale === 'string' ? locale : locale.path;
    const localeParam = localeCode === localeConfig.defaultLocale ? undefined : localeCode;
    const entries = await getAppreciationEntrySort(localeParam ?? localeConfig.defaultLocale);
    const paginatedPaths = paginate(entries, {
      pageSize: siteConfig.pageSize,
      params: { locale: localeParam }
    });
    paths.push(...paginatedPaths);
  }
  return paths;
}) satisfies GetStaticPaths

const pageTitle = `${t("header.appreciation")} - ${siteConfig.title}`;
---

<MainPageLayout title={pageTitle} lang={currentLang}>
  <Cover 
    title={currentLang === 'en' ? 'Articles' : '文章'} 
    subTitle={currentLang === 'en' ? 'Curated appreciation articles' : '我喜欢的文章、段落摘录和个人创作'} 
  />
  <div class="mx-auto w-full max-w-[var(--page-width)] mb-6">
    <a href={getRelativeLocaleUrl(currentLang, '/appreciation/')} class="inline-flex items-center gap-1 px-4 py-2 text-sm rounded-lg border border-[var(--button-border-color)] text-[var(--text-color)] hover:border-[var(--link-color)] hover:text-[var(--link-color)] transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      {currentLang === 'en' ? 'Back' : '返回鉴赏'}
    </a>
  </div>
  <PostPage page={page} basePath="/appreciation/articles/" />
  <Navi page={page} base="/appreciation/articles/" />
  <FabMenu showBackBottom={true} />
</MainPageLayout>
