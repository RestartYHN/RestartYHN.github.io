---
import MainPageLayout from '@layouts/MainPageLayout.astro';
import Cover from '@components/Cover.astro';
import FabMenu from '@components/control/FabMenu.astro';
import Comments from '@components/comment/Comments.svelte';
import { siteConfig } from '@/config';
import { musicConfig } from '@/data/music';
import i18nit from '@i18n/translation';
import { i18n } from 'astro:config/client';

export async function getStaticPaths() {
  return i18n?.locales.map((locale) => ({
    params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) },
  }));
}

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);
const isEn = currentLang === 'en';
const pageTitle = `${t('header.music')} - ${siteConfig.title}`;
---

<MainPageLayout title={pageTitle} lang={currentLang} noCache={true}>
  <div class="mx-auto w-full max-w-[var(--page-width)]">
    <Cover
      title={isEn ? 'Music' : '音乐'}
      subTitle={isEn
        ? 'NetEase web player(web recommended): You can select any playlist and start listening.Stay before the page and you can appreciate the lyrics.Moreover,the global player is enabled, so opening other sibling pages will not affect the current playlist playback. However, re-entering the music page will fail to load properly (not fixed yet). To reselect a playlist, please refresh the entire page to reinitialize, then choose the playlist you want to listen to. Summary: Open the music page, select a playlist to listen, refresh the page to reselect. Note: Only public playlist info is loaded, VIP tracks cannot be played in full.'
        : '网易云网页播放(推荐网页端)：你可以选择任一歌单然后开听,保持在此页面可欣赏歌词.另外已设置全局播放器,打开其他同级页面不影响当前歌单播放，但在再次进入音乐页时会无法正常加载（还没修好）,如要重新选择歌单请刷新整个页面重新初始化,再选择想听的歌单.\n一句话概括:打开音乐页面、选歌单收听、刷新整个页面重新选.\n另外,页面读取的是公开歌单信息,vip曲目不能播放全曲,还请注意.'
      }
    />

    <p id="music-status" class="music-status hidden"></p>

    {/* Playlist Popup Modal */}
    <div id="music-playlist-modal" class="music-playlist-modal hidden">
      <div class="music-playlist-modal-backdrop" id="music-playlist-modal-backdrop"></div>
      <div class="music-playlist-modal-content">
        <div class="music-playlist-modal-header">
          <h3 class="music-playlist-modal-title">{isEn ? 'Current Playlist' : '当前播放列表'}</h3>
          <button id="music-playlist-modal-close" class="music-playlist-modal-close" type="button">×</button>
        </div>
        <ul id="music-playlist-modal-list" class="music-playlist-modal-list"></ul>
      </div>
    </div>

    <div class="music-main-grid">
      {/* Top Row: Album & Lyrics */}
      <section class="music-hero">
        <div class="music-hero-bg" id="music-hero-bg"></div>
        <div class="music-hero-content">
          <div class="music-now-card">
            <div id="music-cover" class="music-cover"></div>
            <h3 id="music-title" class="music-title">Loading...</h3>
            <p id="music-artist" class="music-artist">-</p>
            <button id="music-play-toggle" class="music-play-btn" type="button">
              {isEn ? 'Play / Pause' : '播放 / 暂停'}
            </button>
            {/* Play Mode & Playlist Controls */}
            <div class="music-controls-row">
              <button id="music-mode-sequential" class="music-mode-btn active" type="button" title={isEn ? 'Sequential' : '顺序播放'}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="3" y1="6" x2="21" y2="6"></line>
                  <line x1="3" y1="12" x2="21" y2="12"></line>
                  <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
              </button>
              <button id="music-mode-loop" class="music-mode-btn" type="button" title={isEn ? 'Loop One' : '单曲循环'}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="9"></circle>
                  <path d="M12 8v4l2 2"></path>
                </svg>
              </button>
              <button id="music-mode-shuffle" class="music-mode-btn" type="button" title={isEn ? 'Shuffle' : '随机播放'}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M16 3h5v5"></path>
                  <path d="M4 20L21 3"></path>
                  <path d="M21 16v5h-5"></path>
                  <path d="M15 15l6 6"></path>
                  <path d="M4 4l5 5"></path>
                </svg>
              </button>
              <button id="music-playlist-toggle" class="music-playlist-btn" type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 18V5l12-2v13"></path>
                  <circle cx="6" cy="18" r="3"></circle>
                  <circle cx="18" cy="16" r="3"></circle>
                </svg>
                <span id="music-playlist-count">0</span>
              </button>
            </div>
          </div>
        </div>
      </section>

      <section class="music-panel music-lyrics-panel">
        <h4 class="music-lyrics-title">{isEn ? 'Lyrics' : '歌词'}</h4>
        <ul id="music-lyrics" class="music-lyrics">
          <li>{isEn ? 'Lyrics loading...' : '歌词加载中...'}</li>
        </ul>
      </section>

      {/* Bottom Row: Playlists & Tracks */}
      <section class="music-panel music-playlist-section">
        <div class="mb-3 flex items-end justify-between gap-3">
          <h2 class="music-panel-title">{isEn ? 'Playlists' : '歌单'}</h2>
          <span id="music-playlist-subtitle" class="music-panel-subtitle">{isEn ? 'Click to load' : '点击加载'}</span>
        </div>
        <ul id="music-playlist-list" class="music-playlist-list"></ul>
      </section>

      <section class="music-panel music-tracks-section">
        <div class="mb-3 flex items-end justify-between gap-3">
          <h2 class="music-panel-title" id="music-list-title">{isEn ? 'Tracks' : '歌曲列表'}</h2>
          <span id="music-list-subtitle" class="music-panel-subtitle">{isEn ? 'Click to play' : '点击播放'}</span>
        </div>
        <ul id="music-track-list" class="music-track-list"></ul>
      </section>
    </div>

    <section id="music-comments" data-music-comments="true" class="mt-10 rounded-xl border border-[var(--button-border-color)] p-4">
      <h3 class="mb-4 text-lg font-semibold text-[var(--text-color)]">
        {isEn ? 'Comments' : '评论区'}
      </h3>
      <Comments
        client:load
        postSlug="music"
        postTitle={pageTitle}
        language={currentLang}
      />
    </section>

  </div>

  <FabMenu showBackBottom={true} />
</MainPageLayout>

<style>
  .music-main-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  @media (max-width: 1024px) {
    .music-main-grid {
      grid-template-columns: 1fr;
    }
  }

  .music-hero {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--button-border-color);
    grid-column: 1;
    grid-row: 1;
  }

  @media (max-width: 1024px) {
    .music-hero {
      grid-column: 1;
      grid-row: 1;
    }
  }

  .music-lyrics-panel {
    grid-column: 2;
    grid-row: 1;
  }

  @media (max-width: 1024px) {
    .music-lyrics-panel {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .music-playlist-section {
    grid-column: 1;
    grid-row: 2;
  }

  @media (max-width: 1024px) {
    .music-playlist-section {
      grid-column: 1;
      grid-row: 3;
    }
  }

  .music-tracks-section {
    grid-column: 2;
    grid-row: 2;
  }

  @media (max-width: 1024px) {
    .music-tracks-section {
      grid-column: 1;
      grid-row: 4;
    }
  }

  .music-hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 20%, rgba(213, 165, 106, 0.2), transparent 48%),
      linear-gradient(135deg, rgba(0, 0, 0, 0.08), transparent 60%);
    filter: saturate(1.1);
  }

  .music-hero-content {
    position: relative;
    z-index: 1;
    padding: 1.1rem;
    backdrop-filter: blur(5px);
  }

  .music-status {
    margin: 0 0 0.8rem;
    padding: 0.5rem 0.8rem;
    border-radius: 0.6rem;
    border: 1px solid color-mix(in oklab, #d5a56a 40%, var(--button-border-color));
    background: color-mix(in oklab, #d5a56a 14%, transparent);
    color: var(--text-color-70);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .music-status.hidden {
    display: none;
  }

  .music-now-card,
  .music-lyrics-panel,
  .music-panel {
    border: 1px solid var(--button-border-color);
    border-radius: 0.95rem;
    padding: 1rem;
    background: color-mix(in oklab, var(--bg-color) 88%, transparent);
  }

  .music-cover {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 0.8rem;
    background: var(--button-hover-color);
    background-size: cover;
    background-position: center;
    margin-bottom: 0.8rem;
  }

  .music-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-color);
  }

  .music-artist,
  .music-panel-subtitle,
  .music-lyrics-title {
    color: var(--text-color-70);
  }

  .music-play-btn {
    margin-top: 1rem;
    border-radius: 999px;
    border: none;
    background: #d5a56a;
    color: #fff;
    padding: 0.55rem 1rem;
    cursor: pointer;
    transition: background-color 160ms ease;
  }

  .music-play-btn:hover {
    background: #c9925f;
  }

  .music-play-btn,
  .music-control {
    transition: transform 160ms ease, background-color 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }

  .music-play-btn:hover,
  .music-control:hover {
    transform: translateY(-1px);
  }

  .music-play-btn:active,
  .music-control:active {
    transform: translateY(0) scale(0.96);
  }

  .music-panel-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-color);
  }

  .music-lyrics {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 500px;
    overflow: auto;
    overscroll-behavior: contain;
    scroll-behavior: smooth;
    scroll-padding-block: 45%;
    line-height: 1.9;
  }

  @media (max-width: 768px) {
    .music-lyrics {
      scroll-padding-block: 45%;
    }
  }

  .music-lyrics li {
    color: var(--text-color-70);
    padding: 0.4rem 0;
    transition: color 160ms ease;
  }

  .music-lyrics li.active {
    color: var(--text-color);
    font-weight: 600;
  }

  .music-lyrics-main {
    line-height: 1.5;
  }

  .music-lyrics-trans {
    margin-top: 0.15rem;
    font-size: 0.86rem;
    line-height: 1.45;
    color: color-mix(in oklab, var(--text-color-70) 85%, transparent);
  }

  .music-lyrics li.active .music-lyrics-main {
    color: var(--text-color);
  }

  .music-lyrics li.active .music-lyrics-trans {
    color: color-mix(in oklab, var(--text-color) 65%, transparent);
  }

  .music-track-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-height: 500px;
    overflow-y: auto;
  }

  .music-track-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    border: 1px solid var(--button-border-color);
    border-radius: 0.9rem;
    background: color-mix(in oklab, var(--bg-color) 95%, transparent);
    padding: 0.7rem;
    cursor: pointer;
    transition: background-color 160ms ease, transform 160ms ease;
  }

  .music-track-index {
    width: 2rem;
    text-align: center;
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--text-color-70);
    flex-shrink: 0;
  }

  .music-track-card.active {
    background: var(--button-hover-color);
    border-color: #d5a56a;
  }

  .music-track-card.unavailable {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .music-track-card.unavailable:hover {
    background: color-mix(in oklab, var(--bg-color) 95%, transparent);
    transform: none;
  }

  .music-track-card:hover {
    background: var(--button-hover-color);
  }

  .music-track-card.loading {
    opacity: 0.6;
    pointer-events: none;
  }

  .music-track-played {
    margin-top: 0.15rem;
    color: var(--text-color-70);
    font-size: 0.75rem;
  }

  .music-track-title {
    margin: 0;
    color: var(--text-color);
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .music-track-artist {
    margin-top: 0.2rem;
    color: var(--text-color-70);
    font-size: 0.85rem;
  }

  .music-bottom-player {
    position: sticky;
    bottom: 0.8rem;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid var(--button-border-color);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--bg-color) 90%, transparent);
    padding: 0.75rem;
    backdrop-filter: blur(8px);
  }

  @media (max-width: 768px) {
    .music-bottom-player {
      display: grid;
      grid-template-columns: 54px minmax(0, 1fr) auto auto auto;
      grid-template-areas:
        "cover info prev play next"
        "progress progress progress progress progress";
      gap: 0.45rem 0.5rem;
      align-items: center;
      padding: 0.65rem;
    }

    .music-bottom-cover {
      grid-area: cover;
    }

    .music-bottom-player .min-w-0 {
      grid-area: info;
      min-width: 0;
    }

    #music-prev {
      grid-area: prev;
    }

    #music-main-play {
      grid-area: play;
    }

    #music-next {
      grid-area: next;
    }

    .music-progress-wrap {
      grid-area: progress;
      grid-column: 1 / -1;
      margin-top: 0.2rem;
      margin-left: -0.65rem;
      margin-right: -0.65rem;
      padding: 0 0.65rem;
      grid-template-columns: 34px 1fr 34px;
      gap: 0.35rem;
    }

    .music-position-info {
      display: none;
    }

    .music-control {
      width: 36px;
      height: 36px;
    }
  }

  .music-bottom-cover {
    width: 54px;
    height: 54px;
    border-radius: 0.65rem;
    background: var(--button-hover-color);
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .music-progress-wrap {
    margin-top: 0.35rem;
    display: grid;
    grid-template-columns: 42px 1fr 42px;
    align-items: center;
    gap: 0.45rem;
    --progress-percent: 0%;
  }

  .music-progress-wrap.is-dragging {
    filter: saturate(1.08);
  }

  .music-progress {
    width: 100%;
    accent-color: #d5a56a;
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
    height: 18px;
    background: linear-gradient(
      to right,
      #d5a56a 0%,
      #d5a56a var(--progress-percent),
      color-mix(in oklab, #d5a56a 20%, var(--button-border-color)) var(--progress-percent),
      color-mix(in oklab, #d5a56a 20%, var(--button-border-color)) 100%
    );
    border-radius: 999px;
    outline: none;
  }

  .music-progress::-webkit-slider-runnable-track {
    height: 3px;
    border-radius: 999px;
    background: transparent;
  }

  .music-progress::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    margin-top: -5.5px;
    border-radius: 50%;
    border: 2px solid color-mix(in oklab, #d5a56a 80%, #fff);
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }

  .music-progress::-moz-range-track {
    height: 3px;
    border: none;
    border-radius: 999px;
    background: transparent;
  }

  .music-progress::-moz-range-thumb {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid color-mix(in oklab, #d5a56a 80%, #fff);
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }

  .music-time {
    font-size: 0.72rem;
    color: var(--text-color-70);
    text-align: center;
    white-space: nowrap;
  }

  .music-position-info {
    font-size: 0.8rem;
    color: var(--text-color-70);
    white-space: nowrap;
    margin-right: 0.3rem;
  }

  .music-playlist-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-height: 500px;
    overflow-y: auto;
  }

  .music-playlist-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    border: 1px solid var(--button-border-color);
    border-radius: 0.9rem;
    background: color-mix(in oklab, var(--bg-color) 95%, transparent);
    padding: 0.75rem 0.8rem;
    cursor: pointer;
    transition: background-color 160ms ease, transform 160ms ease, opacity 160ms ease;
    position: relative;
  }

  .music-playlist-index {
    width: 2rem;
    text-align: center;
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--text-color-70);
    flex-shrink: 0;
  }

  .music-playlist-card:not(.loading):hover {
    background: var(--button-hover-color);
    transform: translateY(-1px);
  }

  .music-playlist-card.active {
    background: var(--button-hover-color);
    border-color: #d5a56a;
  }

  .music-playlist-card.loading {
    opacity: 0.6;
    pointer-events: none;
  }

  .music-playlist-card.loading::after {
    content: '';
    position: absolute;
    right: 0.8rem;
    top: 50%;
    transform: translateY(-50%);
    width: 14px;
    height: 14px;
    border: 2px solid var(--text-color-70);
    border-top-color: #d5a56a;
    border-radius: 50%;
    animation: music-spin 0.6s linear infinite;
  }

  @keyframes music-spin {
    to {
      transform: translateY(-50%) rotate(360deg);
    }
  }

  .music-playlist-name {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text-color);
    line-height: 1.35;
  }

  .music-playlist-meta {
    margin-top: 0.3rem;
    color: var(--text-color-70);
    font-size: 0.82rem;
  }

  .music-control {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid var(--button-border-color);
    background: var(--bg-color);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-color);
    box-shadow: 0 0 0 rgba(0, 0, 0, 0);
  }

  .music-control:hover {
    background: var(--button-hover-color);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  }

  .music-control.primary {
    background: #d5a56a;
    color: #fff;
    border-color: #d5a56a;
  }

  .music-control.primary:hover {
    background: #c9925f;
  }

  .music-control-play {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .music-control-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.1rem;
    height: 1.1rem;
    line-height: 1;
  }

  .music-control.playing {
    background: color-mix(in oklab, #d5a56a 86%, #fff);
    border-color: color-mix(in oklab, #d5a56a 80%, #fff);
    color: #fff;
  }

  .music-control.playing:hover {
    background: #c9925f;
  }

  .music-empty {
    color: var(--text-color-70);
    padding: 1rem;
    text-align: center;
  }

  /* Playlist Modal Styles */
  .music-playlist-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .music-playlist-modal.hidden {
    display: none;
  }

  .music-playlist-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .music-playlist-modal-content {
    position: relative;
    width: min(480px, calc(100vw - 2rem));
    max-height: 70vh;
    background: var(--bg-color);
    border: 1px solid var(--button-border-color);
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  }

  .music-playlist-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.2rem;
    border-bottom: 1px solid var(--button-border-color);
    background: color-mix(in oklab, var(--bg-color) 95%, transparent);
  }

  .music-playlist-modal-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-color);
    margin: 0;
  }

  .music-playlist-modal-close {
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--text-color-70);
    font-size: 1.5rem;
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 160ms ease;
  }

  .music-playlist-modal-close:hover {
    background: var(--button-hover-color);
  }

  .music-playlist-modal-list {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    overflow-y: auto;
