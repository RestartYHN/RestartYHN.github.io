  function renderPlaylistModalList() {
    if (!playlistModalList) return;
    if (!tracks.length) {
      playlistModalList.innerHTML = `<li class="music-empty">${isEn ? "No tracks" : "暂无歌曲"}</li>`;
      return;
    }

    playlistModalList.innerHTML = tracks
      .map(
        (track, idx) => `
          <li class="music-playlist-modal-item ${idx === currentIndex ? "active" : ""}" data-idx="${idx}">
