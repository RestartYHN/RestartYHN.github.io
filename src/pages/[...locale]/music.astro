</style>

<script define:vars={{ musicConfig, isEn }}>
  const API_BASE = musicConfig.apiBase;
  const NETEASE_API_BASE = musicConfig.neteaseApiBase || "";
  const NETEASE_REAL_IP = musicConfig.neteaseRealIp || "";
  const USE_DIRECT_NETEASE_API = Boolean(musicConfig.preferDirectNeteaseApi && NETEASE_API_BASE);

  const audio = document.getElementById("music-audio");
  const trackListEl = document.getElementById("music-track-list");
  const cover = document.getElementById("music-cover");
  const titleEl = document.getElementById("music-title");
  const artistEl = document.getElementById("music-artist");
  const lyricsEl = document.getElementById("music-lyrics");
  const heroBg = document.getElementById("music-hero-bg");
  const statusEl = document.getElementById("music-status");
  const bottomCover = document.getElementById("music-bottom-cover");
  const bottomTitle = document.getElementById("music-bottom-title");
  const bottomArtist = document.getElementById("music-bottom-artist");
  const progressEl = document.getElementById("music-progress");
  const currentTimeEl = document.getElementById("music-current-time");
  const totalTimeEl = document.getElementById("music-total-time");
  const playlistListEl = document.getElementById("music-playlist-list");
  const playlistSubtitleEl = document.getElementById("music-playlist-subtitle");
  const btnMainPlay = document.getElementById("music-main-play");
  const btnCardPlay = document.getElementById("music-play-toggle");
  const btnPrev = document.getElementById("music-prev");
  const btnNext = document.getElementById("music-next");
  const progressWrap = document.querySelector(".music-progress-wrap");
  const playIcon = btnMainPlay?.querySelector(".music-control-icon-play");
  const pauseIcon = btnMainPlay?.querySelector(".music-control-icon-pause");

  let tracks = [];
  let currentIndex = 0;
  let lyricLines = [];
  let activeLyricIndex = -1;
  let lyricScrollReady = false;
  let lastLyricScrollAtMs = 0;
  let loadVersion = 0;
  let currentPlaylistId = "";
  let userToken = localStorage.getItem("music-user-token") || null;
  let userData = userToken ? JSON.parse(localStorage.getItem("music-user-data") || "null") : null;

  // Global music player sync key
  const GLOBAL_MUSIC_KEY = '__globalMusicBootstrapV1';

  // Sync tracks to global player whenever tracks change
  function syncToGlobalPlayer() {
    const globalController = window[GLOBAL_MUSIC_KEY];
    if (globalController && typeof globalController.syncState === 'function') {
      globalController.syncState({
        tracks: tracks,
        currentIndex: currentIndex,
      });
    }
  }

  // Bootstrap global player with current tracks
  function bootstrapGlobalPlayer() {
    const globalController = window[GLOBAL_MUSIC_KEY];
    if (globalController && typeof globalController.bootstrap === 'function') {
      globalController.bootstrap({
        tracks: tracks,
        currentIndex: currentIndex,
      });
    }
  }

  // Restore state from global player (for page re-entry)
  function restoreFromGlobalPlayer() {
    const globalController = window[GLOBAL_MUSIC_KEY];
    if (globalController && typeof globalController.getState === 'function') {
      const state = globalController.getState();
      if (state && Array.isArray(state.tracks) && state.tracks.length && state.loaded) {
        tracks = state.tracks;
        currentIndex = Number.isFinite(state.currentIndex) ? state.currentIndex : 0;
        return true;
      }
    }
    return false;
  }

  // Play mode: 'sequential' | 'loop' | 'shuffle'
  const PLAY_MODE_KEY = "music-play-mode";
  let playMode = localStorage.getItem(PLAY_MODE_KEY) || "sequential";

  // Playlist modal elements
  const playlistModal = document.getElementById("music-playlist-modal");
  const playlistModalBackdrop = document.getElementById("music-playlist-modal-backdrop");
  const playlistModalClose = document.getElementById("music-playlist-modal-close");
  const playlistModalList = document.getElementById("music-playlist-modal-list");
  const playlistCountEl = document.getElementById("music-playlist-count");
  const btnModeSequential = document.getElementById("music-mode-sequential");
  const btnModeLoop = document.getElementById("music-mode-loop");
  const btnModeShuffle = document.getElementById("music-mode-shuffle");
  const btnPlaylistToggle = document.getElementById("music-playlist-toggle");

  // Shuffle history for navigation
  let shuffleHistory = [];
  let shuffleIndex = -1;

  function showStatus(text, level = "info") {
    if (!statusEl) return;
    statusEl.textContent = text;
    statusEl.classList.remove("hidden");
    if (level === "error") {
      statusEl.style.borderColor = "color-mix(in oklab, #d14b4b 45%, var(--button-border-color))";
      statusEl.style.background = "color-mix(in oklab, #d14b4b 14%, transparent)";
    } else {
      statusEl.style.borderColor = "color-mix(in oklab, #d5a56a 40%, var(--button-border-color))";
      statusEl.style.background = "color-mix(in oklab, #d5a56a 14%, transparent)";
    }
  }

  function hideStatus() {
    if (!statusEl) return;
    statusEl.classList.add("hidden");
  }

  // Play mode management
  function updatePlayModeUI() {
    [btnModeSequential, btnModeLoop, btnModeShuffle].forEach((btn) => btn?.classList.remove("active"));
    if (playMode === "sequential" && btnModeSequential) btnModeSequential.classList.add("active");
    if (playMode === "loop" && btnModeLoop) btnModeLoop.classList.add("active");
    if (playMode === "shuffle" && btnModeShuffle) btnModeShuffle.classList.add("active");
  }

  function setPlayMode(mode) {
    playMode = mode;
    localStorage.setItem(PLAY_MODE_KEY, mode);
    updatePlayModeUI();
    // Reset shuffle history when mode changes
    if (mode === "shuffle") {
      shuffleHistory = [currentIndex];
      shuffleIndex = 0;
    }
  }

  function getNextIndex() {
    if (!tracks.length) return 0;
    if (playMode === "loop") {
      return currentIndex; // Same track
    }
    if (playMode === "shuffle") {
      // If we're not at the end of shuffle history, move forward
      if (shuffleIndex < shuffleHistory.length - 1) {
        shuffleIndex++;
        return shuffleHistory[shuffleIndex];
      }
      // Generate new random index
      let nextIdx;
      do {
        nextIdx = Math.floor(Math.random() * tracks.length);
      } while (tracks.length > 1 && nextIdx === currentIndex);
      shuffleHistory.push(nextIdx);
      shuffleIndex = shuffleHistory.length - 1;
      return nextIdx;
    }
    // Sequential mode
    return (currentIndex + 1) % tracks.length;
  }

  function getPrevIndex() {
    if (!tracks.length) return 0;
    if (playMode === "loop") {
      return currentIndex; // Same track
    }
    if (playMode === "shuffle") {
      // If we have history to go back to
      if (shuffleIndex > 0) {
        shuffleIndex--;
        return shuffleHistory[shuffleIndex];
      }
      // Generate new random index for "previous"
      let prevIdx;
      do {
        prevIdx = Math.floor(Math.random() * tracks.length);
      } while (tracks.length > 1 && prevIdx === currentIndex);
      shuffleHistory.unshift(prevIdx);
      return prevIdx;
    }
    // Sequential mode
    return (currentIndex - 1 + tracks.length) % tracks.length;
  }

  // Playlist modal functions
  function openPlaylistModal() {
    if (!playlistModal) return;
    playlistModal.classList.remove("hidden");
    renderPlaylistModalList();
    document.body.style.overflow = "hidden";
  }

  function closePlaylistModal() {
    if (!playlistModal) return;
    playlistModal.classList.add("hidden");
    document.body.style.overflow = "";
  }

  function renderPlaylistModalList() {
    if (!playlistModalList) return;
    if (!tracks.length) {
      playlistModalList.innerHTML = `<li class="music-empty">${isEn ? "No tracks" : "暂无歌曲"}</li>`;
      return;
    }

    playlistModalList.innerHTML = tracks
      .map(
        (track, idx) => `
          <li class="music-playlist-modal-item ${idx === currentIndex ? "active" : ""}" data-idx="${idx}">
            <div class="music-playlist-modal-item-index">${idx === currentIndex ? "▶" : String(idx + 1).padStart(2, "0")}</div>
            <div class="music-playlist-modal-item-info">
              <div class="music-playlist-modal-item-title">${track.title || "Unknown"}</div>
              <div class="music-playlist-modal-item-artist">${track.artist || "Unknown Artist"}</div>
            </div>
          </li>
        `
      )
      .join("");

    playlistModalList.querySelectorAll(".music-playlist-modal-item").forEach((el) => {
      el.addEventListener("click", async () => {
        const idx = Number(el.getAttribute("data-idx") || "0");
        currentIndex = idx;
        const current = await prepareTrackForPlayback(currentIndex);
        if (!current) return;
        updateNowPlaying(current);
        renderTrackList();
        renderPlaylistModalList();
        updatePlayerPosition();
        if (current?.audio && audio?.src) {
          hideStatus();
          audio.play().catch(() => {});
        }
      });
    });

    // Scroll to current track
    const activeItem = playlistModalList.querySelector(".music-playlist-modal-item.active");
    if (activeItem) {
      activeItem.scrollIntoView({ behavior: "auto", block: "nearest" });
    }
  }

  function updatePlaylistCount() {
    if (playlistCountEl) {
      playlistCountEl.textContent = tracks.length;
    }
  }

  // Event listeners for play mode buttons
  btnModeSequential?.addEventListener("click", () => setPlayMode("sequential"));
  btnModeLoop?.addEventListener("click", () => setPlayMode("loop"));
  btnModeShuffle?.addEventListener("click", () => setPlayMode("shuffle"));
  btnPlaylistToggle?.addEventListener("click", openPlaylistModal);
  playlistModalBackdrop?.addEventListener("click", closePlaylistModal);
  playlistModalClose?.addEventListener("click", closePlaylistModal);

  // Initialize play mode UI
  updatePlayModeUI();

  function updatePlayButtonState() {
    if (!btnMainPlay || !audio) return;
    const isPlaying = !audio.paused;
    btnMainPlay.classList.toggle("playing", isPlaying);
    btnMainPlay.setAttribute("aria-pressed", String(isPlaying));
    btnMainPlay.setAttribute("aria-label", isPlaying ? (isEn ? "Pause" : "暂停") : (isEn ? "Play" : "播放"));
    playIcon?.classList.toggle("hidden", isPlaying);
    pauseIcon?.classList.toggle("hidden", !isPlaying);
  }

  function updateProgressVisual() {
    if (!progressEl) return;
    const ratio = Number(progressEl.value || 0) / 1000;
    progressEl.style.setProperty("--progress-percent", `${Math.max(0, Math.min(100, ratio * 100))}%`);
  }

  async function getJson(url) {
    const res = await fetch(url, { referrerPolicy: "no-referrer" });
    if (!res.ok) {
      throw new Error(`HTTP ${res.status}`);
    }
    return res.json();
  }

  function withTimestamp(params = {}) {
    return {
      ...params,
      timestamp: Date.now(),
    };
  }

  function buildUrl(base, path, params = {}) {
    const cleanBase = String(base || "").replace(/\/+$/, "");
    const cleanPath = String(path || "").replace(/^\/+/, "");
    const url = new URL(`${cleanBase}/${cleanPath}`);
    Object.entries(params).forEach(([k, v]) => {
      if (v === undefined || v === null || v === "") return;
      url.searchParams.set(k, String(v));
    });
    return url.toString();
  }

  async function getNeteaseJson(path, params = {}) {
    if (!NETEASE_API_BASE) {
      throw new Error("PUBLIC_NETEASE_API is not configured");
    }
    return getJson(buildUrl(NETEASE_API_BASE, path, withTimestamp(params)));
  }

  function normalizeAudioUrl(rawUrl) {
    if (!rawUrl || typeof rawUrl !== "string") return "";
    const trimmed = rawUrl.trim();
    if (!trimmed) return "";

    // GitHub Pages is HTTPS. Convert known NetEase HTTP media links to HTTPS to avoid mixed-content blocking.
    if (window.location.protocol === "https:" && /^http:\/\/m\d+\.music\.126\.net\//i.test(trimmed)) {
      return trimmed.replace(/^http:\/\//i, "https://");
    }

    return trimmed;
  }

  function withPreferredRealIP(params = {}) {
    if (!NETEASE_REAL_IP) return params;
    return {
      ...params,
      realIP: NETEASE_REAL_IP,
    };
  }

  async function getBestDirectAudioUrl(id) {
    const levels = ["standard", "higher", "exhigh", "lossless"];
    const realIpCandidates = Array.from(
      new Set([
        "",
        NETEASE_REAL_IP,
        "211.161.244.70",
      ].filter(Boolean)),
    );

    for (const level of levels) {
      for (const realIP of realIpCandidates) {
        try {
          const params = realIP ? { id, level, realIP } : { id, level };
          const urlResp = await getNeteaseJson("/song/url/v1", params);
          const urlItem = Array.isArray(urlResp?.data) ? urlResp.data[0] : null;
          const normalized = normalizeAudioUrl(urlItem?.url || "");
          if (normalized) {
            return normalized;
          }
        } catch (e) {
          console.debug(`[music] /song/url/v1 failed for ${id} at ${level} realIP=${realIP || "none"}`, e);
        }
      }
    }

    // Fallback endpoint for compatibility with some tracks.
    for (const realIP of realIpCandidates) {
      try {
        const params = realIP ? { id, br: 320000, realIP } : { id, br: 320000 };
        const legacyResp = await getNeteaseJson("/song/url", params);
        const legacyItem = Array.isArray(legacyResp?.data) ? legacyResp.data[0] : null;
        const normalized = normalizeAudioUrl(legacyItem?.url || "");
        if (normalized) {
          return normalized;
        }
      } catch (e) {
        console.debug(`[music] /song/url fallback failed for ${id} realIP=${realIP || "none"}`, e);
      }
    }

    return "";
  }

  function formatClock(sec) {
    const t = Number.isFinite(sec) ? Math.max(0, Math.floor(sec)) : 0;
    const m = Math.floor(t / 60);
    const s = t % 60;
    return `${m}:${String(s).padStart(2, "0")}`;
  }

  function formatPlayedTime(ms) {
    if (!ms) return "";
    const diff = Date.now() - Number(ms);
    if (diff <= 0) return isEn ? "just now" : "刚刚";
    const min = Math.floor(diff / 60000);
    if (min < 60) return isEn ? `${min}m ago` : `${min} 分钟前`;
    const hour = Math.floor(min / 60);
    if (hour < 24) return isEn ? `${hour}h ago` : `${hour} 小时前`;
    const day = Math.floor(hour / 24);
    return isEn ? `${day}d ago` : `${day} 天前`;
  }

  function parseLrc(text) {
    if (!text) return { lines: [], offsetSec: 0 };

    const offsetMatch = text.match(/^\[offset:([+-]?\d+)\]$/m);
    const offsetSec = offsetMatch ? Number(offsetMatch[1]) / 1000 : 0;
    const lines = [];

    text.split("\n").forEach((rawLine) => {
      const line = String(rawLine || "").trim();
      if (!line) return;

      const tags = [...line.matchAll(/\[(\d+):(\d+(?:\.\d+)?)\]/g)];
      if (!tags.length) return;

      const plainText = line.replace(/\[(\d+):(\d+(?:\.\d+)?)\]/g, "").trim();
      tags.forEach((tag) => {
        const t = Number(tag[1]) * 60 + Number(tag[2]) + offsetSec;
        lines.push({
          time: Math.max(0, t),
          text: plainText,
        });
      });
    });

    lines.sort((a, b) => a.time - b.time);
    return { lines, offsetSec };
  }

  function buildLyricLines(lyricText, translationText) {
    const parsedBase = parseLrc(lyricText);
    const base = parsedBase.lines;
    if (!base.length) return [];

    const trans = parseLrc(translationText).lines;
    let transIdx = 0;
    const TOLERANCE_SEC = 0.45;

    return base.map((line) => {
      let matched = "";

      while (transIdx + 1 < trans.length && trans[transIdx + 1].time <= line.time) {
        transIdx += 1;
      }

      const candidates = [trans[transIdx - 1], trans[transIdx], trans[transIdx + 1]].filter(Boolean);
      let best = null;
      let bestDelta = Number.POSITIVE_INFINITY;

      candidates.forEach((item) => {
        const delta = Math.abs(item.time - line.time);
        if (delta < bestDelta) {
          best = item;
          bestDelta = delta;
        }
      });

      if (best && bestDelta <= TOLERANCE_SEC && best.text && best.text !== "//") {
        matched = best.text;
      }

      return {
        time: line.time,
        text: line.text,
        translation: matched,
      };
    });
  }

  function renderLyrics(lines) {
    if (!lyricsEl) return;
    if (!lines.length) {
      lyricsEl.innerHTML = `<li>${isEn ? "No lyric available" : "暂无歌词"}</li>`;
      return;
    }
    lyricsEl.innerHTML = lines
      .map(
        (line, i) => `
          <li data-i="${i}">
            <div class="music-lyrics-main">${line.text || "..."}</div>
            ${line.translation ? `<div class="music-lyrics-trans">${line.translation}</div>` : ""}
          </li>
        `,
      )
      .join("");
  }

  function getActiveLyricIndex(currentTime) {
    if (!lyricLines.length) return -1;

    const t = currentTime + 0.03;
    if (t < lyricLines[0].time) return -1;

    let active = -1;
    for (let i = 0; i < lyricLines.length; i += 1) {
      if (t >= lyricLines[i].time) active = i;
      else break;
    }

    // If many lines share exactly the same timestamp, keep the first one
    // to avoid jumping several lines on initial mobile sync.
    while (active > 0 && lyricLines[active - 1].time === lyricLines[active].time) {
      active -= 1;
    }

    return active;
  }

  function syncLyrics() {
    if (!audio || !lyricsEl || !lyricLines.length) return;
    const active = getActiveLyricIndex(audio.currentTime);
    if (active === activeLyricIndex) return;

    activeLyricIndex = active;
    lyricsEl.querySelectorAll("li").forEach((li) => li.classList.remove("active"));
    if (active < 0) return;

    const activeLine = lyricsEl.querySelector(`li[data-i='${active}']`);
    if (activeLine) {
      activeLine.classList.add("active");

      if (!lyricScrollReady && audio.currentTime < 2.2) {
        return;
      }
      lyricScrollReady = true;

      const isMobile = window.matchMedia("(max-width: 768px)").matches;
      const ACTIVE_LINE_VIEWPORT_RATIO = isMobile ? 0.72 : 0.62;
      const targetTop = activeLine.offsetTop - lyricsEl.clientHeight * ACTIVE_LINE_VIEWPORT_RATIO + activeLine.clientHeight / 2;

      if (isMobile) {
        const nowMs = performance.now();
        const MIN_SCROLL_INTERVAL_MS = 220;
        if (nowMs - lastLyricScrollAtMs < MIN_SCROLL_INTERVAL_MS) {
          return;
        }
        lastLyricScrollAtMs = nowMs;

        const MAX_SCROLL_STEP_PX = 34;
        const currentTop = lyricsEl.scrollTop;
        const delta = targetTop - currentTop;
        const clampedTop = Math.abs(delta) > MAX_SCROLL_STEP_PX
          ? currentTop + Math.sign(delta) * MAX_SCROLL_STEP_PX
          : targetTop;

        lyricsEl.scrollTo({ top: Math.max(0, clampedTop), behavior: "auto" });
      } else {
        lyricsEl.scrollTo({ top: Math.max(0, targetTop), behavior: "smooth" });
      }
    }
  }

  function updateNowPlaying(track, options = {}) {
    const preserveActivePlayback = Boolean(options?.preserveActivePlayback);
    if (titleEl) titleEl.textContent = track.title || "-";
    if (artistEl) artistEl.textContent = track.artist || "-";
    if (bottomTitle) bottomTitle.textContent = track.title || "-";
    if (bottomArtist) bottomArtist.textContent = track.artist || "-";

    if (cover) cover.style.backgroundImage = track.cover ? `url(${track.cover})` : "";
    if (bottomCover) bottomCover.style.backgroundImage = track.cover ? `url(${track.cover})` : "";

    if (heroBg && track.cover) {
      heroBg.style.backgroundImage = `linear-gradient(135deg, rgba(0,0,0,.22), rgba(0,0,0,.1)), url(${track.cover})`;
      heroBg.style.backgroundSize = "cover";
      heroBg.style.backgroundPosition = "center";
    }

    if (audio) {
      if (track.audio) {
        const currentSrc = String(audio.currentSrc || audio.src || "");
        const nextSrc = String(track.audio || "");
        const shouldPreserve = preserveActivePlayback && currentSrc && currentSrc !== nextSrc;
        if (!shouldPreserve) {
          audio.src = nextSrc;
          audio.load();
        }
      } else {
        if (!preserveActivePlayback) {
          audio.pause();
          audio.removeAttribute("src");
          audio.load();
        }
      }
    }

    lyricLines = buildLyricLines(track.lyric, track.tlyric);
    activeLyricIndex = -1;
    lyricScrollReady = false;
    lastLyricScrollAtMs = 0;
    renderLyrics(lyricLines);
    if (lyricsEl) {
      lyricsEl.scrollTo({ top: 0, behavior: "auto" });
    }
  }

  function renderTrackList() {
    if (!trackListEl) return;
    if (!tracks.length) {
      trackListEl.innerHTML = `<li class="music-empty">${isEn ? "No tracks" : "暂无歌曲"}</li>`;
      return;
    }

    trackListEl.innerHTML = tracks
      .map(
        (track, idx) => `
          <li class="music-track-card ${idx === currentIndex ? "active" : ""} ${track.unavailable ? "unavailable" : ""}" data-idx="${idx}">
            <div class="music-track-index">${String(idx + 1).padStart(2, "0")}</div>
            <div class="min-w-0 flex-1">
              <p class="music-track-title truncate">${track.title || "Unknown"}</p>
              <p class="music-track-artist truncate">${track.artist || "Unknown Artist"}</p>
            </div>
          </li>
        `,
      )
      .join("");

    trackListEl.querySelectorAll(".music-track-card").forEach((el) => {
      el.addEventListener("click", async () => {
        const idx = Number(el.getAttribute("data-idx") || "0");
        currentIndex = idx;
        const current = await prepareTrackForPlayback(currentIndex);
        if (!current) return;

        updateNowPlaying(current);
        renderTrackList();
        updatePlayerPosition();
        
        if (current?.audio && audio?.src) {
          hideStatus();
          audio.play().catch(() => {});
        } else if (current?.id) {
          showStatus(
            isEn
              ? "No playable URL for this track in direct mode."
              : "直连模式下该歌曲暂无可用播放链接。",
            "error"
          );
        } else {
          showStatus(isEn ? "Cannot load this track." : "无法加载此歌曲。", "error");
        }
      });
    });
  }

  async function prepareTrackForPlayback(index) {
    let current = tracks[index];
    if (!current) return null;

    current = await hydrateTrack(current);
    tracks[index] = current;

    // Direct mode loads playback URL lazily. Ensure prev/next and list click share the same behavior.
    if (USE_DIRECT_NETEASE_API && current?.id && !current?.audio && !current?.unavailable) {
      showStatus(isEn ? "Loading playback URL..." : "正在获取播放链接...");
      try {
        const fullTrack = await loadTrack(current.id);
        current = {
          ...current,
          ...fullTrack,
          unavailable: !fullTrack?.audio,
        };
        tracks[index] = current;
      } catch (e) {
        console.warn("[music] URL retry failed", e);
        current = {
          ...current,
          unavailable: true,
        };
        tracks[index] = current;
      }
    }

    // Sync to global player after track is hydrated
    syncToGlobalPlayer();

    return current;
  }

  function updatePlayerPosition() {
    const posEl = document.getElementById("music-player-position");
    if (posEl && tracks.length > 0) {
      posEl.textContent = `${currentIndex + 1} / ${tracks.length}`;
    }
  }

  // Track cache with 10 minute TTL
  const trackCacheKey = "music-track-cache-v2";
  const trackCacheTTL = 10 * 60 * 1000; // 10 minutes
  
  function getTrackCache(id) {
    try {
      const cached = localStorage.getItem(`${trackCacheKey}:${id}`);
      if (!cached) return null;
      const { data, timestamp } = JSON.parse(cached);
      if (Date.now() - timestamp > trackCacheTTL) {
        localStorage.removeItem(`${trackCacheKey}:${id}`);
        return null;
      }

      // Drop placeholder cache entries so metadata fixes can propagate immediately.
      const title = String(data?.title || "");
      const artist = String(data?.artist || "");
      const isPlaceholderTitle = title === `Song ${id}`;
      const isPlaceholderArtist = artist === "Unknown Artist";
      if (isPlaceholderTitle || isPlaceholderArtist) {
        localStorage.removeItem(`${trackCacheKey}:${id}`);
        return null;
      }

      return data;
    } catch {
      return null;
    }
  }

  function setTrackCache(id, data) {
    try {
      localStorage.setItem(`${trackCacheKey}:${id}`, JSON.stringify({
        data,
        timestamp: Date.now(),
      }));
    } catch (e) {
      console.warn("[music] cache write failed", e);
    }
  }

  // Concurrent request queue (max 3 simultaneous)
  let trackLoadQueue = [];
  let trackLoadInProgress = 0;
  const MAX_CONCURRENT = 3;

  function enqueueTrackLoad(id) {
    return new Promise((resolve, reject) => {
      trackLoadQueue.push({ id, resolve, reject });
      processTrackLoadQueue();
    });
  }

  async function processTrackLoadQueue() {
    if (trackLoadInProgress >= MAX_CONCURRENT || trackLoadQueue.length === 0) return;
    trackLoadInProgress += 1;
    const { id, resolve, reject } = trackLoadQueue.shift();
    try {
      const result = await loadTrackInternal(id);
      resolve(result);
    } catch (error) {
      reject(error);
    } finally {
      trackLoadInProgress -= 1;
      processTrackLoadQueue();
    }
  }

  async function loadTrackInternal(id) {
    // Check cache first
    const cached = getTrackCache(id);
    if (cached) {
      console.debug("[music] track cache hit", id);
      return cached;
    }

    if (USE_DIRECT_NETEASE_API) {
      try {
        const [detailResp, lrcResp] = await Promise.all([
          getNeteaseJson("/song/detail", withPreferredRealIP({ ids: id })),
          getNeteaseJson("/lyric", withPreferredRealIP({ id })),
        ]);

        const song = Array.isArray(detailResp?.songs) ? detailResp.songs[0] : null;
        const audioUrl = await getBestDirectAudioUrl(id);

        const result = {
          id: String(id),
          title: song?.name || `Song ${id}`,
          artist: Array.isArray(song?.ar)
            ? song.ar.map((item) => item?.name || "Unknown").join(", ")
            : "Unknown Artist",
          cover: song?.al?.picUrl || "",
          audio: audioUrl,
          lyric: typeof lrcResp?.lrc?.lyric === "string" ? lrcResp.lrc.lyric : "",
          tlyric: typeof lrcResp?.tlyric?.lyric === "string" ? lrcResp.tlyric.lyric : "",
        };
        setTrackCache(id, result);
        return result;
      } catch (error) {
        console.warn("[music] load direct track failed", id, error);
      }
    }

    try {
      const result = await getJson(`${API_BASE}/api/music/track?id=${encodeURIComponent(id)}`);
      if (result?.code === 200 && result.data) {
        setTrackCache(id, result.data);
        return result.data;
      }
    } catch (error) {
      console.warn("[music] load track failed", id, error);
    }

    const seed = musicConfig.seedTracks.find((x) => String(x.id) === String(id));
    if (seed) return seed;

    return {
      id,
      title: `Song ${id}`,
      artist: "Unknown Artist",
      cover: "",
      audio: "",
      lyric: "",
      tlyric: "",
    };
  }

  async function loadTrack(id) {
    return enqueueTrackLoad(id);
  }

  function mapPlaylistSongToTrack(item) {
    return {
      id: item?.id !== undefined ? String(item.id) : "",
      title: item?.name || "Unknown",
      artist: Array.isArray(item?.ar)
        ? item.ar.map((artist) => artist?.name || "Unknown").join(", ")
        : "Unknown Artist",
      cover: item?.al?.picUrl || "",
      audio: "",
      lyric: "",
      tlyric: "",
      unavailable: false,
    };
  }

  function isPlaceholderTrack(track) {
    if (!track?.id) return false;
    const title = String(track.title || "");
    const artist = String(track.artist || "");
    return title === `Song ${track.id}` || title === "Unknown" || artist === "Unknown Artist";
  }

  async function hydrateTrack(track) {
    if (!track?.id || !isPlaceholderTrack(track)) return track;
    try {
      const fresh = await loadTrack(track.id);
      if (fresh && fresh.id) {
        return {
          ...track,
          ...fresh,
          unavailable: !fresh.audio,
        };
      }
    } catch (error) {
      console.warn("[music] hydrate track failed", track?.id, error);
    }
    return track;
  }

  function dedupeIds(ids) {
    return Array.from(new Set((ids || []).map((id) => String(id)).filter(Boolean)));
  }

  function renderPlaylistList() {
    if (!playlistListEl) return;
    const playlists = Array.isArray(userData?.playlists) ? userData.playlists : [];
    if (!playlists.length) {
      playlistListEl.innerHTML = `<li class="music-empty">${isEn ? "No playlist data yet" : "暂无歌单数据"}</li>`;
      return;
    }

    playlistListEl.innerHTML = playlists
      .map(
        (pl, idx) => `
          <li class="music-playlist-card ${String(pl.id) === String(currentPlaylistId) ? "active" : ""}" data-playlist-id="${pl.id}">
            <div class="music-playlist-index">${String(idx + 1).padStart(2, "0")}</div>
            <div class="min-w-0 flex-1">
              <p class="music-playlist-name truncate">${pl.name || (isEn ? "Playlist" : "歌单")}</p>
              <p class="music-playlist-meta">${pl.songCount || 0} ${isEn ? "songs" : "首歌"}</p>
            </div>
          </li>
        `,
      )
      .join("");

    playlistListEl.querySelectorAll(".music-playlist-card").forEach((el) => {
      el.addEventListener("click", async () => {
        const playlistId = String(el.getAttribute("data-playlist-id") || "");
        if (!playlistId) return;
        currentPlaylistId = playlistId;
        renderPlaylistList();
        await loadPlaylistSongs(playlistId);
      });
    });
  }

  async function loadPlaylistSongs(playlistId, options = {}) {
    const preserveActivePlayback = Boolean(options?.preserveActivePlayback);
    try {
      const loadingText = preserveActivePlayback
        ? (isEn ? "Loading playlist songs (keeping current playback)..." : "正在加载歌单歌曲（保持当前播放不中断）...")
        : (isEn ? "Loading playlist songs..." : "正在加载歌单歌曲...");
      showStatus(loadingText);
      if (playlistSubtitleEl) {
        playlistSubtitleEl.textContent = preserveActivePlayback
          ? (isEn ? "Syncing page view (playback preserved)..." : "正在同步页面展示（保持当前播放）...")
          : (isEn ? "Loading songs..." : "正在加载歌曲...");
      }

      if (USE_DIRECT_NETEASE_API) {
        let songsRaw = [];
        try {
          // Prefer playlist/detail: it keeps full playlist metadata (e.g. 12 tracks here),
          // while playlist/track/all may drop tracks that cannot provide playable URLs.
          const detail = await getNeteaseJson("/playlist/detail", withPreferredRealIP({ id: playlistId }));
          songsRaw = Array.isArray(detail?.playlist?.tracks) ? detail.playlist.tracks : [];
        } catch (error) {
          console.warn("[music] load /playlist/detail failed", error);
        }

        if (!songsRaw.length) {
          const data = await getNeteaseJson(
            "/playlist/track/all",
            withPreferredRealIP({
              id: playlistId,
              limit: 500,
              offset: 0,
            }),
          );
          songsRaw = Array.isArray(data?.songs) ? data.songs : [];
        }

        const limit = Number(musicConfig.playlistSongLimit || 120);
        const version = ++loadVersion;

        tracks = songsRaw
          .slice(0, limit)
          .map((item) => mapPlaylistSongToTrack(item))
          .filter((item) => item.id);

        if (!tracks.length) {
          renderTrackList();
          showStatus(isEn ? "Playlist is empty." : "该歌单为空。", "error");
          return;
        }

        currentIndex = 0;
        updateNowPlaying(tracks[currentIndex], { preserveActivePlayback });
        updatePlayerPosition();
        renderTrackList();
        hideStatus();
        if (playlistSubtitleEl) {
          playlistSubtitleEl.textContent = isEn ? `Loaded ${tracks.length} songs` : `已加载 ${tracks.length} 首歌`;
        }
        // Bootstrap global player with loaded tracks
        bootstrapGlobalPlayer();

        // Warm only the first track in background to improve first-play experience.
        loadTrack(tracks[0].id)
          .then((firstTrack) => {
            if (version !== loadVersion || !firstTrack) return;
            tracks[0] = { ...tracks[0], ...firstTrack, unavailable: !firstTrack.audio };
            if (currentIndex === 0) {
              updateNowPlaying(tracks[0], { preserveActivePlayback });
            }
            renderTrackList();
          })
          .catch((error) => {
            console.warn("[music] warm first track failed", error);
          });

        return;
      }

      let result = null;
      if (userToken) {
        result = await getJson(
          `${API_BASE}/api/music/playlist-songs?token=${encodeURIComponent(userToken)}&playlistId=${encodeURIComponent(playlistId)}`,
        );
      } else if (musicConfig.preferCookieProfile) {
        result = await getJson(
          `${API_BASE}/api/music/cookie-playlist-songs?playlistId=${encodeURIComponent(playlistId)}`,
        );
      } else {
        result = await getJson(
          `${API_BASE}/api/music/public-playlist-songs?playlistId=${encodeURIComponent(playlistId)}`,
        );
      }

      if (result?.code !== 200 || !Array.isArray(result?.data?.songs)) {
        showStatus(isEn ? "Failed to load playlist songs." : "歌单歌曲加载失败。", "error");
        return;
      }

      const ids = dedupeIds(result.data.songs).slice(0, Number(musicConfig.playlistSongLimit || 120));
      const version = ++loadVersion;
      tracks = [];
      const resetLoadingFeedback = () => {
        hideStatus();
        if (playlistSubtitleEl) {
          playlistSubtitleEl.textContent = isEn ? "Click to load" : "点击加载";
        }
      };

      // Batch rendering: first show 20 songs, then continue loading rest
      const BATCH_SIZE = 20;
      const batchesCount = Math.ceil(ids.length / BATCH_SIZE);

      for (let batchIdx = 0; batchIdx < batchesCount; batchIdx += 1) {
        if (version !== loadVersion) {
          resetLoadingFeedback();
          return;
        }

        const batchStart = batchIdx * BATCH_SIZE;
        const batchEnd = Math.min(batchStart + BATCH_SIZE, ids.length);
        const batchIds = ids.slice(batchStart, batchEnd);

        // Load all tracks in this batch
        for (const id of batchIds) {
          if (version !== loadVersion) {
            resetLoadingFeedback();
            return;
          }
          const track = await loadTrack(id);
          tracks.push(track);
        }

        // Render tracks after each batch (show progressive loading)
        if (tracks.length && !currentIndex) {
          currentIndex = 0;
          updateNowPlaying(tracks[currentIndex], { preserveActivePlayback });
        }
        if (tracks.length) {
          updatePlayerPosition();
          renderTrackList();
        }

        // After first batch, hide loading message
        if (batchIdx === 0 && batchesCount > 1) {
          hideStatus();
          if (playlistSubtitleEl) {
            playlistSubtitleEl.textContent = isEn
              ? `Loading... ${tracks.length} / ${ids.length}`
              : `加载中... ${tracks.length} / ${ids.length}`;
          }
        }
      }

      if (version !== loadVersion) {
        resetLoadingFeedback();
        return;
      }
      if (!tracks.length) {
        renderTrackList();
        showStatus(isEn ? "Playlist is empty." : "该歌单为空。", "error");
        return;
      }

      hideStatus();
      if (playlistSubtitleEl) {
        playlistSubtitleEl.textContent = isEn ? `Loaded ${tracks.length} songs` : `已加载 ${tracks.length} 首歌`;
      }
      // Bootstrap global player with loaded tracks
      bootstrapGlobalPlayer();
    } catch (error) {
      console.warn("[music] load playlist songs failed", error);
      showStatus(isEn ? "Failed to load playlist songs." : "歌单歌曲加载失败。", "error");
    }
  }

  async function restoreUserDataByToken() {
    if (USE_DIRECT_NETEASE_API) return false;
    if (!userToken) return false;
    try {
      const result = await getJson(`${API_BASE}/api/music/user?token=${encodeURIComponent(userToken)}`);
      if (result?.code === 200 && result.data) {
        userData = result.data;
        localStorage.setItem("music-user-data", JSON.stringify(result.data));
        return true;
      }
    } catch {
      // Token may have expired after backend restart.
    }
    userToken = null;
    localStorage.removeItem("music-user-token");
    localStorage.removeItem("music-user-data");
    return false;
  }

  async function loadPublicProfileIfConfigured() {
    if (!musicConfig.preferPublicProfile || !musicConfig.neteaseUserId) return false;

    if (USE_DIRECT_NETEASE_API) {
      try {
        const [detailResp, playlistResp] = await Promise.all([
          getNeteaseJson("/user/detail", { uid: musicConfig.neteaseUserId }),
          getNeteaseJson("/user/playlist", { uid: musicConfig.neteaseUserId, limit: 50 }),
        ]);

        const profile = detailResp?.profile || {};
        const playlistsRaw = Array.isArray(playlistResp?.playlist) ? playlistResp.playlist : [];
        userData = {
          userId: String(profile.userId || musicConfig.neteaseUserId),
          username: profile.nickname || "NetEase User",
          avatarUrl: profile.avatarUrl || "",
          playlists: playlistsRaw.map((pl) => ({
            id: pl?.id ? String(pl.id) : "",
            name: pl?.name || (isEn ? "Playlist" : "歌单"),
            songCount: Number(pl?.trackCount || 0),
          })),
          recentSongs: [],
          recentHistory: [],
          favoriteSongs: [],
          source: "public-profile-direct",
        };
        return true;
      } catch (error) {
        console.warn("[music] load direct public profile failed", error);
      }
      return false;
    }

    try {
      const result = await getJson(
        `${API_BASE}/api/music/public-user?uid=${encodeURIComponent(musicConfig.neteaseUserId)}`,
      );
      if (result?.code === 200 && result.data) {
        userData = result.data;
        return true;
      }
    } catch (error) {
      console.warn("[music] load public profile failed", error);
    }
    return false;
  }

  async function warmupNeteaseApi() {
    if (!USE_DIRECT_NETEASE_API || !NETEASE_API_BASE) return;
    try {
      await getNeteaseJson("/inner/version", {});
      console.debug("[music] API warmup succeeded");
    } catch (e) {
      console.debug("[music] API warmup (non-critical)", e);
    }
  }

  async function loadCookieProfileIfConfigured() {
    if (USE_DIRECT_NETEASE_API) return false;
    if (!musicConfig.preferCookieProfile) return false;
    try {
      const result = await getJson(`${API_BASE}/api/music/cookie-user`);
      if (result?.code === 200 && result.data) {
        userData = result.data;
        return true;
      }
    } catch (error) {
      console.warn("[music] load cookie profile failed", error);
    }
    return false;
  }

  function togglePlay() {
    if (!audio) return;
    if (audio.paused) {
      audio.play().catch(() => {});
    } else {
      audio.pause();
    }
  }

  btnMainPlay?.addEventListener("click", togglePlay);
  btnCardPlay?.addEventListener("click", togglePlay);
  btnPrev?.addEventListener("click", async () => {
    if (!tracks.length) return;
    currentIndex = getPrevIndex();
    const current = await prepareTrackForPlayback(currentIndex);
    if (!current) return;
    updateNowPlaying(current);
    renderTrackList();
    updatePlayerPosition();
    updatePlaylistCount();
    syncToGlobalPlayer();
    if (current?.audio && audio?.src) {
      hideStatus();
      audio?.play().catch(() => {});
    } else {
      showStatus(isEn ? "No playable URL for this track in direct mode." : "直连模式下该歌曲暂无可用播放链接。", "error");
    }
  });
  btnNext?.addEventListener("click", async () => {
    if (!tracks.length) return;
    currentIndex = getNextIndex();
    const current = await prepareTrackForPlayback(currentIndex);
    if (!current) return;
    updateNowPlaying(current);
    renderTrackList();
    updatePlayerPosition();
    updatePlaylistCount();
    syncToGlobalPlayer();
    if (current?.audio && audio?.src) {
      hideStatus();
      audio?.play().catch(() => {});
    } else {
      showStatus(isEn ? "No playable URL for this track in direct mode." : "直连模式下该歌曲暂无可用播放链接。", "error");
    }
  });

  audio?.addEventListener("timeupdate", syncLyrics);
  audio?.addEventListener("loadedmetadata", () => {
    if (totalTimeEl) totalTimeEl.textContent = formatClock(audio?.duration || 0);
  });
  audio?.addEventListener("timeupdate", () => {
    if (!audio) return;
    if (currentTimeEl) currentTimeEl.textContent = formatClock(audio.currentTime);
    if (progressEl && Number.isFinite(audio.duration) && audio.duration > 0) {
      const ratio = audio.currentTime / audio.duration;
      progressEl.value = String(Math.min(1000, Math.max(0, Math.round(ratio * 1000))));
      updateProgressVisual();
    }
  });
  audio?.addEventListener("ended", async () => {
    if (!tracks.length) return;
    // For loop mode, just replay the current track
    if (playMode === "loop") {
      audio.currentTime = 0;
      audio.play().catch(() => {});
      return;
    }
    // For sequential and shuffle modes, go to next track
    currentIndex = getNextIndex();
    const current = await prepareTrackForPlayback(currentIndex);
    if (!current) return;
    updateNowPlaying(current);
    renderTrackList();
    updatePlayerPosition();
    updatePlaylistCount();
    syncToGlobalPlayer();
    if (current?.audio && audio?.src) {
      hideStatus();
      audio.play().catch(() => {});
    }
  });

  progressEl?.addEventListener("input", () => {
    if (!audio || !Number.isFinite(audio.duration) || audio.duration <= 0) return;
    const ratio = Number(progressEl.value || 0) / 1000;
    audio.currentTime = ratio * audio.duration;
  });

  (async () => {
    // Warmup API in parallel (don't await)
    warmupNeteaseApi();

    const shouldPreservePlaybackOnInit = Boolean(audio && !audio.paused && (audio.currentSrc || audio.src));

    // Try to restore from global player first (for page re-entry)
    const hasGlobalState = restoreFromGlobalPlayer();
    if (hasGlobalState) {
      renderPlaylistList();
      renderTrackList();
      if (tracks[currentIndex]) {
        updateNowPlaying(tracks[currentIndex]);
      }
      updatePlayerPosition();
      updatePlaylistCount();
      showStatus(isEn ? "Restored playlist from global player." : "已从全局播放器恢复歌单。");
      return;
    }

    const hasTokenData = await restoreUserDataByToken();
    if (!hasTokenData) {
      const hasCookieData = await loadCookieProfileIfConfigured();
      if (hasCookieData) {
        showStatus(
          isEn
            ? "Loaded private profile songs from backend cookie mode (no QR)."
            : "已从后端 Cookie 模式加载私有歌曲（免扫码）。",
        );
      } else {
        const hasPublicData = await loadPublicProfileIfConfigured();
        if (hasPublicData) {
          showStatus(
            isEn
              ? USE_DIRECT_NETEASE_API
                ? "Loaded public profile songs from direct NetEase API mode."
                : "Loaded public profile songs without QR login."
              : USE_DIRECT_NETEASE_API
                ? "已通过直连网易云 API 模式加载公开资料歌曲。"
                : "已加载公开资料歌曲（免扫码模式）。",
          );
        } else {
          showStatus(
            isEn
              ? USE_DIRECT_NETEASE_API
                ? "No public profile data. Check PUBLIC_NETEASE_API and neteaseUserId."
                : "No account data yet. Set cookie mode for private no-login data, or set neteaseUserId for public profile songs."
              : USE_DIRECT_NETEASE_API
                ? "未读取到公开资料数据，请检查 PUBLIC_NETEASE_API 与 neteaseUserId。"
                : "当前未读取到账户数据。可配置 Cookie 私有免登录数据，或配置 neteaseUserId 公开资料歌曲。",
          );
        }
      }
    } else {
      showStatus(isEn ? "Restored login session from local storage." : "已从本地恢复登录会话。", "info");
    }

    renderPlaylistList();

    if (musicConfig.defaultPlaylistId) {
      currentPlaylistId = musicConfig.defaultPlaylistId;
      await loadPlaylistSongs(musicConfig.defaultPlaylistId, { preserveActivePlayback: shouldPreservePlaybackOnInit });
      return;
    }

    if (Array.isArray(userData?.playlists) && userData.playlists.length) {
      currentPlaylistId = String(userData.playlists[0].id || "");
      if (currentPlaylistId) {
        await loadPlaylistSongs(currentPlaylistId, { preserveActivePlayback: shouldPreservePlaybackOnInit });
        return;
      }
    }

    renderTrackList();
  })();
</script>
