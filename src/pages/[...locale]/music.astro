  }

  function getNextIndex() {
    if (!tracks.length) return 0;
    var mode = getPlayMode();
    if (mode === 'single') return currentIndex;
    if (mode === 'shuffle') {
      var idx = currentIndex;
      while (tracks.length > 1 && idx === currentIndex) {
        idx = Math.floor(Math.random() * tracks.length);
      }
      return idx;
    }
    return (currentIndex + 1) % tracks.length;
  }

  function getPrevIndex() {
    if (!tracks.length) return 0;
    var mode = getPlayMode();
    if (mode === 'single' || mode === 'shuffle') return currentIndex;
    return (currentIndex - 1 + tracks.length) % tracks.length;
  }

  // Playlist modal functions
  function openPlaylistModal() {
    if (!playlistModal) return;
    playlistModal.classList.remove("hidden");
    renderPlaylistModalList();
    document.body.style.overflow = "hidden";
  }

  function closePlaylistModal() {
    if (!playlistModal) return;
    playlistModal.classList.add("hidden");
