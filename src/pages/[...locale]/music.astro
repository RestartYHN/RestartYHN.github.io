      const line = String(rawLine || "").trim();
      if (!line) return;

      // Find all time tags in the line
      const tags = [...line.matchAll(timeTagRe)];
      if (!tags.length) return;

      // Remove all time tags to get the plain lyric text
      const plainText = line.replace(timeTagRe, "").trim();
      if (/^(作[词曲]|编曲|混[音缩]|[词曲](\s*[:：])|Vocal\.|Chorus\.|Guitar|Bass|Drum|Key(board)?|Strings|Arrang|Compos|Lyric|Record|Mix|Master|Producer|Program)/i.test(plainText)) return;

