  async function getBestDirectAudioUrl(id) {
    const levels = ["standard", "exhigh"];
    const realIP = NETEASE_REAL_IP || "";

    for (const level of levels) {
      try {
        const params = realIP ? { id, level, realIP } : { id, level };
        const urlResp = await getNeteaseJson("/song/url/v1", params);
        const urlItem = Array.isArray(urlResp?.data) ? urlResp.data[0] : null;
