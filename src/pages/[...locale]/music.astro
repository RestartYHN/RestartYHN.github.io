<script define:vars={{ musicConfig, isEn }}>
  const API_BASE = musicConfig.apiBase;
  function cut(s, n) { n = n || 12; var str = String(s || ''), w = 0, i = 0; for (i = 0; i < str.length; i++) { var c = str.charCodeAt(i); w += (c >= 0x2E80 && c <= 0x9FFF) || (c >= 0xAC00 && c <= 0xD7AF) || (c >= 0x3040 && c <= 0x30FF) || (c >= 0xFF00 && c <= 0xFFEF) || (c >= 0x4E00 && c <= 0xA000) ? 1 : 0.5; if (w > n) break; } return i < str.length ? str.slice(0, i) + '\u2026' : str; }
