---
import MainPageLayout from '@layouts/MainPageLayout.astro';
import Cover from '@components/Cover.astro';
import FabMenu from '@components/control/FabMenu.astro';
import Comments from '@components/comment/Comments.svelte';
import { siteConfig } from '@/config';
import { musicConfig } from '@/data/music';
import i18nit from '@i18n/translation';
import { i18n } from 'astro:config/client';

export async function getStaticPaths() {
  return i18n?.locales.map((locale) => ({
    params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) },
  }));
}

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);
const isEn = currentLang === 'en';
const pageTitle = `${t('header.music')} - ${siteConfig.title}`;
---

<MainPageLayout title={pageTitle} lang={currentLang} noCache={true}>
  <div class="mx-auto w-full max-w-[var(--page-width)]">
    <Cover
      title={isEn ? 'Music' : '音乐'}
      subTitle={isEn
        ? 'A NetEase Cloud web player with synced lyrics. Browse all your playlists — public, private, and liked songs. The global player keeps music going even when you switch pages. VIP tracks require an active membership on your account.'
        : '基于网易云账号的在线音乐播放器。支持同步歌词，可访问公开歌单、私密歌单与我喜欢的音乐。内置全局播放器，切换页面不会中断播放。VIP 歌曲需账号持有相应权益。'
      }
    />

    <p id="music-status" class="music-status hidden"></p>

    {/* Playlist Popup Modal */}
    <div id="music-playlist-modal" class="music-playlist-modal hidden">
      <div class="music-playlist-modal-backdrop" id="music-playlist-modal-backdrop"></div>
      <div class="music-playlist-modal-content">
        <div class="music-playlist-modal-header">
          <h3 class="music-playlist-modal-title">{isEn ? 'Current Playlist' : '当前播放列表'}</h3>
          <button id="music-playlist-modal-close" class="music-playlist-modal-close" type="button">×</button>
        </div>
        <ul id="music-playlist-modal-list" class="music-playlist-modal-list"></ul>
      </div>
    </div>

    <div class="mx-auto w-full max-w-[var(--page-width)]">
      <div class="music-search-wrap" id="music-search-wrap">
        <input id="music-search-input" class="music-search-input" type="text" placeholder={isEn ? 'Search and add to queue...' : '搜索歌曲加入队列...'} autocomplete="off" />
        <div id="music-search-results" class="music-search-results hidden"></div>
      </div>
    </div>
    <div class="music-main-grid">
      {/* Top Row: Album & Lyrics */}
      <section class="music-hero">
        <div class="music-hero-bg" id="music-hero-bg"></div>
        <div class="music-hero-content">
          <div class="music-now-card">
            <div id="music-cover" class="music-cover"></div>
            <h3 id="music-title" class="music-title">Loading...</h3>
            <p id="music-artist" class="music-artist">-</p>
            <button id="music-play-toggle" class="music-play-btn" type="button">
              {isEn ? 'Play / Pause' : '播放 / 暂停'}
            </button>
          </div>
        </div>
      </section>

      <section class="music-lyrics-panel">
        <div class="lyrics-container" id="music-lyrics">
          <div class="lyrics-track" id="lyrics-track">
            <p class="lyrics-line lyrics-placeholder">{isEn ? 'Lyrics loading...' : '歌词加载中...'}</p>
          </div>
        </div>
      </section>

      {/* Bottom Row: Playlists & Tracks */}
      <section class="music-panel music-playlist-section">
        <div class="mb-3 flex items-end justify-between gap-3">
          <h2 class="music-panel-title">{isEn ? 'Playlists' : '歌单'}</h2>
          <span id="music-playlist-subtitle" class="music-panel-subtitle">{isEn ? 'Click to load' : '点击加载'}</span>
        </div>
        <ul id="music-playlist-list" class="music-playlist-list"></ul>
      </section>

      <div class="music-col-tight">
        <section class="music-panel music-mini-section">
          <div class="mb-3 flex items-end justify-between gap-3">
            <h2 class="music-panel-title">{isEn ? 'Podcasts' : '播客'}</h2>
            <span id="music-podcast-subtitle" class="music-panel-subtitle">{isEn ? 'Click to load' : '点击加载'}</span>
          </div>
          <ul id="music-podcast-list" class="music-playlist-list"></ul>
        </section>
        <section class="music-panel music-mini-section">
          <div class="mb-3 flex items-end justify-between gap-3">
            <h2 class="music-panel-title">{isEn ? 'Recent' : '最近播放'}</h2>
            <span id="music-recent-subtitle" class="music-panel-subtitle"></span>
          </div>
          <ul id="music-recent-list" class="music-track-list"></ul>
        </section>
      </div>

      <section class="music-panel music-album-section">
        <div class="mb-3 flex items-end justify-between gap-3">
          <h2 class="music-panel-title">{isEn ? 'Albums' : '收藏专辑'}</h2>
          <span id="music-album-subtitle" class="music-panel-subtitle">{isEn ? 'Click to load' : '点击加载'}</span>
        </div>
        <ul id="music-album-list" class="music-playlist-list"></ul>
      </section>

      <section class="music-panel music-tracks-section">
        <div class="mb-3 flex items-end justify-between gap-3">
          <h2 class="music-panel-title" id="music-list-title">{isEn ? 'Tracks' : '歌曲列表'}</h2>
          <span id="music-list-subtitle" class="music-panel-subtitle">{isEn ? 'Click to play' : '点击播放'}</span>
        </div>
        <ul id="music-track-list" class="music-track-list"></ul>
      </section>
    </div>

    <section id="music-comments" data-music-comments="true" class="mt-10 rounded-xl border border-[var(--button-border-color)] p-4">
      <h3 class="mb-4 text-lg font-semibold text-[var(--text-color)]">
        {isEn ? 'Comments' : '评论区'}
      </h3>
      <Comments
        client:load
        postSlug="music"
        postTitle={pageTitle}
        language={currentLang}
      />
    </section>

  </div>

  <FabMenu showBackBottom={true} />
</MainPageLayout>

<style>
  .music-main-grid {
    display: grid;
    /* Fixed column widths: left (playlist/hero) and right (lyrics/tracks) */
    grid-template-columns: 360px 420px;
    grid-template-rows: auto auto auto auto auto auto;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  @media (max-width: 1024px) {
    .music-main-grid {
      grid-template-columns: 1fr;
    }
  }

  .music-hero {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--button-border-color);
    grid-column: 1;
    grid-row: 1;
  }

  @media (max-width: 1024px) {
    .music-hero {
      grid-column: 1;
      grid-row: 1;
    }
  }

  .music-lyrics-panel {
    grid-column: 2;
    grid-row: 1;
  }

  @media (max-width: 1024px) {
    .music-lyrics-panel {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .music-playlist-section {
    grid-column: 1;
    grid-row: 2;
  }

  .music-playlist-section {
    grid-column: 1;
    grid-row: 2;
  }

  .music-album-section {
    grid-column: 1;
    grid-row: 3;
  }

  .music-col-tight {
    grid-column: 2;
    grid-row: 3;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .music-mini-section {
    flex-shrink: 0;
  }

  .music-tracks-section {
    grid-column: 2;
    grid-row: 2;
  }

  @media (max-width: 1024px) {
    .music-playlist-section { grid-column: 1; grid-row: 3; }
    .music-tracks-section  { grid-column: 1; grid-row: 4; }
    .music-col-tight       { grid-column: 1; grid-row: 5; }
    .music-album-section   { grid-column: 1; grid-row: 6; }
  }

  .music-hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 20%, rgba(213, 165, 106, 0.2), transparent 48%),
      linear-gradient(135deg, rgba(0, 0, 0, 0.08), transparent 60%);
    filter: saturate(1.1);
  }

  .music-hero-content {
    position: relative;
    z-index: 1;
    padding: 1.1rem;
    backdrop-filter: blur(5px);
  }

  .music-status {
    margin: 0 0 0.8rem;
    padding: 0.5rem 0.8rem;
    border-radius: 0.6rem;
    border: 1px solid color-mix(in oklab, #d5a56a 40%, var(--button-border-color));
    background: color-mix(in oklab, #d5a56a 14%, transparent);
    color: var(--text-color-70);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .music-status.hidden {
    display: none;
  }

  .music-now-card,
  .music-panel {
    border: 1px solid var(--button-border-color);
    border-radius: 0.95rem;
    padding: 1rem;
    background: color-mix(in oklab, var(--bg-color) 88%, transparent);
  }

  .music-cover {
    width: 100%;
    aspect-ratio: 1/1;
    border-radius: 0.8rem;
    background: var(--button-hover-color);
    background-size: cover;
    background-position: center;
    margin-bottom: 0.8rem;
  }

  .music-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-color);
  }

  .music-artist,
  .music-panel-subtitle {
    color: var(--text-color-70);
  }

  .music-play-btn {
    margin-top: 1rem;
    border-radius: 999px;
    border: none;
    background: #d5a56a;
    color: #fff;
    padding: 0.55rem 1rem;
    cursor: pointer;
    transition: background-color 160ms ease;
  }

  .music-play-btn:hover {
    background: #c9925f;
  }

  .music-play-btn,
  .music-control {
    transition: transform 160ms ease, background-color 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }

  .music-play-btn:hover,
  .music-control:hover {
    transform: translateY(-1px);
  }

  .music-play-btn:active,
  .music-control:active {
    transform: translateY(0) scale(0.96);
  }

  .music-panel-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-color);
  }

  .music-lyrics-panel {
    position: relative;
    height: 500px;
    overflow: hidden;
    border: none;
    background: transparent;
    border-radius: 0;
    padding: 0.5rem 1rem;
  }

  @media (max-width: 1024px) {
    .music-lyrics-panel {
      height: 400px;
    }
  }

  @media (max-width: 768px) {
    .music-lyrics-panel {
      height: 350px;
    }
  }

  .music-search-wrap {
    position: relative;
    margin-bottom: 0.5rem;
  }
  .music-search-input {
    width: 100%;
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--button-border-color);
    border-radius: 0.5rem;
    background: color-mix(in oklab, var(--bg-color) 95%, transparent);
    color: var(--text-color);
    font-size: 0.85rem;
    outline: none;
  }
  .music-search-input:focus { border-color: var(--link-color); }
  :global(.music-search-results) {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    z-index: 20;
    max-height: 300px;
    overflow-y: auto;
    border: 1px solid var(--button-border-color);
    border-radius: 0.6rem;
    background: var(--bg-color);
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
    padding: 0.25rem 0;
  }
  :global(.music-search-results.hidden) { display: none; }
  :global(.music-search-result-item) {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.75rem;
    cursor: pointer;
    border-bottom: 1px solid color-mix(in oklab, var(--button-border-color) 40%, transparent);
    transition: background-color 0.12s;
  }
  :global(.music-search-result-item:last-child) { border-bottom: none; }
  :global(.music-search-result-item:hover) { background: var(--button-hover-color); }
  :global(.music-search-result-item.active) {
    background: var(--button-hover-color);
    border-left: 3px solid var(--link-color);
  }
  :global(.music-search-result-cover) {
    width: 36px; height: 36px;
    border-radius: 4px;
    background-color: var(--button-hover-color);
    flex-shrink: 0;
    object-fit: cover;
  }
  :global(.music-search-result-text) {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  :global(.music-search-result-title) {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-color);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    line-height: 1.35;
  }
  :global(.music-search-result-artist) {
    font-size: 0.78rem;
    color: var(--text-color-70);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    line-height: 1.2;
  }

  .lyrics-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to bottom,
        transparent 0%,
        rgba(0,0,0,0.3) 8%,
        black 18%,
        black 82%,
        rgba(0,0,0,0.3) 92%,
        transparent 100%);
    mask-image: linear-gradient(to bottom,
        transparent 0%,
        rgba(0,0,0,0.3) 8%,
        black 18%,
        black 82%,
        rgba(0,0,0,0.3) 92%,
        transparent 100%);
  }

  .lyrics-container.is-static {
    overflow-y: auto;
    -webkit-mask-image: none;
    mask-image: none;
    scroll-behavior: smooth;
  }

  .lyrics-track {
    position: absolute;
    width: 100%;
    top: 0;
    left: 0;
    will-change: transform;
    transition: transform 0.12s ease-out;
  }

  .lyrics-line {
    text-align: center;
    padding: 0.45rem 1rem;
    opacity: 0.25;
    transition: opacity 0.35s ease, font-size 0.35s ease, color 0.35s ease;
    cursor: pointer;
    user-select: none;
    font-size: 0.92rem;
    line-height: 1.8;
  }

  .lyrics-line.active {
    opacity: 1;
    font-size: 1.12rem;
    font-weight: 600;
  }

  .lyrics-line.near {
    opacity: 0.55;
    font-size: 0.96rem;
  }

  .lyrics-main {
    color: var(--text-color);
  }

  .lyrics-trans {
    margin-top: 0.15rem;
    font-size: 0.86rem;
    color: color-mix(in oklab, var(--text-color-70) 85%, transparent);
  }

  .lyrics-line.active .lyrics-main {
    color: var(--text-color);
  }

  .lyrics-line.active .lyrics-trans {
    color: color-mix(in oklab, var(--text-color) 65%, transparent);
  }

  .lyrics-static {
    opacity: 0.85;
    font-size: 0.95rem;
    font-weight: normal;
    cursor: default;
    text-align: left;
    padding: 0.3rem 0.5rem;
  }
  .lyrics-static .lyrics-main {
    color: var(--text-color-70);
  }

  .music-track-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-height: 500px;
    overflow-y: auto;
  }

  .music-track-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    border: 1px solid var(--button-border-color);
    border-radius: 0.9rem;
    background: color-mix(in oklab, var(--bg-color) 95%, transparent);
    padding: 0.7rem;
    cursor: pointer;
    transition: background-color 160ms ease, transform 160ms ease;
    min-height: 3.2rem;
  }

  :global(.music-track-card) { border-bottom: 1px solid color-mix(in oklab, var(--button-border-color) 40%, transparent); }
  :global(.music-track-card:hover) { background: var(--button-hover-color) !important; border-color: var(--link-color) !important; }
  :global(.music-playlist-card) { border-bottom: 1px solid color-mix(in oklab, var(--button-border-color) 40%, transparent); }
  :global(.music-playlist-card:hover) { background: var(--button-hover-color) !important; border-color: var(--link-color) !important; }

  .music-track-index {
    width: 2rem;
    text-align: center;
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--text-color-70);
    flex-shrink: 0;
  }

  .music-track-card.active {
    background: var(--button-hover-color);
    border-color: #d5a56a;
  }

  .music-track-card.unavailable {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .music-track-card.unavailable:hover {
    background: color-mix(in oklab, var(--bg-color) 95%, transparent);
    transform: none;
  }

  .music-track-card:hover {
    background: var(--button-hover-color);
  }

  .music-track-card.loading {
    opacity: 0.6;
    pointer-events: none;
  }

  .music-track-played {
    margin-top: 0.15rem;
    color: var(--text-color-70);
    font-size: 0.75rem;
  }

  .music-track-title {
    margin: 0;
    color: var(--text-color);
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .music-track-artist {
    margin-top: 0.2rem;
    color: var(--text-color-70);
    font-size: 0.85rem;
  }

  .music-bottom-player {
    position: sticky;
    bottom: 0.8rem;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid var(--button-border-color);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--bg-color) 90%, transparent);
    padding: 0.75rem;
    backdrop-filter: blur(8px);
  }

  @media (max-width: 768px) {
    .music-bottom-player {
      display: grid;
      grid-template-columns: 54px minmax(0, 1fr) auto auto auto auto;
      grid-template-areas:
        "cover info prev play next list"
        "progress progress progress progress progress progress";
      gap: 0.45rem 0.5rem;
      align-items: center;
      padding: 0.65rem;
    }

    .music-bottom-cover {
      grid-area: cover;
    }

    .music-bottom-player .min-w-0 {
      grid-area: info;
      min-width: 0;
    }

    #music-prev {
      grid-area: prev;
    }

    #music-main-play {
      grid-area: play;
    }

    #music-next {
      grid-area: next;
    }

    #music-playlist-btn {
      grid-area: list;
    }

    .music-progress-wrap {
      grid-area: progress;
      grid-column: 1 / -1;
      margin-top: 0.2rem;
      margin-left: -0.65rem;
      margin-right: -0.65rem;
      padding: 0 0.65rem;
      grid-template-columns: 34px 1fr 34px;
      gap: 0.35rem;
    }

    .music-position-info {
      display: none;
    }

    .music-control {
      width: 36px;
      height: 36px;
    }
  }

  .music-bottom-cover {
    width: 54px;
    height: 54px;
    border-radius: 0.65rem;
    background: var(--button-hover-color);
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .music-progress-wrap {
    margin-top: 0.35rem;
    display: grid;
    grid-template-columns: 42px 1fr 42px;
    align-items: center;
    gap: 0.45rem;
    --progress-percent: 0%;
  }

  .music-progress-wrap.is-dragging {
    filter: saturate(1.08);
  }

  .music-progress {
    width: 100%;
    accent-color: #d5a56a;
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
    height: 18px;
    background: linear-gradient(
      to right,
      #d5a56a 0%,
      #d5a56a var(--progress-percent),
      color-mix(in oklab, #d5a56a 20%, var(--button-border-color)) var(--progress-percent),
      color-mix(in oklab, #d5a56a 20%, var(--button-border-color)) 100%
    );
    border-radius: 999px;
    outline: none;
  }

  .music-progress::-webkit-slider-runnable-track {
    height: 3px;
    border-radius: 999px;
    background: transparent;
  }

  .music-progress::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    margin-top: -5.5px;
    border-radius: 50%;
    border: 2px solid color-mix(in oklab, #d5a56a 80%, #fff);
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }

  .music-progress::-moz-range-track {
    height: 3px;
    border: none;
    border-radius: 999px;
    background: transparent;
  }

  .music-progress::-moz-range-thumb {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid color-mix(in oklab, #d5a56a 80%, #fff);
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }

  .music-time {
    font-size: 0.72rem;
    color: var(--text-color-70);
    text-align: center;
    white-space: nowrap;
  }

  .music-position-info {
    font-size: 0.8rem;
    color: var(--text-color-70);
    white-space: nowrap;
    margin-right: 0.3rem;
  }

  .music-playlist-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-height: 500px;
    overflow-y: auto;
  }

  .music-playlist-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    border: 1px solid var(--button-border-color);
    border-radius: 0.9rem;
    background: color-mix(in oklab, var(--bg-color) 95%, transparent);
    padding: 0.75rem 0.8rem;
    cursor: pointer;
    transition: background-color 160ms ease, transform 160ms ease, opacity 160ms ease;
    position: relative;
    min-height: 3.2rem;
  }

  .music-playlist-card:not(.loading):hover {
    background: var(--button-hover-color);
    border-color: var(--link-color);
  }

  .music-playlist-index {
    width: 2rem;
    text-align: center;
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--text-color-70);
    flex-shrink: 0;
  }

  .music-playlist-card.active {
    background: var(--button-hover-color);
    border-color: #d5a56a;
