  }

  function setupSearch() {
    const input = document.getElementById('music-search-input');
    const results = document.getElementById('music-search-results');
    if (!input || !results) return;
    let timer, selectedIdx = -1, currentDataset = [];
    input.addEventListener('input', () => {
      clearTimeout(timer);
      selectedIdx = -1;
      const q = input.value.trim();
      if (q.length < 2) { results.classList.add('hidden'); return; }
      timer = setTimeout(async () => {
        try {
          const res = await fetch(`${API_BASE}/api/music/search?q=${encodeURIComponent(q)}`, { referrerPolicy: 'no-referrer' });
          const json = await res.json();
          if (json.code !== 200 || !Array.isArray(json.data) || !json.data.length) {
            results.innerHTML = `<div class="music-search-result-item" style="cursor:default"><span class="music-search-result-artist">${isEn ? 'No results' : '无结果'}</span></div>`;
            results.classList.remove('hidden');
            currentDataset = [];
            return;
          }
          currentDataset = json.data;
          results.innerHTML = currentDataset.map((t, i) => `
            <div class="music-search-result-item" data-idx="${i}" data-id="${t.id}">
              <img class="music-search-result-cover" src="${t.cover}?param=40y40" referrerpolicy="no-referrer" alt="" />
              <div class="music-search-result-text">
                <div class="music-search-result-title">${escHtml(t.title)}</div>
                <div class="music-search-result-artist">${escHtml(t.artist)}</div>
              </div>
            </div>
          `).join('');
          results.classList.remove('hidden');
          results.querySelectorAll('.music-search-result-item').forEach(el => {
            el.addEventListener('click', () => selectResult(parseInt(el.getAttribute('data-idx') || '0', 10)));
          });
        } catch (e) {}
      }, 300);
    });

    input.addEventListener('keydown', (e) => {
      if (!currentDataset.length || results.classList.contains('hidden')) return;
      const items = results.querySelectorAll('.music-search-result-item');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIdx = Math.min(selectedIdx + 1, currentDataset.length - 1);
        highlightItem(items, selectedIdx);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIdx = Math.max(selectedIdx - 1, 0);
        highlightItem(items, selectedIdx);
      } else if (e.key === 'Enter' && selectedIdx >= 0) {
        e.preventDefault();
        selectResult(selectedIdx);
      }
    });

    function highlightItem(items, idx) {
      items.forEach((el, i) => el.classList.toggle('active', i === idx));
      if (items[idx]) items[idx].scrollIntoView({ block: 'nearest' });
    }

    async function selectResult(idx) {
      const track = currentDataset[idx];
      if (!track) return;
      const loaded = await loadTrack(track.id);
      if (!loaded.audio) return;
      tracks.push(loaded);
      currentIndex = tracks.length - 1;
      renderTrackList();
      updatePlayerPosition();
      results.classList.add('hidden');
      input.value = '';
      currentDataset = [];
      selectedIdx = -1;
      showStatus(isEn ? `Queued: ${loaded.title}` : `已加入: ${loaded.title}`);
      setTimeout(hideStatus, 2000);
    }

    document.addEventListener('click', (e) => {
      if (!input.contains(e.target) && !results.contains(e.target)) results.classList.add('hidden');
    });
  }

  function escHtml(s) {
    const d = document.createElement('div');
    d.textContent = s || '';
    return d.innerHTML;
  }

  async function loadCookieProfileIfConfigured() {
    if (USE_DIRECT_NETEASE_API) return false;
    if (!musicConfig.preferCookieProfile) return false;
    try {
      const result = await getJson(`${API_BASE}/api/music/cookie-user`);
      if (result?.code === 200 && result.data) {
        userData = result.data;
        return true;
      }
    } catch (error) {
      console.warn("[music] load cookie profile failed", error);
    }
    return false;
  }

  async function loadRecentSongs() {
    if (!recentListEl) return;
    const history = Array.isArray(userData?.recentHistory) ? userData.recentHistory : [];
    if (!history.length) {
      recentListEl.innerHTML = `<li class="music-empty">${isEn ? 'No recent plays yet' : '暂无最近播放'}</li>`;
      return;
    }

    if (recentSubtitleEl) recentSubtitleEl.textContent = isEn ? 'recent' : '最近';

    const limit = Math.min(3, history.length);
    const recentTracks = [];
    for (let i = 0; i < limit; i++) {
      const item = history[i];
      try {
        const track = await loadTrack(String(item.id));
        if (track.audio) {
          recentTracks.push({ ...track, playedAt: Number(item.playedAt) || 0 });
        }
      } catch (e) {}
    }

    if (!recentTracks.length) {
      recentListEl.innerHTML = `<li class="music-empty">${isEn ? 'No playable track' : '无可播放歌曲'}</li>`;
      return;
    }

    recentListEl.innerHTML = recentTracks.map((t, i) => {
      const timeStr = formatPlayedTime(t.playedAt);
      return `
        <li class="music-track-card" data-ri="${i}" data-id="${t.id}">
          <div class="music-track-index">${String(i + 1).padStart(2, '0')}</div>
          <div class="min-w-0 flex-1">
            <p class="music-track-title truncate">${t.title || 'Unknown'}</p>
            <p class="music-track-artist truncate">${t.artist || 'Unknown Artist'}</p>
            ${timeStr ? `<p class="music-track-played">${timeStr}</p>` : ''}
          </div>
        </li>`;
    }).join('');

    recentListEl.querySelectorAll('.music-track-card').forEach((el) => {
      el.addEventListener('click', async () => {
        const ri = parseInt(el.getAttribute('data-ri') || '0', 10);
        if (ri < 0 || ri >= recentTracks.length) return;
        tracks = recentTracks;
        currentIndex = ri;
        const current = await prepareTrackForPlayback(currentIndex);
        if (!current) return;
        updateNowPlaying(current);
        renderTrackList();
        updatePlayerPosition();
        syncToGlobalPlayer();
        if (current.audio) {
          hideStatus();
          try { audio?.play(); } catch (e) {}
        }
      });
    });
  }

  async function loadAlbums() {
    if (!albumListEl) return;
    try {
      const result = await getJson(`${API_BASE}/api/music/albums`);
      if (result?.code !== 200 || !Array.isArray(result.data)) {
        albumListEl.innerHTML = `<li class="music-empty">${isEn ? 'Failed to load' : '加载失败'}</li>`;
        return;
      }
      const albums = result.data;
      if (albumSubtitleEl) albumSubtitleEl.textContent = `${albums.length} ${isEn ? 'albums' : '张'}`;
      albumListEl.innerHTML = albums.map((a, idx) => `
        <li class="music-playlist-card" data-album-id="${a.id}">
          <div class="music-playlist-index">${String(idx + 1).padStart(2, '0')}</div>
          <div class="min-w-0 flex-1">
            <p class="music-playlist-name truncate">${a.name}</p>
            <p class="music-playlist-meta">${a.artist} · ${a.size} ${isEn ? 'tracks' : '首'}</p>
          </div>
        </li>
      `).join('');
      albumListEl.querySelectorAll('.music-playlist-card').forEach((el) => {
        el.addEventListener('click', async () => {
          const albumId = String(el.getAttribute('data-album-id') || '');
          if (!albumId) return;
          showStatus(isEn ? 'Loading album...' : '正在加载专辑...');
          try {
            const r = await getJson(`${API_BASE}/api/music/album?id=${albumId}`);
            if (r?.code !== 200 || !Array.isArray(r.data?.tracks)) {
              showStatus(isEn ? 'Failed to load album.' : '专辑加载失败。', 'error');
              return;
            }
            const ids = r.data.tracks.map((t) => t.id).filter(Boolean);
            const version = ++loadVersion;
            tracks = [];
            for (const id of ids) {
              if (version !== loadVersion) return;
              const track = await loadTrack(id);
              if (track.audio) tracks.push(track);
            }
            if (!tracks.length) {
              renderTrackList();
              showStatus(isEn ? 'Album is empty.' : '专辑为空。', 'error');
              return;
            }
            currentIndex = 0;
            updateNowPlaying(tracks[currentIndex], { preserveActivePlayback: false });
            updatePlayerPosition();
            renderTrackList();
            hideStatus();
            bootstrapGlobalPlayer();
          } catch (e) {
            showStatus(isEn ? 'Failed to load album.' : '专辑加载失败。', 'error');
          }
        });
      });
    } catch (e) {
      albumListEl.innerHTML = `<li class="music-empty">${isEn ? 'Failed to load' : '加载失败'}</li>`;
    }
  }

  // Podcast helpers (moved to top-level so init can call them)
  // Load all programs (episodes) from a podcast (radio) and treat each program's mainTrackId as a track
  async function loadPodcastPrograms(rid, options = {}) {
    const preserveActivePlayback = Boolean(options?.preserveActivePlayback);
    try {
      showStatus(isEn ? 'Loading podcast episodes...' : '正在加载播客剧集...');
      if (playlistSubtitleEl) playlistSubtitleEl.textContent = isEn ? 'Loading podcast...' : '加载播客...';

      let programs = [];
      if (USE_DIRECT_NETEASE_API) {
        const result = await getNeteaseJson("/dj/program", { rid, limit: 500, offset: 0 });
        programs = Array.isArray(result?.programs) ? result.programs : [];
      } else {
        const url = `${API_BASE}/api/music/podcast/programs?rid=${encodeURIComponent(rid)}&limit=500&offset=0`;
        const result = await getJson(url);
        programs = Array.isArray(result?.programs)
          ? result.programs
          : Array.isArray(result?.data?.programs)
            ? result.data.programs
            : Array.isArray(result?.data)
              ? result.data
              : [];
      }

      if (!programs.length) {
        showStatus(isEn ? 'No episodes found.' : '未找到剧集。', 'error');
        return;
      }

      const ids = programs.map((p) => String(p?.mainTrackId || p?.id || '')).filter(Boolean);
      const version = ++loadVersion;

      tracks = [];
      if (USE_DIRECT_NETEASE_API) {
        tracks = programs.map((p) => {
          const id = String(p?.mainTrackId || p?.id || '');
          return {
            id,
            title: p?.name || p?.title || `Song ${id}`,
            artist: p?.dj?.nickname || p?.radio?.name || 'Unknown Artist',
            cover: p?.coverUrl || p?.radio?.picUrl || '',
            audio: '', lyric: '', tlyric: '', unavailable: false
          };
        }).filter((t) => t.id);
      } else {
        for (let i = 0; i < ids.length; i++) {
          if (version !== loadVersion) return;
          const id = ids[i];
          const p = programs.find((x) => String(x.mainTrackId) === id || String(x.id) === id) || {};
          try {
            const track = await loadTrack(id);
            const pTitle = p?.name || p?.title;
            const pArtist = p?.dj?.nickname || p?.radio?.name;
            const pCover = p?.coverUrl || p?.radio?.picUrl;
            const pDesc = p?.description;
            tracks.push({
              ...track,
              title: pTitle || track.title,
              artist: pArtist || track.artist,
              cover: pCover || track.cover || '',
              lyric: pDesc || track.lyric || ''
            });
          } catch (e) {
            console.warn('[music] load podcast track failed', id, e);
          }
        }
      }

      if (!tracks.length) {
        renderTrackList();
        showStatus(isEn ? 'Podcast has no playable episodes.' : '播客暂无可播放剧集。', 'error');
        return;
      }

      currentIndex = 0;
      updateNowPlaying(tracks[currentIndex], { preserveActivePlayback });
      updatePlayerPosition();
      renderTrackList();
      hideStatus();
      if (playlistSubtitleEl) playlistSubtitleEl.textContent = isEn ? `Loaded ${tracks.length} episodes` : `已加载 ${tracks.length} 集`;

      // Bootstrap global player with loaded tracks
      bootstrapGlobalPlayer();

      // Warm first track in background
      loadTrack(tracks[0].id).then((firstTrack) => {
        if (version !== loadVersion || !firstTrack) return;
        const keepTitle = tracks[0].title && tracks[0].title !== `Song ${tracks[0].id}` && tracks[0].title !== 'Unknown';
        const keepArtist = tracks[0].artist && tracks[0].artist !== 'Unknown Artist' && tracks[0].artist !== 'Unknown';
        const keepCover = Boolean(tracks[0].cover);
        const keepLyric = Boolean(tracks[0].lyric);

        tracks[0] = { 
          ...tracks[0], 
          ...firstTrack, 
          title: keepTitle ? tracks[0].title : firstTrack.title,
          artist: keepArtist ? tracks[0].artist : firstTrack.artist,
          cover: keepCover ? tracks[0].cover : firstTrack.cover,
          lyric: keepLyric ? tracks[0].lyric : firstTrack.lyric,
          tlyric: keepLyric ? tracks[0].tlyric : firstTrack.tlyric,
          unavailable: !firstTrack.audio 
        };
        if (currentIndex === 0) updateNowPlaying(tracks[0], { preserveActivePlayback });
        renderTrackList();
      }).catch(() => {});
    } catch (error) {
      console.warn('[music] load podcast failed', error);
      showStatus(isEn ? 'Failed to load podcast.' : '播客加载失败。', 'error');
    }
  }

  // Fetch raw programs array for a radio id without modifying global tracks
  async function fetchPodcastPrograms(rid) {
    try {
      if (USE_DIRECT_NETEASE_API) {
        const result = await getNeteaseJson("/dj/program", { rid, limit: 500, offset: 0 });
        return Array.isArray(result?.programs) ? result.programs : [];
      }
      const url = `${API_BASE}/api/music/podcast/programs?rid=${encodeURIComponent(rid)}&limit=500&offset=0`;
      const result = await getJson(url);
      const programs = Array.isArray(result?.programs)
        ? result.programs
        : Array.isArray(result?.data?.programs)
          ? result.data.programs
          : Array.isArray(result?.data)
            ? result.data
            : [];
      return programs;
    } catch (e) {
      console.warn('[music] fetchPodcastPrograms error', e);
      return [];
    }
  }

  function renderPodcastProgramsList(programs, containerEl = podcastTrackListEl) {
    if (!containerEl) return;
    if (!programs || !programs.length) {
      containerEl.innerHTML = `<li class="music-empty">${isEn ? 'No episodes' : '暂无剧集'}</li>`;
      return;
    }

    containerEl.innerHTML = programs
      .map((p, idx) => `
        <li class="music-track-card" data-episode-id="${p?.id || ''}" data-track-id="${p?.mainTrackId || ''}">
          <div class="music-track-index">${String(idx + 1).padStart(2, '0')}</div>
          <div class="min-w-0 flex-1">
            <p class="music-track-title truncate">${p?.name || p?.title || 'Episode'}</p>
            <p class="music-track-artist truncate">${p?.dj?.nickname || p?.radio?.name || ''}</p>
          </div>
        </li>
      `)
      .join('');

    containerEl.querySelectorAll('.music-track-card').forEach((el) => {
      el.addEventListener('click', async () => {
        const trackId = String(el.getAttribute('data-track-id') || '');
        if (!trackId) return;
        showStatus(isEn ? 'Loading episode...' : '正在加载剧集...');
        try {
          const track = await loadTrack(trackId);
          if (!track?.id) {
            showStatus(isEn ? 'Failed to load episode.' : '加载剧集失败。', 'error');
            return;
          }

          const p = programs.find((x) => String(x.mainTrackId) === trackId || String(x.id) === trackId);
          const pTitle = p?.name || p?.title;
          const pArtist = p?.dj?.nickname || p?.radio?.name;
          const pCover = p?.coverUrl || p?.radio?.picUrl;
          const pDesc = p?.description;
          const finalTrack = {
            ...track,
            title: pTitle || track.title,
            artist: pArtist || track.artist,
            cover: pCover || track.cover || '',
            lyric: pDesc || track.lyric || ''
          };

          // Replace current playlist with single episode and play directly
          tracks = [finalTrack];
          currentIndex = 0;
          updateNowPlaying(finalTrack, { preserveActivePlayback: false });
          renderTrackList();
          updatePlayerPosition();
          bootstrapGlobalPlayer();
          hideStatus();
          try { audio.play().catch(e => console.warn('[music] Play failed:', e?.message || e)); } catch (e) {}
        } catch (e) {
          console.warn('[music] fetch track for episode failed', e);
          showStatus(isEn ? 'Failed to load episode.' : '加载剧集失败。', 'error');
        }
      });
    });
  }

  function togglePlay() {
    if (!audio) return;
    if (audio.paused) {
      audio.play().catch(e => console.warn('[music] Play failed:', e?.message || e));
    } else {
      audio.pause();
    }
  }

  // Delegate play/pause clicks to avoid binding-order issues and duplicate handlers.
  function delegateMusicClicks(e) {
    const btn = e.target.closest('#music-main-play, #music-play-toggle');
    if (!btn) return;

    // On the music page, let the page handle bottom player clicks (page owns playback UI).
    if (/\/music\/?$/i.test(window.location.pathname)) {
      e.preventDefault();
      togglePlay();
      return;
    }

    

    // Off music page: if a global controller exists, prefer it (avoid double-toggle).
    try {
      const globalController = window[GLOBAL_MUSIC_KEY];
      if (btn.matches && btn.matches('#music-main-play') && globalController) {
        return;
      }
    } catch (err) {
      // ignore and continue
    }

    e.preventDefault();
    togglePlay();
  }

  if (!document._musicDelegationBound) {
    document.addEventListener('click', delegateMusicClicks);
    document._musicDelegationBound = true;
  }
  

  let _musicHandlers = {};

  function musicBind() {
    musicUnbind();
    if (!audio || !btnPrev || !btnNext || !progressEl) return;

    _musicHandlers.onPlay = () => updatePlayButtonState();
    _musicHandlers.onPause = () => updatePlayButtonState();
    _musicHandlers.onPrev = async () => {
      if (!tracks.length) return;
      currentIndex = getPrevIndex();
      const current = await prepareTrackForPlayback(currentIndex);
      if (!current) return;
      updateNowPlaying(current);
      renderTrackList();
      updatePlayerPosition();
      updatePlaylistCount();
      syncPlaylistModalIfOpen();
      syncToGlobalPlayer();
      if (current?.audio && audio?.src) {
        hideStatus();
        audio?.play().catch(e => console.warn('[music] Play failed:', e?.message || e));
      } else {
        showStatus(isEn ? "No playable URL for this track in direct mode." : "直连模式下该歌曲暂无可用播放链接。", "error");
      }
    };
    _musicHandlers.onNext = async () => {
      if (!tracks.length) return;
      currentIndex = getNextIndex();
      const current = await prepareTrackForPlayback(currentIndex);
      if (!current) return;
      updateNowPlaying(current);
      renderTrackList();
      updatePlayerPosition();
      updatePlaylistCount();
      syncPlaylistModalIfOpen();
      syncToGlobalPlayer();
      if (current?.audio && audio?.src) {
        hideStatus();
        audio?.play().catch(e => console.warn('[music] Play failed:', e?.message || e));
      } else {
        showStatus(isEn ? "No playable URL for this track in direct mode." : "直连模式下该歌曲暂无可用播放链接。", "error");
      }
    };
    _musicHandlers.onError = () => {
      console.warn('[music] Audio error:', audio?.error?.code, audio?.error?.message, 'src:', audio?.src);
    };
    _musicHandlers.onEnded = async () => {
      if (!tracks.length) return;
      currentIndex = getNextIndex();
      const current = await prepareTrackForPlayback(currentIndex);
      if (!current) return;
      updateNowPlaying(current);
      renderTrackList();
      updatePlayerPosition();
      updatePlaylistCount();
      syncPlaylistModalIfOpen();
      syncToGlobalPlayer();
      if (current?.audio && audio?.src) {
        hideStatus();
        audio.play().catch(e => console.warn('[music] Play failed:', e?.message || e));
      }
    };
    _musicHandlers.onTimeUpdate = syncLyrics;
    _musicHandlers.onProgressTimeUpdate = () => {
      if (!audio) return;
      if (currentTimeEl) currentTimeEl.textContent = formatClock(audio.currentTime);
      if (progressEl && Number.isFinite(audio.duration) && audio.duration > 0) {
        const ratio = audio.currentTime / audio.duration;
        progressEl.value = String(Math.min(1000, Math.max(0, Math.round(ratio * 1000))));
        updateProgressVisual();
      }
    };
    _musicHandlers.onLoadedMetadata = () => {
      if (totalTimeEl) totalTimeEl.textContent = formatClock(audio?.duration || 0);
    };
    _musicHandlers.onProgressInput = () => {
      if (!audio || !Number.isFinite(audio.duration) || audio.duration <= 0) return;
      const ratio = Number(progressEl.value || 0) / 1000;
      audio.currentTime = ratio * audio.duration;
    };

    audio.addEventListener("play", _musicHandlers.onPlay);
    audio.addEventListener("pause", _musicHandlers.onPause);
    audio.addEventListener("timeupdate", _musicHandlers.onTimeUpdate);
    audio.addEventListener("timeupdate", _musicHandlers.onProgressTimeUpdate);
    audio.addEventListener("loadedmetadata", _musicHandlers.onLoadedMetadata);
    audio.addEventListener("ended", _musicHandlers.onEnded);
    audio.addEventListener("error", _musicHandlers.onError);
    btnPrev.addEventListener("click", _musicHandlers.onPrev);
    btnNext.addEventListener("click", _musicHandlers.onNext);
    progressEl.addEventListener("input", _musicHandlers.onProgressInput);
  }

  function musicUnbind() {
    if (_musicHandlers.onPlay) audio?.removeEventListener("play", _musicHandlers.onPlay);
    if (_musicHandlers.onPause) audio?.removeEventListener("pause", _musicHandlers.onPause);
    if (_musicHandlers.onTimeUpdate) audio?.removeEventListener("timeupdate", _musicHandlers.onTimeUpdate);
    if (_musicHandlers.onProgressTimeUpdate) audio?.removeEventListener("timeupdate", _musicHandlers.onProgressTimeUpdate);
    if (_musicHandlers.onLoadedMetadata) audio?.removeEventListener("loadedmetadata", _musicHandlers.onLoadedMetadata);
    if (_musicHandlers.onEnded) audio?.removeEventListener("ended", _musicHandlers.onEnded);
    if (_musicHandlers.onError) audio?.removeEventListener("error", _musicHandlers.onError);
    if (_musicHandlers.onPrev) btnPrev?.removeEventListener("click", _musicHandlers.onPrev);
    if (_musicHandlers.onNext) btnNext?.removeEventListener("click", _musicHandlers.onNext);
    if (_musicHandlers.onProgressInput) progressEl?.removeEventListener("input", _musicHandlers.onProgressInput);
    _musicHandlers = {};
  }

  async function initMusicPage() {
    queryPageEls();
    var mbp = document.getElementById('music-bottom-player');
    if (mbp) mbp.style.display = '';

    if (!/\/music\/?$/i.test(window.location.pathname)) {
      musicUnbind();
      return;
    }
    musicBind();

    // Playlist modal bindings
    if (btnPlaylistToggle && !btnPlaylistToggle._musicBound) {
      btnPlaylistToggle.addEventListener("click", openPlaylistModal);
      btnPlaylistToggle._musicBound = true;
    }
    if (playlistModalBackdrop && !playlistModalBackdrop._musicBound) {
      playlistModalBackdrop.addEventListener("click", closePlaylistModal);
      playlistModalBackdrop._musicBound = true;
    }
    if (playlistModalClose && !playlistModalClose._musicBound) {
      playlistModalClose.addEventListener("click", closePlaylistModal);
      playlistModalClose._musicBound = true;
    }
    // Warmup API in parallel (don't await)
    warmupNeteaseApi();
    setupSearch();

    // Auto-load multiple fixed podcasts and render as a simple podcast title list
    (async () => {
      const version = ++podcastLoadVersion;
      try {
        const rids = ['1490741063'];
        if (!podcastCardsEl) return;

        const results = await Promise.all(
          rids.map((rid) => fetchPodcastPrograms(rid)),
        );

        if (version !== podcastLoadVersion) return;

        podcastCardsEl.innerHTML = '';
        const seenNames = new Set();
        results.forEach((programs, i) => {
          if (!Array.isArray(programs) || !programs.length) return;
          const radioName = (programs[0]?.radio?.name || '').trim();
          if (!radioName || seenNames.has(radioName)) return;
          seenNames.add(radioName);
          const count = programs.length;
          const rid = rids[i];
          const li = document.createElement('li');
          li.className = 'music-playlist-card';
          li.setAttribute('data-rid', rid);
          li.innerHTML = `
            <div class="music-playlist-index">${String(podcastCardsEl.children.length + 1).padStart(2, '0')}</div>
            <div class="min-w-0 flex-1">
              <p class="music-playlist-name truncate">${radioName}</p>
              <p class="music-playlist-meta">${count} ${isEn ? 'episodes' : '集'}</p>
            </div>
          `;
          li.addEventListener('click', async () => {
            const ridVal = String(li.getAttribute('data-rid') || '');
            if (!ridVal) return;
            await loadPodcastPrograms(ridVal, { preserveActivePlayback: false });
          });
          podcastCardsEl.appendChild(li);
        });
        if (playlistSubtitleEl && podcastCardsEl.children.length) {
          playlistSubtitleEl.textContent = isEn ? 'Podcasts loaded' : '已加载播客';
        }
      } catch (e) {
        console.debug('[music] auto-load podcasts failed', e);
      }
    })();

    const shouldPreservePlaybackOnInit = Boolean(audio && !audio.paused && (audio.currentSrc || audio.src));

    // Try to restore from global player first (for page re-entry)
    const hasGlobalState = restoreFromGlobalPlayer();
    if (hasGlobalState) {
      renderTrackList();
      if (tracks[currentIndex]) {
        const hydrated = await prepareTrackForPlayback(currentIndex);
        if (hydrated) {
          updateNowPlaying(hydrated, { preserveActivePlayback: shouldPreservePlaybackOnInit });
        }
      }
      updatePlayerPosition();
      updatePlaylistCount();
    }

    const hasTokenData = await restoreUserDataByToken();
    if (!hasTokenData) {
      await loadCookieProfileIfConfigured();
    }

    if (hasGlobalState) {
      loadRecentSongs();
      loadAlbums();
      renderPlaylistList();
      return;
    }

    loadRecentSongs();
    loadAlbums();
    renderPlaylistList();

    if (musicConfig.defaultPlaylistId) {
      currentPlaylistId = musicConfig.defaultPlaylistId;
      await loadPlaylistSongs(musicConfig.defaultPlaylistId, { preserveActivePlayback: shouldPreservePlaybackOnInit });
      await prewarmFirstTrack();
      return;
    }

    if (Array.isArray(userData?.playlists) && userData.playlists.length) {
      currentPlaylistId = String(userData.playlists[0].id || "");
      if (currentPlaylistId) {
        await loadPlaylistSongs(currentPlaylistId, { preserveActivePlayback: shouldPreservePlaybackOnInit });
        await prewarmFirstTrack();
        return;
      }
    }

    renderTrackList();
  }

  // Initialize now and on Astro partial navigation
  initMusicPage();
  window.addEventListener('music-track-change', async (e) => {
    const idx = e.detail?.index;
    if (idx == null || idx >= tracks.length) return;
    currentIndex = idx;
    const current = await prepareTrackForPlayback(idx);
    if (!current) return;
    updateNowPlaying(current);
    renderTrackList();
    updatePlayerPosition();
  });
  document.addEventListener('astro:after-swap', initMusicPage);
  document.addEventListener('astro:page-load', initMusicPage);
</script>
