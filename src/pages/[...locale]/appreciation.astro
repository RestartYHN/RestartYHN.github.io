---
import MainPageLayout from '@layouts/MainPageLayout.astro'
import Cover from '@components/Cover.astro'
import FabMenu from '@components/control/FabMenu.astro'
import { siteConfig } from '@/config'
import i18nit from '@i18n/translation'
import { i18n } from "astro:config/client"
import { getRelativeLocaleUrl } from '@utils/url-utils'

export async function getStaticPaths() {
  return i18n?.locales.map(locale => ({
    params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) }
  }))
}

const currentLang = Astro.currentLocale || i18n!.defaultLocale
const normalizedLang = currentLang === 'en' ? 'en' : 'zh-cn'
const t = i18nit(currentLang)

const pageTitle = `${t("header.appreciation")} - ${siteConfig.title}`
---

<MainPageLayout title={pageTitle} lang={currentLang}>
  <div class="mx-auto w-full max-w-[var(--page-width)]">
    <Cover title={t("cover.title.appreciation")} subTitle={t("cover.subTitle.appreciation")} />

    <div class="flex flex-wrap gap-3 mb-6">
      <a href={getRelativeLocaleUrl(currentLang, '/appreciation/gallery/tags/')} class="inline-flex items-center gap-1 px-4 py-2 text-sm rounded-lg border border-[var(--button-border-color)] text-[var(--text-color)] hover:border-[var(--link-color)] hover:text-[var(--link-color)] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>
        {normalizedLang === 'en' ? 'Gallery Overview' : '画廊总览'}
      </a>
      <a href={getRelativeLocaleUrl(currentLang, '/appreciation/archives/')} class="inline-flex items-center gap-1 px-4 py-2 text-sm rounded-lg border border-[var(--button-border-color)] text-[var(--text-color)] hover:border-[var(--link-color)] hover:text-[var(--link-color)] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>
        {normalizedLang === 'en' ? 'Article Archive' : '文章归档'}
      </a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 mt-8 mb-8">
      <a
        href={getRelativeLocaleUrl(currentLang, '/appreciation/gallery/')}
        class="group block overflow-hidden rounded-xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/70 hover:border-[var(--link-color)] transition-colors p-8 text-center"
      >
        <div class="text-5xl mb-4">🖼️</div>
        <h2 class="text-xl font-semibold text-[var(--text-color)] group-hover:text-[var(--link-color)] transition-colors">
          {normalizedLang === 'en' ? 'Gallery' : '画廊'}
        </h2>
        <p class="mt-2 text-sm text-[var(--text-color-70)]">
          {normalizedLang === 'en' ? 'My favorite illustrators/IPs and image appreciation' : '我喜爱的画师/IP以及图片鉴赏'}
        </p>
      </a>

      <a
        href={getRelativeLocaleUrl(currentLang, '/appreciation/articles/')}
        class="group block overflow-hidden rounded-xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/70 hover:border-[var(--link-color)] transition-colors p-8 text-center"
      >
        <div class="text-5xl mb-4">📝</div>
        <h2 class="text-xl font-semibold text-[var(--text-color)] group-hover:text-[var(--link-color)] transition-colors">
          {normalizedLang === 'en' ? 'Articles' : '文章'}
        </h2>
        <p class="mt-2 text-sm text-[var(--text-color-70)]">
          {normalizedLang === 'en' ? 'Articles I like, paragraph excerpts, and personal creations' : '我喜欢的文章、段落摘录和个人创作'}
        </p>
      </a>
    </div>
  </div>
  <FabMenu showBackBottom={true} />
</MainPageLayout>
