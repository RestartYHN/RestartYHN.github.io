---
import MainPageLayout from '@layouts/MainPageLayout.astro';
import Cover from '@components/Cover.astro';
import FindMeCard from '@components/misc/FindMeCard.astro';
import HomePostCards from '@components/misc/HomePostCards.astro';
import FabMenu from '@components/control/FabMenu.astro';
import MusicStatsCard from '@components/misc/MusicStatsCard.astro';

import { getAppreciationEntrySort } from '@utils/content-utils';
import { getRelativeLocaleUrl } from '@utils/url-utils';

import zhCN from '@i18n/language/zh-cn';
import en from '@i18n/language/en';

import { siteConfig } from '@/config';
import { i18n } from "astro:config/client";
import type { GetStaticPaths } from 'astro';
import type { Translation } from '@i18n/key';

import i18nit from '@i18n/translation'

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);
const localeContent: Translation = currentLang === "en" ? en : zhCN;

export const getStaticPaths = (async ({ paginate }) => {
  // 首页只生成语言维度路径，不再承担文章分页。
  const paths = [];
  const localeConfig = i18n!;
  for (const locale of localeConfig.locales) {
    const localeCode = typeof locale === 'string' ? locale : locale.path;
    const localeParam = localeCode === localeConfig.defaultLocale ? undefined : localeCode;
    const onePage = paginate([localeCode], {
      pageSize: 1,
      params: { locale: localeParam },
    });

    paths.push(...onePage);
  }

  return paths;
}) satisfies GetStaticPaths

const pageTitle = `${siteConfig.title} - ${siteConfig.subTitle}`;

const appreciationEntries = await getAppreciationEntrySort(currentLang);
const randomApp = appreciationEntries.length > 0
  ? appreciationEntries[Math.floor(Math.random() * appreciationEntries.length)]
  : null;
const appUrl = randomApp ? getRelativeLocaleUrl(currentLang, `/appreciation/articles/${randomApp.id}`) : '';

---

<MainPageLayout title={pageTitle} lang={currentLang}>
  <Cover
    title={t("cover.title.home")}
    rotatingPair={localeContent.cover.rotatingPair.home}
  />
  <FindMeCard />
  <HomePostCards />
  {
    randomApp && (
      <section class="mx-auto mt-6 mb-8 w-full max-w-[var(--page-width)]">
        <div class="mb-4 flex items-end justify-between gap-3 border-b border-[var(--button-border-color)] pb-3">
          <div>
            <h2 class="text-2xl font-bold text-[var(--text-color)]">
              {currentLang === 'en' ? 'Random Appreciation' : '随机鉴赏'}
            </h2>
            <p class="mt-1 text-sm text-[var(--text-color-70)]">
              {currentLang === 'en' ? 'Discover an appreciation article' : '发现一篇鉴赏文章'}
            </p>
          </div>
          <a href={getRelativeLocaleUrl(currentLang, '/appreciation/articles/')} class="text-sm text-[var(--text-color-70)] transition-colors hover:text-[var(--link-color)]">
            {currentLang === 'en' ? 'View all' : '查看全部'} →
          </a>
        </div>
        <a
          href={appUrl}
          class="group block overflow-hidden rounded-xl border border-[var(--button-border-color)] bg-[color-mix(in_oklab,var(--bg-color)_92%,transparent)] shadow-[0_6px_16px_rgba(0,0,0,0.04)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_10px_24px_rgba(0,0,0,0.08)] p-5"
        >
          <div class="mb-2 flex items-center justify-between gap-2 text-xs text-[var(--text-color-70)]">
            <span>{randomApp.data.pubDate.toISOString().substring(0, 10)}</span>
            <span class="rounded-full bg-[var(--button-hover-color)] px-1.5 py-0.5 text-[11px]">
              {randomApp.data.category || ''}
            </span>
          </div>
          <h3 class="mb-1.5 text-base font-bold leading-snug text-[var(--text-color)] transition-colors group-hover:text-[var(--link-color)]">
            {randomApp.data.title}
          </h3>
          <p class="text-xs leading-5 text-[var(--text-color-70)] line-clamp-2">
            {randomApp.data.description}
          </p>
        </a>
      </section>
    )
  }
  <MusicStatsCard />
  <FabMenu showBackBottom={true} />
</MainPageLayout>