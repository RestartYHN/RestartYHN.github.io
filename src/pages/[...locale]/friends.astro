---
import MainPageLayout from '@layouts/MainPageLayout.astro'
import { siteConfig, friendLinkConfig, externalLinkConfig } from '@/config'
import Cover from '@components/Cover.astro';
import Markdown from '@components/misc/Markdown.astro';

import { getSpec } from '@utils/content-utils'

import i18nit from '@i18n/translation';
import { getEntry, render } from 'astro:content'
import { i18n } from "astro:config/client";

export async function getStaticPaths() {
	return i18n?.locales.map(locale => ({ params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) } }));
}

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);
const normalizedLang = currentLang === "en" ? "en" : "zh-cn"

const friendsPost = await getSpec(currentLang, 'friends');
if (!friendsPost) {
    throw new Error('No friends post found');
}
const { Content } = await render(friendsPost);

const pageTitle = t("header.friends") + " - " + siteConfig.title;

const links = externalLinkConfig
  .filter((item) => item.enabled !== false)
  .sort((a, b) => (a.order ?? 999) - (b.order ?? 999))
---

<MainPageLayout title={pageTitle} lang={currentLang}>
    <div class="mx-auto w-full max-w-[var(--page-width)]">
        <Cover title={t("cover.title.friends") + " / " + (currentLang === "en" ? "Links" : "链接")} subTitle={t("cover.subTitle.friends")} />
        
        <h2 class="text-2xl font-bold text-[var(--text-color)] mb-4">{currentLang === "en" ? "Friends" : "友情链接"}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-[var(--text-color)] mb-12">
            {
                friendLinkConfig.map((friend) => (
                    <a 
                        id={`friend-${friend.name}`}
                        data-pagefind-body
                        href={friend.url} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        class="flex items-center p-4 border border-[var(--button-border-color)] rounded-lg shadow-sm active:bg-[var(--button-hover-color)] hover:bg-[var(--button-hover-color)] transition-all duration-300 hover:scale-105"
                    >
                        <div data-pagefind-meta={'category:'+t('header.friends')} style="display:none;"></div>
                        <img 
                            src={friend.avatar} 
                            alt={friend.name} 
                            class="w-16 h-16 rounded-full object-cover mr-4"
                            onerror="this.src='https://www.gravatar.com/avatar/?d=mp'"
                        />
                        <div class="flex-1 min-w-0">
                            <h2 data-pagefind-weight="10.0" class="font-bold text-lg truncate">{friend.name}</h2>
                            <p class="text-[var(--text-color-70)] text-sm">{friend.description}</p>
                        </div>
                    </a>
                ))
            }
        </div>

        <h2 class="text-2xl font-bold text-[var(--text-color)] mb-4">{currentLang === "en" ? "Links" : "外部链接"}</h2>
        <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-12">
            {links.map((item) => (
                <a
                id={`link-${item.title[normalizedLang]}`}
                data-pagefind-body
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group rounded-xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/70 p-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-[var(--link-color)]"
                >
                <div data-pagefind-meta={'category:'+t('header.friends')} style="display:none;"></div>
                <div class="flex items-center justify-between mb-2">
                    <h3 data-pagefind-weight="10.0" class="text-lg font-bold text-[var(--text-color)] group-hover:text-[var(--link-color)] transition-colors">
                    {item.title[normalizedLang]}
                    </h3>
                    <span class="text-xs px-2 py-1 rounded-md bg-[var(--button-hover-color)] text-[var(--text-color-70)]">
                        {item.tag}
                    </span>
                </div>
                <p class="text-sm text-[var(--text-color-70)] leading-relaxed">
                    {item.description[normalizedLang]}
                </p>
                <p class="mt-3 text-xs text-[var(--link-color)] break-all opacity-80">
                    {item.url}
                </p>
                </a>
            ))}
        </section>

        <Markdown class="mb-6 markdown-content onload-animation">
            <Content />
        </Markdown>
    </div>
</MainPageLayout>
